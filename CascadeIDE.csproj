    <Compile Remove="CascadeIDE.Contracts\**\*.cs" />
    <!-- Внешний субмодуль/вендор: не компилировать в IDE (иначе sandbox с top-level Main перехватывает входную точку). -->
    <Compile Remove="externals\**\*.cs" />
    <Compile Remove="CascadeIDE.Tests\**\*.cs" />
    <Compile Remove="CascadeIDE.ArchitectureAnalyzers.Tests\**\*.cs" />
    <Compile Remove="samples\**\*.cs" />
