  <!-- При RID вывод в net10.0/win-x64/; в корне net10.0/ часто остаётся старый apphost от прошлой сборки — Cursor/проводник открывают его и кажется «древняя» сборка. Удаляем только наши артефакты в корне TFM. -->
  <Target Name="RemoveStaleTfmRootHost" AfterTargets="Build" Condition="'$(RuntimeIdentifier)' != ''">
    <PropertyGroup>
      <_TfmRoot>$(MSBuildProjectDirectory)\bin\$(Configuration)\$(TargetFramework)</_TfmRoot>
    </PropertyGroup>
    <ItemGroup>
      <_StaleHost Include="$(_TfmRoot)\$(AssemblyName).exe" />
      <_StaleHost Include="$(_TfmRoot)\$(AssemblyName).dll" />
      <_StaleHost Include="$(_TfmRoot)\$(AssemblyName).pdb" />
      <_StaleHost Include="$(_TfmRoot)\$(AssemblyName).deps.json" />
      <_StaleHost Include="$(_TfmRoot)\$(AssemblyName).runtimeconfig.json" />
    </ItemGroup>
    <Delete Files="@(_StaleHost)" ContinueOnError="true" />
  </Target>
  <!-- Keep MCP protocol docs and proxy tool summaries in sync with XML-doc in partial IdeCommands (IdeCommands.cs + IdeCommands.*.cs). -->
  <PropertyGroup>
    <GenerateIdeProtocolDocs Condition="'$(GenerateIdeProtocolDocs)'==''">true</GenerateIdeProtocolDocs>
    <_IdeProtocolDocGenProject>$(MSBuildProjectDirectory)\tools\CascadeIDE.ProtocolDocGen\CascadeIDE.ProtocolDocGen.csproj</_IdeProtocolDocGenProject>
    <_ProtocolDocGenProgram>$(MSBuildProjectDirectory)\tools\CascadeIDE.ProtocolDocGen\Program.cs</_ProtocolDocGenProgram>
    <_IdeCommandsFile>$(MSBuildProjectDirectory)\Services\IdeCommands.cs</_IdeCommandsFile>
    <_IdeCommandsDocGenerated>$(MSBuildProjectDirectory)\Services\Generated\IdeCommandsDoc.g.cs</_IdeCommandsDocGenerated>
    <_IdeCommandsArgsGenerated>$(MSBuildProjectDirectory)\Services\Generated\IdeCommandsArgsGenerated.g.cs</_IdeCommandsArgsGenerated>
    <_IdeCommandsContractGenerated>$(MSBuildProjectDirectory)\Services\Generated\IdeCommandsContract.g.cs</_IdeCommandsContractGenerated>
    <_IdeExecutorGenerated>$(MSBuildProjectDirectory)\ViewModels\Generated\IdeMcpCommandExecutor.Generated.g.cs</_IdeExecutorGenerated>
    <_McpProtocolDoc>$(MSBuildProjectDirectory)\docs\MCP-PROTOCOL.md</_McpProtocolDoc>
  </PropertyGroup>
  <ItemGroup Condition="'$(GenerateIdeProtocolDocs)'=='true'">
    <_IdeCommandsSources Include="$(MSBuildProjectDirectory)\Services\IdeCommands.cs" />
    <_IdeCommandsSources Include="$(MSBuildProjectDirectory)\Services\IdeCommands.*.cs" />
  </ItemGroup>
  <!-- Generate C# doc map BEFORE compilation (required by IdeMcpToolCatalog). -->
  <Target Name="GenerateIdeCommandsDocCs" BeforeTargets="CoreCompile" Condition="'$(GenerateIdeProtocolDocs)'=='true' and Exists('$(_IdeProtocolDocGenProject)') and Exists('$(_IdeCommandsFile)')" Inputs="@(_IdeCommandsSources);$(_ProtocolDocGenProgram)" Outputs="$(_IdeCommandsDocGenerated);$(_IdeCommandsArgsGenerated);$(_IdeCommandsContractGenerated);$(_IdeExecutorGenerated)">
    <Exec Command="dotnet run --project &quot;$(_IdeProtocolDocGenProject)&quot; --no-restore -- --cs-only &quot;$(MSBuildProjectDirectory)&quot;" />
  </Target>
  <!-- Lint IdeCommands XML-doc contract: require returns for all, example when args exist. -->
  <Target Name="LintIdeCommandsContract" BeforeTargets="CoreCompile" Condition="'$(GenerateIdeProtocolDocs)'=='true' and Exists('$(_IdeProtocolDocGenProject)') and Exists('$(_IdeCommandsFile)')">
    <Exec Command="dotnet run --project &quot;$(_IdeProtocolDocGenProject)&quot; --no-restore -- --lint &quot;$(MSBuildProjectDirectory)&quot;" />
  </Target>
  <!-- Generate Markdown protocol doc AFTER build (keeps docs always fresh). -->
  <Target Name="GenerateMcpProtocolDocMd" AfterTargets="Build" Condition="'$(GenerateIdeProtocolDocs)'=='true' and Exists('$(_IdeProtocolDocGenProject)') and Exists('$(_IdeCommandsFile)') and Exists('$(_McpProtocolDoc)')" Inputs="@(_IdeCommandsSources);$(_McpProtocolDoc);$(_ProtocolDocGenProgram)" Outputs="$(_McpProtocolDoc)">
    <Exec Command="dotnet run --project &quot;$(_IdeProtocolDocGenProject)&quot; --no-restore -- --md-only &quot;$(MSBuildProjectDirectory)&quot;" />
  </Target>
