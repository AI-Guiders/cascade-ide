    <InternalsVisibleTo Include="CascadeIDE.Tests" />
  </ItemGroup>
  <PropertyGroup>
    <!-- RS1038/RS1041/RS1036/RS2008: ложные срабатывания на встроенном анализаторе при ссылке на Microsoft.CodeAnalysis.Workspaces в этом же приложении -->
    <NoWarn>$(NoWarn);RS1038;RS1041;RS1036;RS2008</NoWarn>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <GenerateExecutable>true</GenerateExecutable>
    <Nullable>enable</Nullable>
    <LangVersion>14</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>CascadeIDE</RootNamespace>
    <AssemblyName>CascadeIDE</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
  </PropertyGroup>
  <PropertyGroup Condition="'$(GenerateIdeProtocolDocs)'=='true'">
    <DefineConstants>$(DefineConstants);IDE_COMMANDS_CODEGEN</DefineConstants>
  </PropertyGroup>
  <!-- Быстрая итерация: dotnet build -p:FastBuild=true — без dotnet run ProtocolDocGen (инкрементальная сборка ~секунды вместо десятков). Полная CI: без FastBuild. -->
