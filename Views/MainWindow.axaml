<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CascadeIDE.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:CascadeIDE.Models"
        xmlns:ae="using:AvaloniaEdit"
        xmlns:md="using:Markdown.Avalonia"
        xmlns:views="using:CascadeIDE.Views"
        xmlns:lang="using:CascadeIDE.Lang"
        xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
        xmlns:Ease="using:Avalonia.Animation.Easings"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="CascadeIDE.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}"
        Background="{DynamicResource CascadeTheme.MainWindowBackground}"
        Width="1000" Height="600">

    <Window.Resources>
        <views:SolutionItemIconConverter x:Key="SolutionItemIconConverter"/>
    </Window.Resources>

    <Window.Styles>
        <!-- Меню и кнопки — из темы (ide_set_ui_theme) -->
        <Style Selector="Menu">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.MenuBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.MenuForeground}"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.MenuForeground}"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ButtonForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ButtonHoverBackground}"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ButtonDisabledBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ButtonDisabledForeground}"/>
        </Style>
        <Style Selector="ae|TextEditor.EditorBox">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.EditorBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.EditorForeground}"/>
        </Style>
        <Style Selector="ae|TextEditor.EditorBox:focus">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.EditorBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.EditorForeground}"/>
        </Style>
        <!-- Поле ввода чата — в тон пузырям сообщений -->
        <Style Selector="TextBox#ChatInputBox">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border#ModeBadge">
            <Setter Property="Background" Value="#29437A"/>
            <Setter Property="BorderBrush" Value="#4D72D5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="RenderTransform" Value="scale(1)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.35">
                        <BrushTransition.Easing>
                            <Ease:CubicEaseOut/>
                        </BrushTransition.Easing>
                    </BrushTransition>
                    <BrushTransition Property="Background" Duration="0:0:0.35">
                        <BrushTransition.Easing>
                            <Ease:CubicEaseOut/>
                        </BrushTransition.Easing>
                    </BrushTransition>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.28">
                        <TransformOperationsTransition.Easing>
                            <Ease:CubicEaseOut/>
                        </TransformOperationsTransition.Easing>
                    </TransformOperationsTransition>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border#ModeBadge.power">
            <Setter Property="Background" Value="#36256D"/>
            <Setter Property="BorderBrush" Value="#8A65FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="RenderTransform" Value="scale(1.04)"/>
        </Style>
        <Style Selector="Border#ModeBadge.agentchat">
            <Setter Property="Background" Value="#1E4D3A"/>
            <Setter Property="BorderBrush" Value="#3DCC8C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Border#ModeBadge.debug">
            <Setter Property="Background" Value="#3A2E1E"/>
            <Setter Property="BorderBrush" Value="#C88A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Border.modeCard">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
    </Window.Styles>

    <Window.KeyBindings>
        <KeyBinding Gesture="Alt+1" Command="{Binding SetFocusModeCommand}"/>
        <KeyBinding Gesture="Alt+2" Command="{Binding SetEditorModeCommand}"/>
        <KeyBinding Gesture="Alt+3" Command="{Binding SetBalancedModeCommand}"/>
        <KeyBinding Gesture="Alt+4" Command="{Binding SetPowerModeCommand}"/>
        <KeyBinding Gesture="Alt+5" Command="{Binding SetAgentChatModeCommand}"/>
        <KeyBinding Gesture="Alt+6" Command="{Binding SetDebugModeCommand}"/>
        <KeyBinding Gesture="Ctrl+Alt+M" Command="{Binding CycleUiModeCommand}"/>
        <KeyBinding Gesture="F5" Command="{Binding DebugStartOrContinueCommand}"/>
        <KeyBinding Gesture="Shift+F5" Command="{Binding DebugStopCommand}"/>
        <KeyBinding Gesture="F10" Command="{Binding DebugStepOverCommand}"/>
        <KeyBinding Gesture="F11" Command="{Binding DebugStepIntoCommand}"/>
        <KeyBinding Gesture="Shift+F11" Command="{Binding DebugStepOutCommand}"/>
    </Window.KeyBindings>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
    <DockPanel>
        <!-- Главное меню -->
        <Menu DockPanel.Dock="Top" Background="{DynamicResource CascadeTheme.MenuBackground}">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Открыть решение..." Command="{Binding OpenSolutionCommand}"/>
                <MenuItem Header="_Открыть файл..." Command="{Binding OpenFileFromDialogCommand}"/>
                <Separator/>
                <MenuItem Header="В_ыход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Отладка">
                <MenuItem Header="_Начать или продолжить" Command="{Binding DebugStartOrContinueCommand}" HotKey="F5"/>
                <MenuItem Header="Стартовый проект из _выделения в дереве" Command="{Binding SetStartupProjectFromSelectionCommand}"/>
                <MenuItem Header="_Сбросить стартовый проект" Command="{Binding ClearStartupProjectCommand}"/>
                <Separator/>
                <MenuItem Header="_Присоединиться к процессу…" Command="{Binding DebugAttachCommand}"/>
                <MenuItem Header="_Остановить отладку" Command="{Binding DebugStopCommand}" HotKey="Shift+F5"/>
                <Separator/>
                <MenuItem Header="Шаг с _обходом" Command="{Binding DebugStepOverCommand}" HotKey="F10"/>
                <MenuItem Header="Шаг с _заходом" Command="{Binding DebugStepIntoCommand}" HotKey="F11"/>
                <MenuItem Header="Шаг с _выходом" Command="{Binding DebugStepOutCommand}" HotKey="Shift+F11"/>
            </MenuItem>
            <MenuItem Header="_Вид">
                <MenuItem Header="Палитра _команд" Command="{Binding ToggleCommandPaletteCommand}" HotKey="Ctrl+Q"/>
                <Separator/>
                <MenuItem Header="Обозреватель _решения" ToggleType="CheckBox" IsChecked="{Binding IsSolutionExplorerVisible, Mode=TwoWay}"/>
                <MenuItem Header="_Вывод сборки" ToggleType="CheckBox" IsChecked="{Binding IsBuildOutputVisible, Mode=TwoWay}"/>
                <MenuItem Header="_Чат" ToggleType="CheckBox" IsChecked="{Binding IsChatPanelExpanded, Mode=TwoWay}"/>
                <MenuItem Header="_Терминал" ToggleType="CheckBox" IsChecked="{Binding IsTerminalVisible, Mode=TwoWay}"/>
                <MenuItem Header="_Git" ToggleType="CheckBox" IsChecked="{Binding IsGitPanelVisible, Mode=TwoWay}"/>
                <MenuItem Header="Док_ инструментирования (события, тесты, отладка)"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsInstrumentationDockVisible, Mode=TwoWay}"
                          IsVisible="{Binding ShowInstrumentationLayoutMenu}"/>
                <Separator/>
                <MenuItem Header="_Режим интерфейса">
                    <MenuItem Header="_Focus" ToggleType="Radio" IsChecked="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Focus}" Command="{Binding SetFocusModeCommand}"/>
                    <MenuItem Header="_Editor" ToggleType="Radio" IsChecked="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Editor}" Command="{Binding SetEditorModeCommand}"/>
                    <MenuItem Header="_Balanced" ToggleType="Radio" IsChecked="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Balanced}" Command="{Binding SetBalancedModeCommand}"/>
                    <MenuItem Header="_Power" ToggleType="Radio" IsChecked="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}" Command="{Binding SetPowerModeCommand}"/>
                    <MenuItem Header="Agent _Chat" ToggleType="Radio" IsChecked="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=AgentChat}" Command="{Binding SetAgentChatModeCommand}"/>
                    <MenuItem Header="_Debug" ToggleType="Radio" IsChecked="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Debug}" Command="{Binding SetDebugModeCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Тема">
                    <MenuItem Header="_Светлая" Command="{Binding ApplyLightThemeCommand}"/>
                    <MenuItem Header="_Тёмная" Command="{Binding ApplyDarkThemeCommand}"/>
                    <MenuItem Header="Как _Cursor" Command="{Binding ApplyCursorLikeThemeCommand}"/>
                    <MenuItem Header="Power _классическая (циан)" Command="{Binding ApplyPowerClassicThemeCommand}"/>
                    <Separator/>
                    <MenuItem Header="Открыть файл темы..." Command="{Binding OpenThemeFileCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{Binding Lang_Menu_UiLanguage, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}">
                    <MenuItem Header="{Binding Lang_Menu_Russian, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                              Command="{Binding SetUiLanguageCommand}" CommandParameter="ru-RU"/>
                    <MenuItem Header="{Binding Lang_Menu_English, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                              Command="{Binding SetUiLanguageCommand}" CommandParameter="en-US"/>
                    <Separator/>
                    <MenuItem Header="{Binding Lang_Menu_FollowSystem, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                              Command="{Binding ResetUiLanguageToSystemCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Превью в отдельном _окне" Command="{Binding OpenPreviewWindowCommand}"/>
            </MenuItem>
            <MenuItem Header="_Настройки">
                <MenuItem Header="Параметры AI и чата..." Command="{Binding OpenSettingsCommand}"/>
            </MenuItem>
            <MenuItem Header="_Справка">
                <MenuItem Header="О _программе" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Редактор (2*) и низ (*): сплиттер между ними — иначе низ только Auto по контенту, «увеличить» док нельзя.
             Высоты строк 3–5: MainGridRowHeights → Services/MainGridRowHeightSet.cs; инвалидация — MainWindowViewModel.LayoutNotifications.cs. -->
        <Grid x:Name="MainGrid" ColumnDefinitions="220,4,*,4,340">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="{Binding MainGridRowHeights.Workspace}"/>
            <RowDefinition Height="{Binding MainGridRowHeights.BottomSplitter}"/>
            <RowDefinition Height="{Binding MainGridRowHeights.BottomPanel}"/>
        </Grid.RowDefinitions>
        <!-- Подсказка при работе как MCP-сервер -->
        <views:McpBannerView Grid.Row="0" Grid.ColumnSpan="5"/>
        <views:ToolbarView Grid.Row="1" Grid.ColumnSpan="5" IsVisible="{Binding ShowMainToolbar}"/>

        <views:TaskCockpitView Grid.Row="2" Grid.ColumnSpan="5"/>

        <!-- Solution tree (скрываемый) -->
        <views:SolutionExplorerView Grid.Row="3" Grid.Column="0"/>
        <GridSplitter Grid.Row="3" Grid.Column="1" Width="4" ResizeDirection="Columns" Background="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}" IsVisible="{Binding IsSolutionExplorerVisible}"/>

        <!-- Editor / Documents (Dock MDI, single window; no floating) -->
        <views:DocumentsDockView Grid.Row="3" Grid.Column="2"/>
        <GridSplitter Grid.Row="3" Grid.Column="3"
                      Grid.RowSpan="{Binding ChatPanelMainGridRowSpan}"
                      Width="4" ResizeDirection="Columns" Background="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                      IsVisible="{Binding IsChatPanelColumnVisible}"/>

        <!-- Chat: в Power — RowSpan 2 (рядом с полосой телеметрии только под левым+центром, по концепту). Свёрнут — колонка 0 px, панель скрыта. -->
        <views:ChatPanelView Grid.Row="3" Grid.Column="4" Grid.RowSpan="{Binding ChatPanelMainGridRowSpan}"
                             IsVisible="{Binding IsChatPanelColumnVisible}"/>

        <GridSplitter Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5"
                      Height="6"
                      ResizeDirection="Rows"
                      Background="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                      IsVisible="{Binding ShowWorkspaceBottomChrome}"/>
        <!-- Телеметрия + док: внутренний сплиттер между полосой WORKSPACE и вкладками терминала/сборки. -->
        <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="5" RowDefinitions="Auto,6,*" MinHeight="160"
              IsVisible="{Binding ShowWorkspaceBottomChrome}">
            <views:WorkspaceTelemetrySurfaceHostView Grid.Row="0"
                                                     IsVisible="{Binding ShowTelemetryStrip}"/>
            <GridSplitter Grid.Row="1"
                          Height="6"
                          ResizeDirection="Rows"
                          Background="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                          IsVisible="{Binding ShowTelemetryStrip}"/>
            <!-- Явный DC с окна: корень BottomPanelView (Classes.power) всегда на MainWindowViewModel -->
            <views:BottomPanelView Grid.Row="2"
                                   DataContext="{Binding DataContext, ElementName=RootWindow}"/>
        </Grid>
        <!-- Bloom только над task bar + рабочей областью (строки 2–3); не закрывать низ (сплиттер + телеметрия + док). -->
        <Border x:Name="UiModeBloomOverlay"
                Grid.Row="2" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="5"
                ZIndex="400"
                IsHitTestVisible="False"
                Background="{Binding Chrome.UiModeBloomBrush}"
                Opacity="{Binding Chrome.UiModeBloomOpacity}">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.42">
                        <DoubleTransition.Easing>
                            <Ease:CubicEaseOut/>
                        </DoubleTransition.Easing>
                    </DoubleTransition>
                </Transitions>
            </Border.Transitions>
        </Border>
        <!-- Оверлей подсветки эффективного контрола (ide_highlight_control, как в Comet) -->
        <Canvas x:Name="AgentHighlightLayer" Grid.Row="0" Grid.RowSpan="6" Grid.Column="0" Grid.ColumnSpan="5" IsHitTestVisible="False" ZIndex="1000">
            <Border x:Name="AgentHighlightOverlay" IsVisible="False" BorderBrush="#FF6B9D" BorderThickness="2" Background="#10000000"/>
        </Canvas>
        </Grid>
    </DockPanel>
    <views:CommandPaletteView ZIndex="5000"/>
    </Grid>
</Window>
