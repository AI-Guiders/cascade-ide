<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CascadeIDE.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:CascadeIDE.Models"
        xmlns:ae="using:AvaloniaEdit"
        xmlns:md="using:Markdown.Avalonia"
        xmlns:views="using:CascadeIDE.Views"
        xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="CascadeIDE.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}"
        Background="{DynamicResource CascadeTheme.MainWindowBackground}"
        Width="1000" Height="600">

    <Window.Resources>
        <views:SolutionItemIconConverter x:Key="SolutionItemIconConverter"/>
    </Window.Resources>

    <Window.Styles>
        <!-- Меню и кнопки — из темы (ide_set_ui_theme) -->
        <Style Selector="Menu">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.MenuBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.MenuForeground}"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.MenuForeground}"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ButtonForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ButtonHoverBackground}"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ButtonDisabledBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ButtonDisabledForeground}"/>
        </Style>
        <Style Selector="ae|TextEditor.EditorBox">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.EditorBackground}"/>
        </Style>
        <Style Selector="ae|TextEditor.EditorBox:focus">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.EditorBackground}"/>
        </Style>
        <!-- Поле ввода чата — в тон пузырям сообщений -->
        <Style Selector="TextBox#ChatInputBox">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border#ModeBadge">
            <Setter Property="Background" Value="#29437A"/>
            <Setter Property="BorderBrush" Value="#4D72D5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border#ModeBadge.power">
            <Setter Property="Background" Value="#36256D"/>
            <Setter Property="BorderBrush" Value="#8A65FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border.modeCard">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style Selector="TextBlock.modeCardTitle">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Styles>

    <Window.KeyBindings>
        <KeyBinding Gesture="Alt+1" Command="{Binding SetFocusModeCommand}"/>
        <KeyBinding Gesture="Alt+2" Command="{Binding SetBalancedModeCommand}"/>
        <KeyBinding Gesture="Alt+3" Command="{Binding SetPowerModeCommand}"/>
        <KeyBinding Gesture="Ctrl+Alt+M" Command="{Binding CycleUiModeCommand}"/>
    </Window.KeyBindings>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Главное меню -->
        <Menu DockPanel.Dock="Top" Background="{DynamicResource CascadeTheme.MenuBackground}">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Открыть решение..." Command="{Binding OpenSolutionCommand}"/>
                <Separator/>
                <MenuItem Header="В_ыход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Вид">
                <MenuItem Header="Обозреватель _решения" ToggleType="CheckBox" IsChecked="{Binding IsSolutionExplorerVisible, Mode=TwoWay}"/>
                <MenuItem Header="_Вывод сборки" ToggleType="CheckBox" IsChecked="{Binding IsBuildOutputVisible, Mode=TwoWay}"/>
                <MenuItem Header="_Чат" ToggleType="CheckBox" IsChecked="{Binding IsChatPanelExpanded, Mode=TwoWay}"/>
                <MenuItem Header="_Терминал" ToggleType="CheckBox" IsChecked="{Binding IsTerminalVisible, Mode=TwoWay}"/>
                <MenuItem Header="Док_ инструментирования (события, тесты, отладка)"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsInstrumentationDockVisible, Mode=TwoWay}"
                          IsVisible="{Binding ShowInstrumentationLayoutMenu}"/>
                <Separator/>
                <MenuItem Header="_Режим интерфейса">
                    <MenuItem Header="_Focus" ToggleType="Radio" IsChecked="{Binding IsFocusMode}" Command="{Binding SetFocusModeCommand}"/>
                    <MenuItem Header="_Balanced" ToggleType="Radio" IsChecked="{Binding IsBalancedMode}" Command="{Binding SetBalancedModeCommand}"/>
                    <MenuItem Header="_Power" ToggleType="Radio" IsChecked="{Binding IsPowerMode}" Command="{Binding SetPowerModeCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Тема">
                    <MenuItem Header="_Светлая" Command="{Binding ApplyLightThemeCommand}"/>
                    <MenuItem Header="_Тёмная" Command="{Binding ApplyDarkThemeCommand}"/>
                    <MenuItem Header="Как _Cursor" Command="{Binding ApplyCursorLikeThemeCommand}"/>
                    <Separator/>
                    <MenuItem Header="Открыть файл темы..." Command="{Binding OpenThemeFileCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Превью в отдельном _окне" Command="{Binding OpenPreviewWindowCommand}"/>
            </MenuItem>
            <MenuItem Header="_Настройки">
                <MenuItem Header="Параметры AI и чата..." Command="{Binding OpenSettingsCommand}"/>
            </MenuItem>
            <MenuItem Header="_Справка">
                <MenuItem Header="О _программе" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <Grid x:Name="MainGrid" RowDefinitions="Auto,Auto,Auto,*,Auto,4,Auto" ColumnDefinitions="220,4,*,4,340">
        <!-- Подсказка при работе как MCP-сервер -->
        <views:McpBannerView Grid.Row="0" Grid.ColumnSpan="5"/>
        <views:ToolbarView Grid.Row="1" Grid.ColumnSpan="5"/>

        <views:TaskCockpitView Grid.Row="2" Grid.ColumnSpan="5"/>

        <!-- Solution tree (скрываемый) -->
        <views:SolutionExplorerView Grid.Row="3" Grid.Column="0"/>
        <GridSplitter Grid.Row="3" Grid.Column="1" Width="4" ResizeDirection="Columns" Background="{DynamicResource CascadeTheme.SolutionExplorerBorderBrush}" IsVisible="{Binding IsSolutionExplorerVisible}"/>

        <!-- Editor / Documents (Dock MDI, single window; no floating) -->
        <views:DocumentsDockView Grid.Row="3" Grid.Column="2"/>
        <GridSplitter Grid.Row="3" Grid.Column="3" Width="4" ResizeDirection="Columns" Background="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>

        <!-- Chat -->
        <views:ChatPanelView Grid.Row="3" Grid.Column="4"/>

        <views:TelemetryStripView Grid.Row="4" Grid.ColumnSpan="5" IsVisible="{Binding ShowTelemetryStrip}"/>
        <views:BottomPanelView Grid.Row="5" Grid.RowSpan="2" Grid.ColumnSpan="5"/>
        <!-- Оверлей подсветки эффективного контрола (ide_highlight_control, как в Comet) -->
        <Canvas x:Name="AgentHighlightLayer" Grid.Row="0" Grid.RowSpan="7" Grid.Column="0" Grid.ColumnSpan="5" IsHitTestVisible="False" ZIndex="1000">
            <Border x:Name="AgentHighlightOverlay" IsVisible="False" BorderBrush="#FF6B9D" BorderThickness="2" Background="#10000000"/>
        </Canvas>
        </Grid>
    </DockPanel>
</Window>
