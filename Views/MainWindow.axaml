<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CascadeIDE.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:CascadeIDE.Models"
        xmlns:ae="using:AvaloniaEdit"
        xmlns:md="using:Markdown.Avalonia"
        xmlns:views="using:CascadeIDE.Views"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="CascadeIDE.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="CascadeIDE"
        Background="{DynamicResource CascadeTheme.MainWindowBackground}"
        Width="1000" Height="600">

    <Window.Resources>
        <views:SolutionItemIconConverter x:Key="SolutionItemIconConverter"/>
    </Window.Resources>

    <Window.Styles>
        <!-- Меню и кнопки — из темы (ide_set_ui_theme) -->
        <Style Selector="Menu">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.MenuBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.MenuForeground}"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.MenuForeground}"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ButtonForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ButtonHoverBackground}"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ButtonDisabledBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ButtonDisabledForeground}"/>
        </Style>
        <Style Selector="ae|TextEditor.EditorBox">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.EditorBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.EditorForeground}"/>
        </Style>
        <Style Selector="ae|TextEditor.EditorBox:focus">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.EditorBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.EditorForeground}"/>
        </Style>
        <!-- Поле ввода чата — в тон пузырям сообщений -->
        <Style Selector="TextBox#ChatInputBox">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border#ModeBadge">
            <Setter Property="Background" Value="#29437A"/>
            <Setter Property="BorderBrush" Value="#4D72D5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border#ModeBadge.power">
            <Setter Property="Background" Value="#36256D"/>
            <Setter Property="BorderBrush" Value="#8A65FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border.modeCard">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style Selector="TextBlock.modeCardTitle">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Styles>

    <Window.KeyBindings>
        <KeyBinding Gesture="Alt+1" Command="{Binding SetFocusModeCommand}"/>
        <KeyBinding Gesture="Alt+2" Command="{Binding SetBalancedModeCommand}"/>
        <KeyBinding Gesture="Alt+3" Command="{Binding SetPowerModeCommand}"/>
        <KeyBinding Gesture="Ctrl+Alt+M" Command="{Binding CycleUiModeCommand}"/>
    </Window.KeyBindings>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Главное меню -->
        <Menu DockPanel.Dock="Top" Background="{DynamicResource CascadeTheme.MenuBackground}">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Открыть решение..." Command="{Binding OpenSolutionCommand}"/>
                <Separator/>
                <MenuItem Header="В_ыход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Вид">
                <MenuItem Header="Обозреватель _решения" ToggleType="CheckBox" IsChecked="{Binding IsSolutionExplorerVisible, Mode=TwoWay}"/>
                <MenuItem Header="_Вывод сборки" ToggleType="CheckBox" IsChecked="{Binding IsBuildOutputVisible, Mode=TwoWay}"/>
                <MenuItem Header="_Чат" ToggleType="CheckBox" IsChecked="{Binding IsChatPanelExpanded, Mode=TwoWay}"/>
                <MenuItem Header="_Терминал" ToggleType="CheckBox" IsChecked="{Binding IsTerminalVisible, Mode=TwoWay}"/>
                <Separator/>
                <MenuItem Header="_Режим интерфейса">
                    <MenuItem Header="_Focus" ToggleType="Radio" IsChecked="{Binding IsFocusMode}" Command="{Binding SetFocusModeCommand}"/>
                    <MenuItem Header="_Balanced" ToggleType="Radio" IsChecked="{Binding IsBalancedMode}" Command="{Binding SetBalancedModeCommand}"/>
                    <MenuItem Header="_Power" ToggleType="Radio" IsChecked="{Binding IsPowerMode}" Command="{Binding SetPowerModeCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Тема">
                    <MenuItem Header="_Светлая" Command="{Binding ApplyLightThemeCommand}"/>
                    <MenuItem Header="_Тёмная" Command="{Binding ApplyDarkThemeCommand}"/>
                    <MenuItem Header="Как _Cursor" Command="{Binding ApplyCursorLikeThemeCommand}"/>
                    <Separator/>
                    <MenuItem Header="Открыть файл темы..." Command="{Binding OpenThemeFileCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Превью в отдельном _окне" Command="{Binding OpenPreviewWindowCommand}"/>
            </MenuItem>
            <MenuItem Header="_Настройки">
                <MenuItem Header="Параметры AI и чата..." Command="{Binding OpenSettingsCommand}"/>
            </MenuItem>
            <MenuItem Header="_Справка">
                <MenuItem Header="О _программе" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <Grid x:Name="MainGrid" RowDefinitions="Auto,Auto,Auto,*,4,Auto" ColumnDefinitions="220,4,*,4,340">
        <!-- Подсказка при работе как MCP-сервер -->
        <Border Grid.Row="0" Grid.ColumnSpan="5" Background="{DynamicResource CascadeTheme.McpBannerBackground}" Padding="8,4" IsVisible="{Binding IsMcpServerMode}">
            <TextBlock Text="Управляется агентом (MCP). Не закрывайте окно — подключение будет потеряно." Foreground="{DynamicResource CascadeTheme.McpBannerForeground}" FontSize="12" VerticalAlignment="Center"/>
        </Border>
        <!-- Toolbar -->
        <ScrollViewer Grid.Row="1" Grid.ColumnSpan="5"
                      Margin="8,4"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" Spacing="8" Background="{DynamicResource CascadeTheme.ToolbarBackground}">
                <Button x:Name="OpenSolutionButton" Content="Открыть решение" Command="{Binding OpenSolutionCommand}"/>
                <Button Content="Собрать" Command="{Binding BuildSolutionCommand}" IsEnabled="{Binding !IsBuilding}"/>
                <TextBlock Text="Режим:" VerticalAlignment="Center" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}" Margin="8,0,0,0"/>
                <ComboBox Width="130"
                          ItemsSource="{Binding UiModeOptionsList}"
                          SelectedItem="{Binding UiMode, Mode=TwoWay}"/>
                <Border x:Name="ModeBadge"
                        Classes.power="{Binding IsPowerMode}"
                        Padding="8,2"
                        Margin="4,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding UiMode}" FontWeight="SemiBold" Foreground="#EAF0FF"/>
                </Border>
                <Button Content="{Binding TelemetryButtonText}"
                        Command="{Binding ToggleTerminalCommand}"
                        IsVisible="{Binding ShowPowerTelemetry}"/>
                <Button Content="Show explorer" Command="{Binding ShowSolutionExplorerPanelCommand}" IsVisible="{Binding IsSolutionPanelHidden}"/>
                <Button Content="Show build" Command="{Binding ShowBuildOutputPanelCommand}" IsVisible="{Binding IsBuildPanelHidden}"/>
                <Button Content="Show chat" Command="{Binding ShowChatPanelCommand}" IsVisible="{Binding IsChatPanelHidden}"/>
                <Button Content="Show terminal" Command="{Binding ShowTerminalPanelCommand}" IsVisible="{Binding IsTerminalPanelHidden}"/>
                <Button Content="1-up" Command="{Binding SetSingleEditorGroupCommand}"/>
                <Button Content="2-up" Command="{Binding SetDualEditorGroupCommand}"/>
                <Button Content="3-up" Command="{Binding SetTripleEditorGroupCommand}"/>
                <TextBlock Text="{Binding SolutionPath}" VerticalAlignment="Center" MaxWidth="300" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                <TextBlock Text="{Binding SolutionLoadError}" VerticalAlignment="Center" MaxWidth="350" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource CascadeTheme.ToolbarErrorForeground}"/>
                <TextBlock Text="{Binding OllamaStatus}" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Task bar / status cockpit -->
        <Border Grid.Row="2" Grid.ColumnSpan="5" Margin="8,0,8,4" Padding="8,6"
                IsVisible="{Binding ShowTaskBar}"
                Classes="modeCard">
            <StackPanel Spacing="6">
                <WrapPanel Orientation="Horizontal" ItemHeight="28">
                    <TextBlock Text="{Binding ActiveTaskTitle}" FontWeight="SemiBold" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}" Margin="0,0,8,0"/>
                    <Border Classes="modeCard" Padding="6,2" Margin="0,0,8,0">
                        <TextBlock Text="{Binding ActiveTaskStatus}" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                    </Border>
                    <TextBlock Text="{Binding ActiveTaskProgress, StringFormat='{}Progress: {0}%'}" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}" Margin="0,0,8,0"/>
                </WrapPanel>
                <Border Classes="modeCard" IsVisible="{Binding ShowTelemetryHiddenHint}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Telemetry panel is hidden. Open it to see the dashboard."
                                   Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"
                                   VerticalAlignment="Center"/>
                        <Button Content="Show now" Command="{Binding ToggleTerminalCommand}"/>
                    </StackPanel>
                </Border>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <WrapPanel Orientation="Horizontal" ItemHeight="30">
                        <Button Content="Fix failing tests" Command="{Binding FixFailingTestsCommand}" IsVisible="{Binding ShowQuickActions}" Margin="0,0,6,0"/>
                        <Button Content="Investigate nullref" Command="{Binding InvestigateNullrefCommand}" IsVisible="{Binding ShowQuickActions}" Margin="0,0,6,0"/>
                        <Button Content="Prepare commit" Command="{Binding PrepareCommitCommand}" IsVisible="{Binding ShowQuickActions}" Margin="0,0,6,0"/>
                        <Border Classes="modeCard" Padding="6,2" Margin="0,0,6,0"><TextBlock Text="{Binding ComplexityBadge, StringFormat='{}Complexity: {0}'}" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/></Border>
                        <Border Classes="modeCard" Padding="6,2" Margin="0,0,6,0"><TextBlock Text="{Binding ImpactedTestsBadge, StringFormat='{}Impacted tests: {0}'}" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/></Border>
                        <Border Classes="modeCard" Padding="6,2" Margin="0,0,6,0"><TextBlock Text="{Binding FilesChangedBadge, StringFormat='{}Files changed: {0}'}" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/></Border>
                    </WrapPanel>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Solution tree (скрываемый) -->
        <Border Grid.Row="3" Grid.Column="0" x:Name="SolutionExplorerBorder" BorderBrush="{DynamicResource CascadeTheme.SolutionExplorerBorderBrush}" BorderThickness="0,0,1,0" Padding="4" IsVisible="{Binding IsSolutionExplorerVisible}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Решение" FontWeight="SemiBold" Margin="4" Foreground="{DynamicResource CascadeTheme.SolutionExplorerHeaderForeground}"/>
                <TreeView ItemsSource="{Binding SolutionRoots}"
                          SelectedItem="{Binding SelectedSolutionItem}"
                          Margin="0,4,0,0">
                    <TreeView.Styles>
                        <!-- Узлы дерева раскрыты по умолчанию, чтобы можно было спуститься к проектам и файлам -->
                        <Style Selector="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                        </Style>
                    </TreeView.Styles>
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate DataType="models:SolutionItem" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="{Binding Converter={StaticResource SolutionItemIconConverter}}"
                                       Width="16" Height="16" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource CascadeTheme.SolutionExplorerHeaderForeground}"/>
                            </StackPanel>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>
        </Border>
        <GridSplitter Grid.Row="3" Grid.Column="1" Width="4" ResizeDirection="Columns" Background="{DynamicResource CascadeTheme.SolutionExplorerBorderBrush}" IsVisible="{Binding IsSolutionExplorerVisible}"/>

        <!-- Editor + (опционально) Markdown preview + Build output -->
        <Border Grid.Row="3" Grid.Column="2" BorderBrush="{DynamicResource CascadeTheme.EditorColumnBorderBrush}" BorderThickness="0,0,1,0" Background="{DynamicResource CascadeTheme.EditorColumnBackground}" Padding="4">
            <Grid x:Name="EditorColumnGrid" RowDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                    <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <Border x:Name="Group1TabsDropHost" DragDrop.AllowDrop="True" DragDrop.Drop="OnGroup1TabsDrop" DragDrop.DragOver="OnGroupTabsDragOver">
                            <ItemsControl x:Name="Group1Tabs" ItemsSource="{Binding Group1Documents}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:OpenDocumentViewModel">
                                        <Border Classes="modeCard" Padding="4,2">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <Button Content="{Binding DisplayTitle}" PointerPressed="OnDocumentTabPointerPressed"
                                                        Command="{Binding DataContext.ActivateDocumentCommand, ElementName=RootWindow}"
                                                        CommandParameter="{Binding FilePath}"/>
                                                <Button Content="Pin"
                                                        Command="{Binding DataContext.TogglePinDocumentCommand, ElementName=RootWindow}"
                                                        CommandParameter="{Binding FilePath}"/>
                                                <Button Content="G2" Command="{Binding DataContext.MoveDocumentToGroup2Command, ElementName=RootWindow}" CommandParameter="{Binding FilePath}"/>
                                                <Button Content="G3" Command="{Binding DataContext.MoveDocumentToGroup3Command, ElementName=RootWindow}" CommandParameter="{Binding FilePath}"/>
                                                <Button Content="x"
                                                        Command="{Binding DataContext.CloseDocumentCommand, ElementName=RootWindow}"
                                                        CommandParameter="{Binding FilePath}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </ScrollViewer>
                    <Button Grid.Column="1"
                            Margin="6,0,0,0"
                            Content="Reopen closed"
                            Command="{Binding ReopenClosedDocumentCommand}"/>
                </Grid>
                <TextBlock Grid.Row="1" Text="{Binding CurrentFilePath}" Margin="4" Foreground="{DynamicResource CascadeTheme.CurrentFileForeground}" TextTrimming="CharacterEllipsis"/>
                <Grid Grid.Row="2" ColumnDefinitions="*,4,*,4,*">
                    <Grid Grid.Column="0" x:Name="EditorContentGrid" ColumnDefinitions="*,0">
                        <ae:TextEditor Grid.Column="0"
                                  x:Name="Editor"
                                  Classes="EditorBox"
                                  ShowLineNumbers="True"
                                  FontFamily="Consolas,Cascadia Code,monospace"
                                  FontSize="13"
                                  Padding="8"/>
                        <Border Grid.Column="1" x:Name="InlinePreviewBorder" Background="{DynamicResource CascadeTheme.MarkdownPreviewPanelBackground}" BorderBrush="{DynamicResource CascadeTheme.MarkdownPreviewPanelBorderBrush}" BorderThickness="1,0,0,0" Padding="8" IsVisible="{Binding IsMarkdownPreviewVisible}">
                            <md:MarkdownScrollViewer x:Name="InlineMarkdownPreview" Markdown="{Binding EditorText}"/>
                        </Border>
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns" IsVisible="{Binding ShowEditorGroup2}" Background="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>
                    <Border Grid.Column="2" Classes="modeCard" IsVisible="{Binding ShowEditorGroup2}">
                        <Grid RowDefinitions="Auto,*">
                            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <Border x:Name="Group2TabsDropHost" DragDrop.AllowDrop="True" DragDrop.Drop="OnGroup2TabsDrop" DragDrop.DragOver="OnGroupTabsDragOver">
                                    <ItemsControl x:Name="Group2Tabs" ItemsSource="{Binding Group2Documents}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="4"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:OpenDocumentViewModel">
                                                <Button Content="{Binding DisplayTitle}"
                                                        PointerPressed="OnDocumentTabPointerPressed"
                                                        Command="{Binding DataContext.ActivateDocumentCommand, ElementName=RootWindow}"
                                                        CommandParameter="{Binding FilePath}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </ScrollViewer>
                            <TextBox Grid.Row="1"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas,monospace"
                                     FontSize="12"
                                     Text="{Binding EditorTextGroup2}"/>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="3" Width="4" ResizeDirection="Columns" IsVisible="{Binding ShowEditorGroup3}" Background="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>
                    <Border Grid.Column="4" Classes="modeCard" IsVisible="{Binding ShowEditorGroup3}">
                        <Grid RowDefinitions="Auto,*">
                            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <Border x:Name="Group3TabsDropHost" DragDrop.AllowDrop="True" DragDrop.Drop="OnGroup3TabsDrop" DragDrop.DragOver="OnGroupTabsDragOver">
                                    <ItemsControl x:Name="Group3Tabs" ItemsSource="{Binding Group3Documents}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="4"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:OpenDocumentViewModel">
                                                <Button Content="{Binding DisplayTitle}"
                                                        PointerPressed="OnDocumentTabPointerPressed"
                                                        Command="{Binding DataContext.ActivateDocumentCommand, ElementName=RootWindow}"
                                                        CommandParameter="{Binding FilePath}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </ScrollViewer>
                            <TextBox Grid.Row="1"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas,monospace"
                                     FontSize="12"
                                     Text="{Binding EditorTextGroup3}"/>
                        </Grid>
                    </Border>
                </Grid>
                <GridSplitter Grid.Row="3" Height="4" ResizeDirection="Rows" Background="{DynamicResource CascadeTheme.BuildOutputBorderBrush}" IsVisible="{Binding IsBuildOutputVisible}"/>
                <Border Grid.Row="4" IsVisible="{Binding IsBuildOutputVisible}" MinHeight="80" Margin="0,4,0,0" BorderBrush="{DynamicResource CascadeTheme.BuildOutputBorderBrush}" BorderThickness="0,1,0,0" Padding="4">
                    <DockPanel>
                        <Button DockPanel.Dock="Top" Content="Скрыть вывод" Command="{Binding HideBuildOutputCommand}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding BuildOutput}" IsReadOnly="True" TextWrapping="NoWrap" FontFamily="Consolas,monospace" FontSize="12" Background="{DynamicResource CascadeTheme.BuildOutputBackground}" BorderThickness="0"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
                <GridSplitter Grid.Row="5" Height="4" ResizeDirection="Rows" Background="{DynamicResource CascadeTheme.BuildOutputBorderBrush}" IsVisible="{Binding IsDebugPanelVisible}"/>
                <Border Grid.Row="6" IsVisible="{Binding IsDebugPanelVisible}" MinHeight="60" Margin="0,4,0,0" BorderBrush="{DynamicResource CascadeTheme.BuildOutputBorderBrush}" BorderThickness="0,1,0,0" Padding="4" Background="{DynamicResource CascadeTheme.BuildOutputBackground}">
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Стек вызовов" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource CascadeTheme.CurrentFileForeground}" Margin="0,0,0,4"/>
                            <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding DebugStackFrames}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:DebugStackFrameViewModel">
                                            <TextBlock FontSize="11" Foreground="{DynamicResource CascadeTheme.EditorForeground}" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Переменные" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource CascadeTheme.CurrentFileForeground}" Margin="0,0,0,4"/>
                            <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding DebugVariables}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:DebugVariableViewModel">
                                            <TextBlock FontSize="11" Foreground="{DynamicResource CascadeTheme.EditorForeground}" TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <Run Text=" = "/>
                                                <Run Text="{Binding Value}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        <GridSplitter Grid.Row="3" Grid.Column="3" Width="4" ResizeDirection="Columns" Background="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>

        <!-- Chat -->
        <Border x:Name="ChatPanel" Grid.Row="3" Grid.Column="4" Background="{DynamicResource CascadeTheme.ChatPanelBackground}" Padding="8">
            <Grid RowDefinitions="Auto,Auto,Auto,4,120,Auto">
                <Border Grid.Row="0" IsVisible="{Binding ShowAgentOperations}" Classes="modeCard" Margin="0,0,0,6">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="modeCardTitle" Text="Agent Operations"/>
                        <TextBlock Text="{Binding ActiveObjective}" TextWrapping="Wrap" Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
                        <ItemsControl ItemsSource="{Binding AgentToolCalls}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding RiskSummary}" Foreground="{DynamicResource CascadeTheme.ToolbarErrorForeground}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ResultSummary}" Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" IsVisible="{Binding ShowAgentTrace}" Classes="modeCard" Margin="0,0,0,6">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="modeCardTitle" Text="Agent Trace Timeline"/>
                        <ItemsControl ItemsSource="{Binding AgentTraceTimeline}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}" Margin="0,0,0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="Explain this step" Command="{Binding ExplainCurrentStepCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="2" IsVisible="{Binding ShowSafetyControls}" Classes="modeCard" Margin="0,0,0,6">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="modeCardTitle" Text="Safety Level Control"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Content="L1" Command="{Binding SetSafetyL1Command}"/>
                            <Button Content="L2" Command="{Binding SetSafetyL2Command}"/>
                            <Button Content="L3" Command="{Binding SetSafetyL3Command}"/>
                            <TextBlock Text="{Binding SafetyLevel}" VerticalAlignment="Center" Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}" Margin="6,0,0,0"/>
                        </StackPanel>
                        <Button Content="Emergency stop" Command="{Binding EmergencyStopCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
                <GridSplitter Grid.Row="3" Height="4" ResizeDirection="Rows" Background="{DynamicResource CascadeTheme.ChatPanelBackground}" IsVisible="{Binding IsChatPanelExpanded}"/>
                <DockPanel Grid.Row="4">
                    <Button DockPanel.Dock="Left" Content="▶ Чат" Command="{Binding ToggleChatPanelCommand}"
                            IsVisible="{Binding !IsChatPanelExpanded}"
                            ToolTip.Tip="Развернуть чат" Padding="6,8" Margin="0,0,4,0"
                            VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4" IsVisible="{Binding IsChatPanelExpanded}">
                        <Button Content="{Binding ChatPanelToggleButtonText}" Command="{Binding ToggleChatPanelCommand}" ToolTip.Tip="Свернуть чат" Padding="4,2"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" IsVisible="{Binding IsChatPanelExpanded}">
                        <ItemsControl ItemsSource="{Binding ChatMessages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:ChatMessageViewModel">
                                    <Border Margin="0,4" Padding="8" Background="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}" CornerRadius="4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Role}" FontWeight="SemiBold" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}" FontSize="11"/>
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
                <StackPanel Grid.Row="5" Spacing="4" Margin="0,8,0,0" IsVisible="{Binding IsChatPanelExpanded}" MinHeight="56">
                    <TextBox x:Name="ChatInputBox"
                             Text="{Binding ChatInput, Mode=TwoWay}"
                             Watermark="Сообщение…"
                             MinHeight="40"
                             AcceptsReturn="True"
                             IsEnabled="{Binding !IsChatLoading}"
                             TextWrapping="Wrap"/>
                    <Button Content="Отправить" Command="{Binding SendChatCommand}" Background="{DynamicResource CascadeTheme.SendButtonBackground}" Foreground="{DynamicResource CascadeTheme.SendButtonForeground}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Разделитель для терминала -->
        <GridSplitter Grid.Row="4" Grid.ColumnSpan="5" Height="4" ResizeDirection="Rows" Background="{DynamicResource CascadeTheme.BuildOutputBorderBrush}" IsVisible="{Binding IsTerminalVisible}"/>
        <!-- Терминал (скрываемый, высота меняется перетаскиванием разделителя) -->
        <Border Grid.Row="5" Grid.ColumnSpan="5" IsVisible="{Binding IsTerminalVisible}" MinHeight="120" BorderBrush="{DynamicResource CascadeTheme.BuildOutputBorderBrush}" BorderThickness="0,1,0,0" Padding="4" Background="{DynamicResource CascadeTheme.TerminalBackground}">
            <DockPanel>
                <Border DockPanel.Dock="Top" IsVisible="{Binding ShowPowerTelemetry}" Classes="modeCard" Margin="0,0,0,4">
                    <StackPanel Spacing="4">
                        <WrapPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ActiveTaskStatus, StringFormat='{}Build: {0}'}" Foreground="{DynamicResource CascadeTheme.TerminalForeground}" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding ResultSummary}" Foreground="{DynamicResource CascadeTheme.TerminalForeground}" Margin="0,0,12,0" MaxWidth="320" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding RiskSummary}" Foreground="{DynamicResource CascadeTheme.TerminalForeground}" Margin="0,0,12,0" MaxWidth="320" TextTrimming="CharacterEllipsis"/>
                        </WrapPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding EventTimeline}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource CascadeTheme.TerminalForeground}" FontSize="11" Margin="0,0,10,0"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
                <TextBlock DockPanel.Dock="Top" Text="Терминал" Foreground="{DynamicResource CascadeTheme.TerminalForeground}" FontSize="11" Margin="0,0,0,4"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TextBox Text="{Binding TerminalOutput, Mode=OneWay}" IsReadOnly="True" TextWrapping="NoWrap" FontFamily="Consolas,monospace" FontSize="12" Background="Transparent" Foreground="{DynamicResource CascadeTheme.TerminalForeground}" BorderThickness="0"/>
                </ScrollViewer>
                <TextBox x:Name="TerminalInputBox" DockPanel.Dock="Bottom" Text="{Binding TerminalInput, Mode=TwoWay}" Watermark="Команда (Enter — выполнить)" FontFamily="Consolas,monospace" FontSize="12" Background="{DynamicResource CascadeTheme.TerminalInputBackground}" Foreground="{DynamicResource CascadeTheme.TerminalForeground}" Margin="0,4,0,0"/>
            </DockPanel>
        </Border>
        <!-- Оверлей подсветки эффективного контрола (ide_highlight_control, как в Comet) -->
        <Canvas x:Name="AgentHighlightLayer" Grid.Row="0" Grid.RowSpan="6" Grid.Column="0" Grid.ColumnSpan="5" IsHitTestVisible="False" ZIndex="1000">
            <Border x:Name="AgentHighlightOverlay" IsVisible="False" BorderBrush="#FF6B9D" BorderThickness="2" Background="#10000000"/>
        </Canvas>
        </Grid>
    </DockPanel>
</Window>
