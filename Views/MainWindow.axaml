<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CascadeIDE.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:CascadeIDE.Models"
        xmlns:ae="using:AvaloniaEdit"
        xmlns:md="using:Markdown.Avalonia"
        xmlns:views="using:CascadeIDE.Views"
        xmlns:chrome="using:CascadeIDE.Features.UiChrome"
        xmlns:lang="using:CascadeIDE.Lang"
        xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="CascadeIDE.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}"
        Background="{DynamicResource CascadeTheme.MainWindowBackground}"
        Width="1000" Height="600">

    <Window.Resources>
        <views:SolutionItemIconConverter x:Key="SolutionItemIconConverter"/>
    </Window.Resources>

    <Window.Styles>
        <!-- Меню и кнопки — из темы (ide_set_ui_theme) -->
        <Style Selector="Menu">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.MenuBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.MenuForeground}"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.MenuForeground}"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ButtonForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ButtonHoverBackground}"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ButtonDisabledBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ButtonDisabledForeground}"/>
        </Style>
        <Style Selector="ae|TextEditor.EditorBox">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.EditorBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.EditorForeground}"/>
        </Style>
        <Style Selector="ae|TextEditor.EditorBox:focus">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.EditorBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.EditorForeground}"/>
        </Style>
        <!-- Поле ввода чата — в тон пузырям сообщений -->
        <Style Selector="TextBox#ChatInputBox">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border.modeCard">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
    <DockPanel>
        <!-- Главное меню -->
        <Menu DockPanel.Dock="Top" Background="{DynamicResource CascadeTheme.MenuBackground}">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Открыть решение..." Command="{Binding OpenSolutionCommand}"/>
                <MenuItem Header="_Открыть папку..." Command="{Binding OpenFolderCommand}"/>
                <MenuItem Header="_Открыть файл..." Command="{Binding OpenFileFromDialogCommand}"/>
                <MenuItem Header="Export expanded _Markdown..." Command="{Binding ExportExpandedMarkdownCommand}"/>
                <Separator/>
                <MenuItem Header="В_ыход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Отладка">
                <MenuItem x:Name="MenuDebugStartOrContinue" Header="_Начать или продолжить" Command="{Binding DebugStartOrContinueCommand}"/>
                <MenuItem Header="Стартовый проект из _выделения в дереве" Command="{Binding SetStartupProjectFromSelectionCommand}"/>
                <MenuItem Header="_Сбросить стартовый проект" Command="{Binding ClearStartupProjectCommand}"/>
                <Separator/>
                <MenuItem Header="_Присоединиться к процессу…" Command="{Binding DebugAttachCommand}"/>
                <MenuItem x:Name="MenuDebugStop" Header="_Остановить отладку" Command="{Binding DebugStopCommand}"/>
                <Separator/>
                <MenuItem x:Name="MenuDebugStepOver" Header="Шаг с _обходом" Command="{Binding DebugStepOverCommand}"/>
                <MenuItem x:Name="MenuDebugStepInto" Header="Шаг с _заходом" Command="{Binding DebugStepIntoCommand}"/>
                <MenuItem x:Name="MenuDebugStepOut" Header="Шаг с _выходом" Command="{Binding DebugStepOutCommand}"/>
            </MenuItem>
            <MenuItem Header="_Вид">
                <MenuItem x:Name="MenuCommandPalette" Header="Палитра _команд" Command="{Binding ToggleCommandPaletteCommand}"/>
                <Separator/>
                <MenuItem Header="Карта _workspace (PFD)" ToggleType="CheckBox" IsChecked="{Binding IsPfdRegionExpanded, Mode=TwoWay}"/>
                <MenuItem Header="_Вывод сборки" ToggleType="CheckBox" IsChecked="{Binding IsBuildOutputVisible, Mode=TwoWay}"/>
                <MenuItem Header="_Чат" ToggleType="CheckBox" IsChecked="{Binding IsMfdRegionExpanded, Mode=TwoWay}"/>
                <MenuItem Header="_Терминал" ToggleType="CheckBox" IsChecked="{Binding IsTerminalVisible, Mode=TwoWay}"/>
                <MenuItem Header="_Git" ToggleType="CheckBox" IsChecked="{Binding IsGitPanelVisible, Mode=TwoWay}"/>
                <MenuItem Header="Док_ инструментирования (события, тесты, отладка)"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsInstrumentationDockVisible, Mode=TwoWay}"
                          IsVisible="{Binding ShowInstrumentationLayoutMenu}"/>
                <MenuItem Header="_Режим интерфейса: Flight" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="_Тема">
                    <MenuItem Header="_Светлая" Command="{Binding ApplyLightThemeCommand}"/>
                    <MenuItem Header="_Тёмная" Command="{Binding ApplyDarkThemeCommand}"/>
                    <MenuItem Header="Как _Cursor" Command="{Binding ApplyCursorLikeThemeCommand}"/>
                    <MenuItem Header="Power _классическая (циан)" Command="{Binding ApplyPowerClassicThemeCommand}"/>
                    <Separator/>
                    <MenuItem Header="Открыть файл темы..." Command="{Binding OpenThemeFileCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{Binding Lang_Menu_UiLanguage, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}">
                    <MenuItem Header="{Binding Lang_Menu_Russian, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                              Command="{Binding SetUiLanguageCommand}" CommandParameter="ru-RU"/>
                    <MenuItem Header="{Binding Lang_Menu_English, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                              Command="{Binding SetUiLanguageCommand}" CommandParameter="en-US"/>
                    <Separator/>
                    <MenuItem Header="{Binding Lang_Menu_FollowSystem, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                              Command="{Binding ResetUiLanguageToSystemCommand}"/>
                </MenuItem>
                <MenuItem Header="Превью в отдельном _окне" Command="{Binding OpenPreviewWindowCommand}"/>
            </MenuItem>
            <MenuItem Header="_Настройки">
                <MenuItem Header="Параметры AI и чата..." Command="{Binding OpenSettingsCommand}"/>
            </MenuItem>
            <MenuItem Header="_Справка">
                <MenuItem Header="О _программе" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Рабочая область: три колонки PFD | Forward | MFD (без отдельных сплиттеров). -->
        <Grid x:Name="MainGrid" ColumnDefinitions="220,*,340">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <views:McpBannerView Grid.Row="0" Grid.ColumnSpan="3"/>
        <views:ToolbarView Grid.Row="1" Grid.ColumnSpan="3" IsVisible="{Binding ShowMainToolbar}"/>

        <views:TaskCockpitView Grid.Row="2" Grid.ColumnSpan="3"/>

        <chrome:AttentionZoneContainer Zone="Pfd" Grid.Row="3" Grid.Column="0">
            <views:WorkspaceNavigationMapView />
        </chrome:AttentionZoneContainer>

        <chrome:AttentionZoneContainer Zone="Forward" Grid.Row="3" Grid.Column="1">
            <views:DocumentsDockView />
        </chrome:AttentionZoneContainer>

        <chrome:AttentionZoneContainer Zone="Mfd" Grid.Row="3" Grid.Column="2"
                                       IsVisible="{Binding IsMfdColumnVisible}">
            <views:SecondaryShellView DataContext="{Binding DataContext, ElementName=RootWindow}"
                                      MinHeight="0"/>
        </chrome:AttentionZoneContainer>

        <!-- Оверлей подсветки контрола (ide_highlight_control, MCP) -->
        <Canvas x:Name="AgentHighlightLayer" Grid.Row="0" Grid.RowSpan="4" Grid.Column="0" Grid.ColumnSpan="3" IsHitTestVisible="False" ZIndex="1000">
            <Border x:Name="AgentHighlightOverlay" IsVisible="False" BorderBrush="#FF6B9D" BorderThickness="2" Background="#10000000"/>
        </Canvas>
        </Grid>
    </DockPanel>
    <views:CommandPaletteView ZIndex="5000"/>
    </Grid>
</Window>
