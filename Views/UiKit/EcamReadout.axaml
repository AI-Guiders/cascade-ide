<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:CascadeIDE.Views"
             x:Class="CascadeIDE.Views.UiKit.EcamReadout"
             x:Name="Root"
             x:CompileBindings="False">
    <UserControl.Resources>
        <views:StringNotEmptyToBoolConverter x:Key="StringNotEmptyToBool"/>
    </UserControl.Resources>
    <Border Padding="10,8"
            CornerRadius="6"
            Background="{DynamicResource CascadeTheme.PanelBackgroundBrush}"
            BorderBrush="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"
            BorderThickness="1">
        <StackPanel Spacing="2">
            <TextBlock Text="{Binding Label, ElementName=Root}"
                       FontSize="10"
                       Opacity="0.75"
                       Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <TextBlock Text="{Binding ValueText, ElementName=Root}"
                       FontSize="{Binding ValueFontSize, ElementName=Root}"
                       FontWeight="{Binding ValueFontWeight, ElementName=Root}"
                       Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
            <TextBlock Text="{Binding SubText, ElementName=Root}"
                       IsVisible="{Binding SubText, ElementName=Root, Converter={StaticResource StringNotEmptyToBool}}"
                       FontSize="10"
                       Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
        </StackPanel>
    </Border>
</UserControl>

