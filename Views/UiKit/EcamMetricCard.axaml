<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CascadeIDE.Views.UiKit.EcamMetricCard"
             x:Name="Root"
             x:CompileBindings="False">
    <Border Classes="modeCard"
            Padding="10"
            Background="{DynamicResource CascadeTheme.PanelBackgroundBrush}"
            BorderBrush="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <TextBlock Grid.Row="0"
                       Text="{Binding Title, ElementName=Root}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Opacity="0.75"
                       Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <ContentPresenter Grid.Row="1"
                              Content="{Binding Content, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </Grid>
    </Border>
</UserControl>

