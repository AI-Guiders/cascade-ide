<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             x:Class="CascadeIDE.Views.CascadeChordHudStripView"
             x:DataType="vm:MainWindowViewModel"
             VerticalAlignment="Center">
    <!-- Постоянный блок рядом с CMD: поле + выпадающий список по префиксу (ADR 0060). -->
    <Panel MinWidth="220" MaxWidth="400">
        <TextBox x:Name="ChordQueryBox"
                 Height="30"
                 MinWidth="200"
                 MaxWidth="400"
                 FontFamily="Consolas,Cascadia Mono,Courier New,monospace"
                 FontSize="13"
                 PlaceholderText="{Binding CascadeChordHudWatermark}"
                 Text="{Binding CascadeChordHudMelodyText, Mode=TwoWay}"
                 IsEnabled="{Binding IsCascadeChordOverlayVisible}"
                 ToolTip.Tip="{Binding CascadeChordOverlayCompactFooter}"/>
        <Popup x:Name="ChordSuggestionsPopup"
               PlacementTarget="{Binding #ChordQueryBox}"
               Placement="BottomEdgeAlignedLeft"
               IsOpen="{Binding IsCascadeChordDropdownOpen, Mode=OneWay}"
               IsLightDismissEnabled="True"
               Closed="OnChordPopupClosed">
            <Border MinWidth="200"
                    MaxWidth="480"
                    MaxHeight="260"
                    Padding="0"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                    Background="{DynamicResource CascadeTheme.CommandPaletteQueryBackground}"
                    BoxShadow="0 6 24 0 #48000000">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0"
                               Padding="10,8"
                               FontSize="12"
                               IsVisible="{Binding CascadeChordOverlayNoMatches}"
                               Foreground="{DynamicResource CascadeTheme.CommandPaletteUnavailableForeground}"
                               Text="Нет alias с таким префиксом"/>
                    <ListBox x:Name="ChordSuggestionList"
                             Grid.Row="1"
                             MaxHeight="220"
                             Background="Transparent"
                             BorderThickness="0"
                             IsVisible="{Binding HasChordDropdownItems}"
                             ItemsSource="{Binding CascadeChordOverlaySuggestions}"
                             SelectionChanged="OnChordSuggestionSelectionChanged">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="MinHeight" Value="32"/>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource CascadeTheme.ButtonHoverBackground}"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:CascadeChordOverlaySuggestion">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0"
                                               FontFamily="Consolas,Cascadia Mono,Courier New,monospace"
                                               FontSize="12.5"
                                               Foreground="{DynamicResource CascadeTheme.CommandPaletteHotkeyPillForeground}"
                                               Text="{Binding Alias}"/>
                                    <TextBlock Grid.Column="1"
                                               Margin="12,0,0,0"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource CascadeTheme.CommandPaletteTitleForeground}"
                                               Text="{Binding Title}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Popup>
    </Panel>
</UserControl>
