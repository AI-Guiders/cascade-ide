<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:views="using:CascadeIDE.Views"
             x:Class="CascadeIDE.Views.AiChatSettingsMfdPageView"
             x:DataType="vm:MainWindowViewModel">
    <DockPanel>
        <views:PanelChromeHeader DockPanel.Dock="Top" Title="Настройки" UppercaseTitle="False"/>
        <views:SettingsShellView MinHeight="360"/>
    </DockPanel>
</UserControl>
