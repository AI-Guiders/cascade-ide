<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
             x:Class="CascadeIDE.Views.DocumentsDockView"
             Classes.power="{Binding IsPowerMode}"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="UserControl">
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="UserControl.power">
            <Setter Property="Margin" Value="8,6,8,6"/>
        </Style>
        <Style Selector="Border#DockIslandInner">
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.EditorColumnBackground}"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
        <Style Selector="Border#DockIslandInner.power">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BoxShadow" Value="0 0 24 0 #5500C8E8, 0 4 20 0 #28000000"/>
        </Style>
    </UserControl.Styles>
    <Panel>
        <Border IsVisible="{Binding IsPowerMode}"
                IsHitTestVisible="False"
                Background="{DynamicResource CascadeTheme.PowerEditorIslandFrameBrush}"
                CornerRadius="14"/>
        <Border x:Name="DockIslandInner"
                ZIndex="1"
                Classes.power="{Binding IsPowerMode}">
            <dock:DockControl x:Name="DocumentsDock"
                              DefaultContext="{Binding}"
                              Factory="{Binding DockFactory}"
                              Layout="{Binding DockLayout}"
                              InitializeFactory="True"
                              InitializeLayout="True"/>
        </Border>
    </Panel>
</UserControl>
