<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:chrome="using:CascadeIDE.Features.UiChrome"
             xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
             x:Class="CascadeIDE.Views.DocumentsDockView"
             Classes.power="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="UserControl">
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="UserControl.power">
            <Setter Property="Margin" Value="8,6,8,6"/>
        </Style>
        <Style Selector="Border#DockIslandInner">
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.EditorColumnBackground}"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
        <Style Selector="Border#DockIslandInner.power">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BoxShadow" Value="0 0 24 0 #5500C8E8, 0 4 20 0 #28000000"/>
        </Style>
    </UserControl.Styles>
    <Panel>
        <Border IsVisible="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}"
                IsHitTestVisible="False"
                Background="{DynamicResource CascadeTheme.PowerEditorIslandFrameBrush}"
                CornerRadius="14"/>
        <Border x:Name="DockIslandInner"
                ZIndex="1"
                Classes.power="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- ADR 0021 §9: HUD — слой на лобовом; визуальный хост — только при непустом баннере. -->
                <chrome:AttentionZoneContainer Zone="Hud" Grid.Row="0"
                                               IsVisible="{Binding IsEditorHudBannerVisible}">
                    <Border Background="#1AFFB300"
                            BorderBrush="#45FFB300"
                            BorderThickness="0,0,0,1"
                            Padding="8,4"
                            CornerRadius="6,6,0,0">
                        <TextBlock Text="{Binding EditorHudBannerText}"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource CascadeTheme.EditorForeground}"
                                   FontSize="12"/>
                    </Border>
                </chrome:AttentionZoneContainer>
                <dock:DockControl x:Name="DocumentsDock"
                                  Grid.Row="1"
                                  DefaultContext="{Binding}"
                                  Factory="{Binding Documents.DockFactory}"
                                  Layout="{Binding Documents.DockLayout}"
                                  InitializeFactory="True"
                                  InitializeLayout="True"/>
            </Grid>
        </Border>
    </Panel>
</UserControl>
