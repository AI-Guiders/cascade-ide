<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:views="using:CascadeIDE.Views"
             xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
             x:Class="CascadeIDE.Views.DocumentsDockView"
             x:DataType="vm:MainWindowViewModel">
    <Border BorderBrush="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"
            BorderThickness="0,0,1,0"
            Background="{DynamicResource CascadeTheme.EditorColumnBackground}"
            Padding="4">
        <dock:DockControl x:Name="DocumentsDock"
                           DefaultContext="{Binding}"
                           Factory="{Binding DockFactory}"
                           Layout="{Binding DockLayout}"
                           InitializeFactory="True"
                           InitializeLayout="True"/>
    </Border>
</UserControl>
