<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:chrome="using:CascadeIDE.Features.UiChrome"
             xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
             x:Class="CascadeIDE.Views.DocumentsDockView"
             Classes.power="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="UserControl">
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="UserControl.power">
            <Setter Property="Margin" Value="8,6,8,6"/>
        </Style>
        <Style Selector="Border#DockIslandInner">
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.MainWindowBackground}"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
        <Style Selector="Border#DockIslandInner.power">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BoxShadow" Value="0 0 24 0 #5500C8E8, 0 4 20 0 #28000000"/>
        </Style>
    </UserControl.Styles>
    <Panel>
        <Border IsVisible="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}"
                IsHitTestVisible="False"
                Background="{DynamicResource CascadeTheme.PowerEditorIslandFrameBrush}"
                CornerRadius="14"/>
        <Border x:Name="DockIslandInner"
                ZIndex="1"
                Classes.power="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- ADR 0021 §9: HUD — слой на лобовом; визуальный хост — когда есть баннер и/или CF-полоска. -->
                <chrome:AttentionZoneContainer Zone="Hud" Grid.Row="0"
                                               IsVisible="{Binding IsEditorHudChromeVisible}">
                    <Border Background="{DynamicResource CascadeTheme.HudBannerBackground}"
                            BorderBrush="{DynamicResource CascadeTheme.HudBannerBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10,6"
                            CornerRadius="6,6,0,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding EditorHudBannerText}"
                                       IsVisible="{Binding IsEditorHudBannerVisible}"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource CascadeTheme.HudBannerForeground}"
                                       Opacity="0.95"
                                       FontSize="11.5"
                                       LineHeight="16"/>

                            <ItemsControl ItemsSource="{Binding EditorHudControlFlowNodes}"
                                          IsVisible="{Binding ShowEditorHudControlFlowStrip}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="6"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:EditorHudControlFlowNodeVm">
                                        <Button ToolTip.Tip="{Binding HudToolTip}"
                                                Command="{Binding $parent[vm:MainWindowViewModel].NavigateEditorHudControlFlowNodeCommand}"
                                                CommandParameter="{Binding}"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0">
                                            <Panel Width="22" Height="22">
                                                <Border IsVisible="{Binding IsHighlighted}"
                                                        Background="{DynamicResource CascadeTheme.HudBannerForeground}"
                                                        Opacity="0.22"
                                                        CornerRadius="11"/>
                                                <Ellipse Width="18" Height="18"
                                                         IsVisible="{Binding IsVisualAnchor}"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         Fill="#5964AAD4"
                                                         Stroke="{DynamicResource CascadeTheme.HudBannerBorderBrush}"
                                                         StrokeThickness="1"/>
                                                <Ellipse Width="18" Height="18"
                                                         IsVisible="{Binding IsVisualCircle}"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         Fill="Transparent"
                                                         Stroke="{DynamicResource CascadeTheme.HudBannerBorderBrush}"
                                                         StrokeThickness="1"/>
                                                <Path IsVisible="{Binding IsVisualDiamond}"
                                                      Stretch="Uniform"
                                                      Width="17" Height="17"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Fill="Transparent"
                                                      Stroke="{DynamicResource CascadeTheme.HudBannerBorderBrush}"
                                                      StrokeThickness="1"
                                                      Data="M 11 3 L 19 11 L 11 19 L 3 11 Z"/>
                                                <Panel HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding IsVisualExit}">
                                                    <Ellipse Width="18" Height="18"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             Fill="Transparent"
                                                             Stroke="{DynamicResource CascadeTheme.HudBannerBorderBrush}"
                                                             StrokeThickness="1"/>
                                                    <Path Stretch="Uniform"
                                                          Width="12" Height="12"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Stroke="{DynamicResource CascadeTheme.HudBannerForeground}"
                                                          StrokeThickness="1.15"
                                                          IsVisible="{Binding ShowExitArrow}"
                                                          Data="M 2 11 L 9 4 M 5.8 4 L 9 4 L 9 7.8"/>
                                                </Panel>
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding HudGlyphInkAnchor}"
                                                           Text="{Binding Glyph}"
                                                           FontWeight="SemiBold"
                                                           FontSize="9.8"
                                                           Foreground="#FFF8FBFF"/>
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding HudGlyphInkDefault}"
                                                           Text="{Binding Glyph}"
                                                           Foreground="{DynamicResource CascadeTheme.HudBannerForeground}"
                                                           FontWeight="SemiBold"
                                                           FontSize="9.8"/>
                                            </Panel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </chrome:AttentionZoneContainer>
                <!-- CascadeChord: полоска ввода — TaskCockpitView (видна без открытого документа). -->
                <dock:DockControl x:Name="DocumentsDock"
                                  Grid.Row="1"
                                  DefaultContext="{Binding}"
                                  Factory="{Binding Documents.DockFactory}"
                                  Layout="{Binding Documents.DockLayout}"
                                  InitializeFactory="True"
                                  InitializeLayout="True"/>
            </Grid>
        </Border>
    </Panel>
</UserControl>
