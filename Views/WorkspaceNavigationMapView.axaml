<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:views="using:CascadeIDE.Views"
             x:Class="CascadeIDE.Views.WorkspaceNavigationMapView"
             x:DataType="vm:MainWindowViewModel">
    <!-- Semantic Map (ADR 0039 / 0047): слот Pfd; list | graph | both; подграф = тот же JSON, что MCP subgraph + компоновка через SemanticMapCompositor. -->
    <Panel IsVisible="{Binding IsPfdRegionExpanded}">
        <Border BorderBrush="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="8"
                Background="{DynamicResource CascadeTheme.TerminalBackground}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{Binding SemanticMapListAreaRowHeight}"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <views:PanelChromeHeader Grid.Column="0"
                                             Title="Semantic Map · workspace"
                                             UppercaseTitle="True"/>
                    <Border Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0"
                            Padding="6,2"
                            CornerRadius="4"
                            Background="#22000000"
                            BorderBrush="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                            BorderThickness="1"
                            IsVisible="{Binding WorkspaceNavigationMapHasRelated}">
                        <TextBlock FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                   Text="{Binding WorkspaceNavigationMapRelatedBadge}"/>
                    </Border>
                </Grid>
                <StackPanel Grid.Row="1" Margin="0,6,0,0" Spacing="4">
                    <TextBlock FontSize="10"
                               TextWrapping="Wrap"
                               Opacity="0.9"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                               Text="{Binding SemanticMapSettingsSummaryLine}"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                   Text="Якорь:"/>
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                   Text="{Binding WorkspaceNavigationMapAnchorLabel}"/>
                    </StackPanel>
                    <views:SemanticMapMiniMapControl x:Name="SemanticMapMiniMap"
                                                     Height="{Binding SemanticMapGraphHeight}"
                                                     HorizontalAlignment="Stretch"
                                                     Margin="0,4,0,0"
                                                     Cursor="Hand"
                                                     IsVisible="{Binding ShowSemanticMapGraph}"
                                                     Scene="{Binding SemanticMapGraphScene}"
                                                     OpenFileCommand="{Binding OpenWorkspaceNavigationRelatedCommand}"/>
                    <TextBlock Margin="0,2,0,0"
                               FontSize="10"
                               Opacity="0.85"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                               TextWrapping="Wrap"
                               IsVisible="{Binding ShowSemanticMapGraphClickHint}"
                               Text="Клик по узлу — открыть файл."/>
                    <TextBlock Text="{Binding WorkspaceNavigationMapStatus}"
                               FontSize="11"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <Border Grid.Row="2" Height="1" Margin="0,8,0,0"
                        Background="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                        IsVisible="{Binding ShowSemanticMapList}"/>
                <ScrollViewer Grid.Row="3"
                              Margin="0,8,0,0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding ShowSemanticMapList}">
                    <ItemsControl ItemsSource="{Binding WorkspaceNavigationMapItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:WorkspaceNavigationMapItemVm">
                                <Button Margin="0,0,0,6"
                                        Padding="6,8"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Background="Transparent"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                                        CornerRadius="6"
                                        Command="{Binding $parent[UserControl].DataContext.OpenWorkspaceNavigationRelatedCommand}"
                                        CommandParameter="{Binding FullPath}">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding RelativePath}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource CascadeTheme.SolutionExplorerHeaderForeground}"/>
                                        <TextBlock Text="{Binding KindRationaleLine}"
                                                   FontSize="10"
                                                   Opacity="0.85"
                                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Panel>
</UserControl>
