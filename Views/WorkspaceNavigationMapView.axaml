<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:views="using:CascadeIDE.Views"
             x:Class="CascadeIDE.Views.WorkspaceNavigationMapView"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Resources>
        <views:StringNotEmptyToBoolConverter x:Key="HciOrientationLineVisible"/>
    </UserControl.Resources>
    <!-- Карта намерений / CodeNavigationMap (ADR 0039 / 0047 / 0088): слот Pfd — граф подграфа; список related — страница MFD RelatedFiles. -->
    <Panel IsVisible="{Binding IsPfdRegionExpanded}">
        <Border BorderBrush="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="8"
                Background="{DynamicResource CascadeTheme.TerminalBackground}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{Binding CodeNavigationMapListAreaRowHeight}"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <views:PanelChromeHeader Grid.Column="0"
                                             Title="Карта намерений · граф"
                                             UppercaseTitle="True"/>
                    <Border Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0"
                            Padding="6,2"
                            CornerRadius="4"
                            Background="#22000000"
                            BorderBrush="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                            BorderThickness="1"
                            IsVisible="{Binding WorkspaceNavigationMapHasRelated}">
                        <TextBlock FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                   Text="{Binding WorkspaceNavigationMapRelatedBadge}"/>
                    </Border>
                </Grid>
                <StackPanel Grid.Row="1" Margin="0,6,0,0" Spacing="4">
                    <TextBlock FontSize="10"
                               TextWrapping="Wrap"
                               Opacity="0.9"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                               Text="{Binding CodeNavigationMapSettingsSummaryLine}"/>
                    <TextBlock FontSize="10"
                               TextWrapping="Wrap"
                               Opacity="0.85"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                               IsVisible="{Binding WorkspaceNavigationMapHciOrientationLine, Converter={StaticResource HciOrientationLineVisible}}"
                               Text="{Binding WorkspaceNavigationMapHciOrientationLine}"/>
                    <Button Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            HorizontalAlignment="Left"
                            Command="{Binding OpenWorkspaceFeatureDocsCommand}"
                            IsVisible="{Binding WorkspaceFeatureLine, Converter={StaticResource HciOrientationLineVisible}}">
                        <TextBlock FontSize="10"
                                   TextWrapping="Wrap"
                                   Opacity="0.9"
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                   Text="{Binding WorkspaceFeatureLine}"/>
                    </Button>
                    <Button Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            HorizontalAlignment="Left"
                            Command="{Binding OpenWorkspaceAdrCorrespondenceCommand}"
                            IsVisible="{Binding WorkspaceAdrCorrespondenceLine, Converter={StaticResource HciOrientationLineVisible}}">
                        <TextBlock FontSize="10"
                                   TextWrapping="Wrap"
                                   Opacity="0.9"
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                   Text="{Binding WorkspaceAdrCorrespondenceLine}"/>
                    </Button>
                    <TextBlock FontSize="10"
                               TextWrapping="Wrap"
                               Opacity="0.85"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                               IsVisible="{Binding WorkspaceDocsCoverageLine, Converter={StaticResource HciOrientationLineVisible}}"
                               Text="{Binding WorkspaceDocsCoverageLine}"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                   Text="Якорь:"/>
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                   Text="{Binding WorkspaceNavigationMapAnchorLabel}"/>
                    </StackPanel>
                    <views:CodeNavigationMapMiniMapControl x:Name="CodeNavigationMapMiniMap"
                                                     Height="{Binding CodeNavigationMapGraphHeight}"
                                                     HorizontalAlignment="Stretch"
                                                     Margin="0,4,0,0"
                                                     Cursor="Hand"
                                                     IsVisible="{Binding ShowCodeNavigationMapGraph}"
                                                     Scene="{Binding CodeNavigationMapGraphScene}"
                                                     OpenFileCommand="{Binding OpenWorkspaceNavigationRelatedCommand}"/>
                    <TextBlock Margin="0,2,0,0"
                               FontSize="10"
                               Opacity="0.85"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                               TextWrapping="Wrap"
                               IsVisible="{Binding ShowCodeNavigationMapGraphClickHint}"
                               Text="Клик по узлу — открыть файл; в control flow — подсветка фрагмента (code anchor)."/>
                    <TextBlock Text="{Binding WorkspaceNavigationMapStatus}"
                               FontSize="11"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <Border Grid.Row="2" Height="1" Margin="0,8,0,0"
                        Background="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                        IsVisible="{Binding ShowCodeNavigationMapListOnPfd}"/>
                <ScrollViewer Grid.Row="3"
                              Margin="0,8,0,0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding ShowCodeNavigationMapListOnPfd}">
                    <ItemsControl ItemsSource="{Binding WorkspaceNavigationMapItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:WorkspaceNavigationMapItemVm">
                                <Button Margin="0,0,0,6"
                                        Padding="6,8"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Background="Transparent"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                                        CornerRadius="6"
                                        Command="{Binding $parent[UserControl].DataContext.OpenWorkspaceNavigationRelatedCommand}"
                                        CommandParameter="{Binding FullPath}">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding RelativePath}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource CascadeTheme.SolutionExplorerHeaderForeground}"/>
                                        <TextBlock Text="{Binding KindRationaleLine}"
                                                   FontSize="10"
                                                   Opacity="0.85"
                                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Panel>
</UserControl>
