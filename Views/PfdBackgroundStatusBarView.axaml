<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:chrome="using:CascadeIDE.Features.UiChrome"
             x:Class="CascadeIDE.Views.PfdBackgroundStatusBarView"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="Button.caution">
            <Setter Property="Background" Value="#33FFB020"/>
        </Style>
    </UserControl.Styles>
    <chrome:AttentionZoneContainer Zone="Hud">
        <StackPanel Spacing="0">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                  Background="{DynamicResource CascadeTheme.McpBannerBackground}">
                <Button Grid.Column="0"
                        Classes.caution="{Binding IsPfdBackgroundStatusCaution}"
                        Background="Transparent"
                        BorderBrush="{DynamicResource CascadeTheme.BuildOutputBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,5"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Command="{Binding OpenPfdBackgroundStatusDetailsCommand}"
                        Cursor="Hand">
                    <TextBlock Text="{Binding PfdBackgroundStatusText}"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource CascadeTheme.HudBannerForeground}"
                               FontSize="11.5"
                               Opacity="0.95"/>
                </Button>
                <Button Grid.Column="1"
                        Content="Повтор"
                        IsVisible="{Binding ShowPfdVerifyEpochRetry}"
                        Margin="0,0,4,0"
                        Padding="8,4"
                        FontSize="11"
                        Classes.caution="{Binding IsPfdBackgroundStatusCaution}"
                        Command="{Binding RetryPfdAgentEnvironmentVerifyCommand}"/>
                <Button Grid.Column="2"
                        Content="Отмена"
                        IsVisible="{Binding ShowPfdAgentEnvironmentCancel}"
                        Margin="0,0,4,0"
                        Padding="8,4"
                        FontSize="11"
                        Command="{Binding CancelPfdAgentEnvironmentVerifyCommand}"/>
                <Button Grid.Column="3"
                        Content="▾"
                        IsVisible="{Binding ShowPfdVerifyEpochExpandToggle}"
                        Margin="0,0,8,0"
                        Padding="6,4"
                        FontSize="11"
                        Command="{Binding TogglePfdVerifyEpochExpandedCommand}"/>
            </Grid>
            <Border IsVisible="{Binding ShowPfdVerifyEpochExpandedPanel}"
                    Background="{DynamicResource CascadeTheme.McpBannerBackground}"
                    BorderBrush="{DynamicResource CascadeTheme.BuildOutputBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="10,6">
                <TextBlock Text="{Binding PfdVerifyEpochExpandedText}"
                           FontFamily="Consolas,Courier New,monospace"
                           FontSize="11"
                           Foreground="{DynamicResource CascadeTheme.HudBannerForeground}"
                           Opacity="0.92"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
    </chrome:AttentionZoneContainer>
</UserControl>
