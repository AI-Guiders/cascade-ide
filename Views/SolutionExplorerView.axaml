<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:models="using:CascadeIDE.Models"
             xmlns:views="using:CascadeIDE.Views"
             x:Class="CascadeIDE.Views.SolutionExplorerView"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Resources>
        <views:SolutionItemIconConverter x:Key="SolutionItemIconConverter"/>
    </UserControl.Resources>
    <Border BorderBrush="{DynamicResource CascadeTheme.SolutionExplorerBorderBrush}"
            BorderThickness="0,0,1,0"
            Padding="4"
            IsVisible="{Binding IsSolutionExplorerVisible}">
        <Grid RowDefinitions="Auto,*,4,Auto">
            <TextBlock Grid.Row="0"
                       Text="Решение"
                       FontWeight="SemiBold"
                       Margin="4"
                       Foreground="{DynamicResource CascadeTheme.SolutionExplorerHeaderForeground}"/>
            <TreeView Grid.Row="1"
                      ItemsSource="{Binding SolutionRoots}"
                      SelectedItem="{Binding SelectedSolutionItem}"
                      Margin="0,4,0,0">
                <TreeView.Styles>
                    <Style Selector="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                    </Style>
                </TreeView.Styles>
                <TreeView.ItemTemplate>
                    <TreeDataTemplate DataType="models:SolutionItem"
                                       ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="{Binding Converter={StaticResource SolutionItemIconConverter}}"
                                   Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource CascadeTheme.SolutionExplorerHeaderForeground}"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
            <GridSplitter Grid.Row="2"
                          Height="4"
                          ResizeDirection="Rows"
                          Background="{DynamicResource CascadeTheme.SolutionExplorerBorderBrush}"
                          IsVisible="{Binding IsPowerMode}"/>
            <Border Grid.Row="3"
                    IsVisible="{Binding IsPowerMode}"
                    MaxHeight="200"
                    MinHeight="72"
                    Margin="0,4,0,0"
                    Padding="4"
                    BorderBrush="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Очередь задач"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"
                               Foreground="{DynamicResource CascadeTheme.SolutionExplorerHeaderForeground}"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Очередь пуста — элементы появятся при постановке задач агентом."
                               FontSize="11"
                               TextWrapping="Wrap"
                               IsVisible="{Binding !HasPowerTaskQueueItems}"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                               Margin="0,0,0,4"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PowerTaskQueueItems}"
                                      IsVisible="{Binding HasPowerTaskQueueItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:PowerTaskQueueItemViewModel">
                                    <Border Padding="4,2" Margin="0,0,0,2" CornerRadius="2"
                                            Background="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}">
                                        <TextBlock Text="{Binding DisplayLine}"
                                                   TextWrapping="Wrap"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource CascadeTheme.SolutionExplorerHeaderForeground}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
