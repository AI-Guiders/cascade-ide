<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:feat="using:CascadeIDE.Features.Instrumentation"
             xmlns:models="using:CascadeIDE.Models"
             xmlns:views="using:CascadeIDE.Views"
             x:Class="CascadeIDE.Views.SolutionExplorerView"
             Classes.power="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Resources>
        <views:SolutionItemIconConverter x:Key="SolutionItemIconConverter"/>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="UserControl">
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="UserControl.power">
            <Setter Property="Margin" Value="8,6,6,6"/>
        </Style>
        <Style Selector="Border#SolutionIslandInner">
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
        <Style Selector="Border#SolutionIslandInner.power">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.PowerSolutionTreePanelBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BoxShadow" Value="0 0 18 0 #3300A8CC, 0 3 14 0 #22000000"/>
        </Style>
        <Style Selector="TreeView TreeViewItem TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.SolutionExplorerHeaderForeground}"/>
        </Style>
        <Style Selector="UserControl.power TreeView TreeViewItem TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.PowerSolutionTreeForeground}"/>
        </Style>
        <Style Selector="UserControl.power TreeView TreeViewItem">
            <Setter Property="Padding" Value="4,6"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style Selector="UserControl.power TreeView TreeViewItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.PowerSolutionTreeItemPointerOverBackground}"/>
        </Style>
        <Style Selector="UserControl.power TreeView TreeViewItem:selected">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.PowerSolutionTreeItemSelectedBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.PowerNeonBorder}"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
        </Style>
        <Style Selector="UserControl.power Image.solutionExplorerTreeIcon">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
        </Style>
    </UserControl.Styles>
    <Panel>
        <Border IsVisible="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}"
                IsHitTestVisible="False"
                Background="{DynamicResource CascadeTheme.PowerSolutionIslandFrameBrush}"
                CornerRadius="14"/>
        <Border x:Name="SolutionIslandInner"
                ZIndex="1"
                Classes.power="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}">
        <Grid RowDefinitions="Auto,*,4,Auto">
            <StackPanel Grid.Row="0" Margin="0,4,0,0">
                <views:PanelChromeHeader Classes.powerSolutionExplorer="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}"
                                         Title="Решение · дерево проекта"
                                         UppercaseTitle="True"/>
                <TextBlock Text="{Binding StartupProjectBanner}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="2,2,0,0"
                           Opacity="0.8"
                           Foreground="{DynamicResource CascadeTheme.SolutionExplorerHeaderForeground}"
                           IsVisible="{Binding HasStartupProject}"/>
            </StackPanel>
            <TreeView Grid.Row="1"
                      ItemsSource="{Binding Workspace.SolutionRoots}"
                      SelectedItem="{Binding Workspace.SelectedSolutionItem}"
                      Margin="0,4,0,0">
                <TreeView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Сделать стартовым для отладки (F5)"
                                  Command="{Binding SetStartupProjectFromSelectionCommand}"/>
                        <MenuItem Header="Сбросить стартовый проект"
                                  Command="{Binding ClearStartupProjectCommand}"/>
                    </ContextMenu>
                </TreeView.ContextMenu>
                <TreeView.Styles>
                    <Style Selector="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                    </Style>
                </TreeView.Styles>
                <TreeView.ItemTemplate>
                    <TreeDataTemplate DataType="models:SolutionItem"
                                       ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Classes="solutionExplorerTreeIcon"
                                   Source="{Binding Converter={StaticResource SolutionItemIconConverter}}"
                                   Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
            <GridSplitter Grid.Row="2"
                          Height="4"
                          ResizeDirection="Rows"
                          Background="{DynamicResource CascadeTheme.PowerSolutionPanelBorderSubtle}"
                          IsVisible="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}"/>
            <Border Grid.Row="3"
                    IsVisible="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}"
                    MaxHeight="200"
                    MinHeight="72"
                    Margin="0,4,0,0"
                    Padding="4"
                    Background="{DynamicResource CascadeTheme.PowerWorkspaceHealthStripBackground}"
                    BorderBrush="{DynamicResource CascadeTheme.PowerSolutionPanelBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="8">
                <DockPanel DataContext="{Binding InstrumentationPanel}" x:DataType="feat:InstrumentationPanelViewModel">
                    <views:PanelChromeHeader DockPanel.Dock="Top"
                                             Classes="powerSolutionExplorer"
                                             Title="Очередь задач · исполнение"
                                             UppercaseTitle="True"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Очередь пуста — элементы появятся при постановке задач агентом."
                               FontSize="11"
                               TextWrapping="Wrap"
                               IsVisible="{Binding !HasPowerTaskQueueItems}"
                               Foreground="{DynamicResource CascadeTheme.PowerSolutionTreeForeground}"
                               Opacity="0.75"
                               Margin="0,0,0,4"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PowerTaskQueueItems}"
                                      IsVisible="{Binding HasPowerTaskQueueItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:PowerTaskQueueItemViewModel">
                                    <Border Padding="4,2" Margin="0,0,0,2" CornerRadius="2"
                                            Background="{DynamicResource CascadeTheme.PowerSolutionTaskQueueBubbleBackground}">
                                        <TextBlock Text="{Binding DisplayLine}"
                                                   TextWrapping="Wrap"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource CascadeTheme.PowerSolutionTreeForeground}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
        </Border>
    </Panel>
</UserControl>
