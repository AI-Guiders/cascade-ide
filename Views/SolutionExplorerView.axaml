<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:models="using:CascadeIDE.Models"
             xmlns:views="using:CascadeIDE.Views"
             x:Class="CascadeIDE.Views.SolutionExplorerView"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Resources>
        <views:SolutionItemIconConverter x:Key="SolutionItemIconConverter"/>
    </UserControl.Resources>
    <Border BorderBrush="{DynamicResource CascadeTheme.SolutionExplorerBorderBrush}"
            BorderThickness="0,0,1,0"
            Padding="4"
            IsVisible="{Binding IsSolutionExplorerVisible}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Text="Решение"
                       FontWeight="SemiBold"
                       Margin="4"
                       Foreground="{DynamicResource CascadeTheme.SolutionExplorerHeaderForeground}"/>
            <TreeView ItemsSource="{Binding SolutionRoots}"
                      SelectedItem="{Binding SelectedSolutionItem}"
                      Margin="0,4,0,0">
                <TreeView.Styles>
                    <!-- Узлы дерева раскрыты по умолчанию, чтобы можно было спуститься к проектам и файлам -->
                    <Style Selector="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                    </Style>
                </TreeView.Styles>
                <TreeView.ItemTemplate>
                    <TreeDataTemplate DataType="models:SolutionItem"
                                       ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="{Binding Converter={StaticResource SolutionItemIconConverter}}"
                                   Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource CascadeTheme.SolutionExplorerHeaderForeground}"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </DockPanel>
    </Border>
</UserControl>
