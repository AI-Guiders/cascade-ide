<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CascadeIDE.ViewModels"
        xmlns:views="using:CascadeIDE.Views"
        x:Class="CascadeIDE.Views.MarkdownPreviewWindow"
        x:DataType="vm:MarkdownPreviewWindowViewModel"
        Title="{Binding Title}"
        Width="700" Height="500"
        Background="{DynamicResource CascadeTheme.PreviewWindowBackground}"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource CascadeTheme.PreviewWindowBackground}">
        <views:MarkdownPreviewSurfaceView DataContext="{Binding}"/>
    </Border>

</Window>
