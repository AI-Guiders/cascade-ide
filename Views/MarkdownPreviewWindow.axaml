<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CascadeIDE.ViewModels"
        x:Class="CascadeIDE.Views.MarkdownPreviewWindow"
        x:DataType="vm:MarkdownPreviewWindowViewModel"
        Title="{Binding Title}"
        Width="700" Height="500"
        Background="{DynamicResource CascadeTheme.PreviewWindowBackground}"
        WindowStartupLocation="CenterOwner">

    <Border Padding="16" Background="{DynamicResource CascadeTheme.PreviewWindowBackground}">
        <ContentControl x:Name="PreviewHost"/>
    </Border>

</Window>
