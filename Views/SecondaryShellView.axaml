<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:feat="using:CascadeIDE.Features.Instrumentation"
             xmlns:dbg="using:CascadeIDE.Features.Debug"
             xmlns:models="using:CascadeIDE.Models"
             xmlns:views="using:CascadeIDE.Views"
             x:Class="CascadeIDE.Views.SecondaryShellView"
             x:Name="SecondaryShellRoot"
             Classes.power="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="Border#BottomPanelShell">
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="views|SecondaryShellView.power Border#BottomPanelShell">
            <Setter Property="CornerRadius" Value="12,12,0,0"/>
            <Setter Property="BoxShadow" Value="0 -8 32 0 #4000C8E8, 0 -2 20 0 #20000000"/>
        </Style>
    </UserControl.Styles>
    <!-- Вторичный контур оболочки (v1 — колонка зоны Mfd): одна активная страница; навигация — палитра «Вторичный контур: …», без TabControl. Сверху: EICAS и полоса Workspace Health (strip). -->
    <Grid MinHeight="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <views:WorkspaceChromeBandView Grid.Row="0"
                                       IsVisible="{Binding ShowWorkspaceChromeBand}"/>
        <Border x:Name="BottomPanelShell"
                Grid.Row="1"
                MinHeight="120"
                BorderBrush="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="4"
                Background="{DynamicResource CascadeTheme.TerminalBackground}">
        <!-- Тёмная тема Fluent для нижней панели. Страница «окружение» (ADR 0023) — оверлей; открытие из палитры. -->
        <ThemeVariantScope RequestedThemeVariant="Dark">
            <Grid>
                <Grid.Resources>
                    <views:SecondaryShellPageEqualsConverter x:Key="SecondaryShellPageEq"/>
                </Grid.Resources>
            <Border IsVisible="{Binding CurrentSecondaryShellPage, Converter={StaticResource SecondaryShellPageEq}, ConverterParameter=WorkspaceHealth}">
                    <views:WorkspaceHealthSecondaryPageView/>
            </Border>
            <Border IsVisible="{Binding CurrentSecondaryShellPage, Converter={StaticResource SecondaryShellPageEq}, ConverterParameter=Chat}">
                    <views:ChatPanelView/>
            </Border>
            <Border IsVisible="{Binding CurrentSecondaryShellPage, Converter={StaticResource SecondaryShellPageEq}, ConverterParameter=Terminal}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" IsVisible="{Binding WorkspaceHealthOnTerminalTab}" Classes="modeCard" Margin="0,0,0,4">
                            <StackPanel Spacing="4">
                                <WrapPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding WorkspaceHealthBuildText}" Foreground="{DynamicResource CascadeTheme.TerminalForeground}" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding ResultSummary}"
                                               IsVisible="{Binding IsResultSummaryVisible}"
                                               Foreground="{DynamicResource CascadeTheme.TerminalForeground}" Margin="0,0,12,0" MaxWidth="320" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding RiskSummary}"
                                               IsVisible="{Binding IsRiskSummaryVisible}"
                                               Foreground="{DynamicResource CascadeTheme.TerminalForeground}" Margin="0,0,12,0" MaxWidth="320" TextTrimming="CharacterEllipsis"/>
                                </WrapPanel>
                                <StackPanel DataContext="{Binding InstrumentationPanel}" x:DataType="feat:InstrumentationPanelViewModel" Spacing="0">
                                    <TextBlock Text="События появятся при работе агента и сборке."
                                               IsVisible="{Binding !HasEventTimeline}"
                                               Foreground="{DynamicResource CascadeTheme.TerminalForeground}"
                                               FontSize="11"
                                               Margin="0,0,0,4"/>
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                                  IsVisible="{Binding HasEventTimeline}">
                                        <ItemsControl ItemsSource="{Binding EventTimeline}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="{DynamicResource CascadeTheme.TerminalForeground}" FontSize="11" Margin="0,0,10,0"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <DockPanel DataContext="{Binding TerminalPanel}">
                            <views:PanelChromeHeader DockPanel.Dock="Top" Classes="terminal" Title="Консоль · ввод и вывод" UppercaseTitle="True"/>
                            <TextBox x:Name="TerminalInputBox"
                                     DockPanel.Dock="Bottom"
                                     Text="{Binding TerminalInput, Mode=TwoWay}"
                                     Watermark="Команда (Enter — выполнить)"
                                     FontFamily="Consolas,monospace"
                                     FontSize="12"
                                     Background="{DynamicResource CascadeTheme.TerminalInputBackground}"
                                     Foreground="{DynamicResource CascadeTheme.TerminalForeground}"
                                     Margin="0,4,0,0">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Enter" Command="{Binding RunTerminalCommandCommand}"/>
                                </TextBox.KeyBindings>
                            </TextBox>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" MinHeight="96">
                                <TextBox Text="{Binding TerminalOutput, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="NoWrap"
                                         FontFamily="Consolas,monospace"
                                         FontSize="12"
                                         Background="Transparent"
                                         Foreground="{DynamicResource CascadeTheme.TerminalForeground}"
                                         BorderThickness="0"/>
                            </ScrollViewer>
                        </DockPanel>
                    </DockPanel>
            </Border>
            <Border IsVisible="{Binding CurrentSecondaryShellPage, Converter={StaticResource SecondaryShellPageEq}, ConverterParameter=Build}">
                    <DockPanel DataContext="{Binding BuildOutputPanel}">
                        <views:PanelChromeHeader DockPanel.Dock="Top" Title="Журнал сборки · MSBuild / Roslyn" UppercaseTitle="True"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" MinHeight="96">
                            <TextBox Text="{Binding BuildOutput, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas,monospace"
                                     FontSize="12"
                                     Background="{DynamicResource CascadeTheme.BuildOutputBackground}"
                                     Foreground="{DynamicResource CascadeTheme.TerminalForeground}"
                                     BorderThickness="0"/>
                        </ScrollViewer>
                    </DockPanel>
            </Border>
            <Border IsVisible="{Binding CurrentSecondaryShellPage, Converter={StaticResource SecondaryShellPageEq}, ConverterParameter=Problems}">
                    <DockPanel DataContext="{Binding ProblemsPanel}">
                        <views:PanelChromeHeader DockPanel.Dock="Top" Title="{Binding SummaryText}" UppercaseTitle="False"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" MinHeight="96">
                            <ListBox x:Name="ProblemsListBox"
                                     ItemsSource="{Binding Items}"
                                     Background="Transparent"
                                     DoubleTapped="ProblemsList_OnDoubleTapped">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="vm:ProblemListItem">
                                        <StackPanel Orientation="Vertical" Spacing="2" Margin="0,2">
                                            <TextBlock Text="{Binding HeaderLine}"
                                                       FontFamily="Consolas,monospace" FontSize="11"
                                                       Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="11"
                                                       Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </DockPanel>
            </Border>
            <Border IsVisible="{Binding CurrentSecondaryShellPage, Converter={StaticResource SecondaryShellPageEq}, ConverterParameter=Git}">
                    <Grid DataContext="{Binding GitPanel}"
                          ColumnDefinitions="280,4,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,120,Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                                   Text="{Binding GitBranchLine, StringFormat=Ветка / состояние: {0}}"
                                   Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"
                                   FontSize="11"
                                   Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="3"
                                   Text="{Binding GitRepositoryContextText}"
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="2" Grid.ColumnSpan="3"
                                   Text="{Binding GitPanelStatusText}"
                                   Foreground="#FFAA6666"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="3" Grid.ColumnSpan="3"
                                   TextWrapping="Wrap"
                                   FontSize="10"
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                   Margin="0,0,0,6"
                                   Text="Submodule: путь из .gitmodules — [sm]. Gitlink в родителе vs коммит внутри submodule. «Открыть решение» — .sln/.slnx в submodule (корень или подпапка 1-го уровня); контекст IDE переключится на этот репозиторий."/>
                        <StackPanel Grid.Row="4" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                            <Button Content="Submodule update --init" Command="{Binding GitSubmoduleUpdateInitCommand}" Padding="8,4" ToolTip.Tip="git submodule update --init --recursive (из корня текущего репо)"/>
                            <Button Content="Submodule sync" Command="{Binding GitSubmoduleSyncCommand}" Padding="8,4" ToolTip.Tip="git submodule sync --recursive"/>
                            <Button Content="Открыть решение в submodule" Command="{Binding OpenSubmoduleSolutionInIdeCommand}" Padding="8,4" ToolTip.Tip="Найти .slnx/.sln в выбранной строке [sm] и открыть как текущее решение"/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="5" Grid.ColumnSpan="3" VerticalScrollBarVisibility="Auto" MaxHeight="80" Margin="0,0,0,6">
                            <TextBox Text="{Binding GitSubmoduleCommandOutput, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas,monospace"
                                     FontSize="9"
                                     Background="Transparent"
                                     Foreground="{DynamicResource CascadeTheme.TerminalForeground}"
                                     BorderThickness="0"
                                     Watermark="Вывод submodule update / sync…"/>
                        </ScrollViewer>
                        <Border Grid.Row="6" Grid.Column="0" BorderBrush="{DynamicResource CascadeTheme.EditorColumnBorderBrush}" BorderThickness="1" Padding="4">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                                    <Button Content="Обновить" Command="{Binding RefreshGitPanelCommand}" Padding="8,4"/>
                                    <Button Content="В индекс" Command="{Binding StageGitSelectionCommand}" Padding="8,4" ToolTip.Tip="git add — выбранный путь"/>
                                    <Button Content="Снять из индекса" Command="{Binding UnstageGitSelectionCommand}" Padding="8,4" ToolTip.Tip="git restore --staged — выбранный путь"/>
                                    <Button Content="Папка submodule" Command="{Binding OpenSubmoduleFolderCommand}" Padding="8,4" ToolTip.Tip="Открыть каталог выбранного submodule в проводнике"/>
                                </StackPanel>
                                <ListBox ItemsSource="{Binding GitStatusRows}"
                                         SelectedItem="{Binding SelectedGitStatusRow}"
                                         Background="Transparent"
                                         MinHeight="80">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="models:GitStatusRow">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="[sm]"
                                                           FontSize="10"
                                                           Foreground="#FF9B7DFF"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding IsSubmodulePath}"/>
                                                <TextBlock Text="{Binding RawLine}"
                                                           FontFamily="Consolas,monospace"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource CascadeTheme.TerminalForeground}"
                                                           TextWrapping="NoWrap"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>
                        <GridSplitter Grid.Row="6" Grid.Column="1" Width="4" ResizeDirection="Columns"
                                      Background="{DynamicResource CascadeTheme.BuildOutputBorderBrush}"/>
                        <ScrollViewer Grid.Row="6" Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding GitDiffText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas,monospace"
                                     FontSize="11"
                                     Background="{DynamicResource CascadeTheme.BuildOutputBackground}"
                                     Foreground="{DynamicResource CascadeTheme.TerminalForeground}"
                                     BorderThickness="0"
                                     Watermark="Выберите строку статуса слева — покажется diff."/>
                        </ScrollViewer>
                        <views:PanelChromeHeader Grid.Row="7" Grid.ColumnSpan="3" Classes="terminal" Title="git submodule status" UppercaseTitle="True" Margin="0,8,0,0"/>
                        <ScrollViewer Grid.Row="8" Grid.ColumnSpan="3" VerticalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding GitSubmoduleStatusText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas,monospace"
                                     FontSize="10"
                                     Background="Transparent"
                                     Foreground="{DynamicResource CascadeTheme.TerminalForeground}"
                                     BorderThickness="0"/>
                        </ScrollViewer>
                        <views:PanelChromeHeader Grid.Row="9" Grid.ColumnSpan="3" Classes="terminal" Title="Сообщение коммита" UppercaseTitle="True" Margin="0,4,0,0"/>
                        <TextBox Grid.Row="10" Grid.ColumnSpan="3"
                                 Text="{Binding GitCommitMessage, Mode=TwoWay}"
                                 Watermark="Сообщение коммита"
                                 FontFamily="Consolas,monospace"
                                 FontSize="12"
                                 MinHeight="36"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"/>
                        <StackPanel Grid.Row="11" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button Content="Коммит (add -A)" Command="{Binding CommitGitFromPanelCommand}" Padding="12,6" ToolTip.Tip="git add -A и commit — как MCP ide_git_commit"/>
                            <Button Content="Коммит (только staged)" Command="{Binding CommitGitStagedOnlyCommand}" Padding="12,6" ToolTip.Tip="git commit без add — только то, что в индексе"/>
                            <Button Content="Push" Command="{Binding PushGitFromPanelCommand}" Padding="12,6"/>
                        </StackPanel>
                    </Grid>
            </Border>
            <Border IsVisible="{Binding CurrentSecondaryShellPage, Converter={StaticResource SecondaryShellPageEq}, ConverterParameter=Events}">
                    <DockPanel>
                        <views:PanelChromeHeader DockPanel.Dock="Top" Classes="terminal" Title="Лента событий · агент и сборка" UppercaseTitle="True"/>
                        <DockPanel DataContext="{Binding InstrumentationPanel}" x:DataType="feat:InstrumentationPanelViewModel">
                            <TextBlock DockPanel.Dock="Top" Text="События появятся при работе агента и сборке."
                                       IsVisible="{Binding !HasEventTimeline}"
                                       Foreground="{DynamicResource CascadeTheme.TerminalForeground}"
                                       FontSize="11"
                                       Margin="0,0,0,4"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                          IsVisible="{Binding HasEventTimeline}">
                                <ItemsControl ItemsSource="{Binding EventTimeline}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource CascadeTheme.TerminalForeground}" FontSize="11" Margin="0,0,10,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </DockPanel>
            </Border>
            <Border IsVisible="{Binding CurrentSecondaryShellPage, Converter={StaticResource SecondaryShellPageEq}, ConverterParameter=Tests}">
                    <DockPanel>
                        <views:PanelChromeHeader DockPanel.Dock="Top" Classes="terminal" Title="{Binding LastTestSummary, StringFormat=Последний прогон: {0}}" UppercaseTitle="False"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                      DataContext="{Binding InstrumentationPanel}" x:DataType="feat:InstrumentationPanelViewModel">
                            <TextBox Text="{Binding TestResultsOutput, Mode=OneWay}"
                                     Watermark="Здесь появится вывод dotnet test после запуска тестов из IDE или агента."
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas,monospace"
                                     FontSize="12"
                                     Background="{DynamicResource CascadeTheme.BuildOutputBackground}"
                                     Foreground="{DynamicResource CascadeTheme.TerminalForeground}"
                                     BorderThickness="0"/>
                        </ScrollViewer>
                    </DockPanel>
            </Border>
            <Border IsVisible="{Binding CurrentSecondaryShellPage, Converter={StaticResource SecondaryShellPageEq}, ConverterParameter=Hypotheses}">
                    <DockPanel DataContext="{Binding HypothesesPanel}" x:DataType="dbg:HypothesesPanelViewModel">
                        <views:PanelChromeHeader DockPanel.Dock="Top" Classes="terminal" Title="Гипотезы · workspace JSON" UppercaseTitle="True"/>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
                            <Button Content="Добавить гипотезу" Command="{Binding AddHypothesisCommand}" Padding="8,4"/>
                            <TextBlock Text=".cascade-ide/debug-hypotheses.json"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                        </StackPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="dbg:HypothesisRowViewModel">
                                        <Border Padding="6" Margin="0,0,0,6"
                                                BorderBrush="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"
                                                BorderThickness="1" CornerRadius="4">
                                            <StackPanel Spacing="6">
                                                <TextBox Text="{Binding Text, Mode=TwoWay}"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         MinHeight="48"
                                                         FontFamily="Consolas,monospace"
                                                         FontSize="12"
                                                         Watermark="Формулировка гипотезы…"/>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Button Content="Открыта" Command="{Binding SetOpenCommand}" Padding="6,2"/>
                                                    <Button Content="Не подтвердилась" Command="{Binding SetRejectedCommand}" Padding="6,2"/>
                                                    <Button Content="Подтвердилась" Command="{Binding SetConfirmedCommand}" Padding="6,2"/>
                                                    <Button Content="Удалить" Command="{Binding RemoveCommand}" Padding="6,2" Margin="12,0,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
            </Border>
            <Border IsVisible="{Binding CurrentSecondaryShellPage, Converter={StaticResource SecondaryShellPageEq}, ConverterParameter=DebugStack}">
                    <Grid DataContext="{Binding InstrumentationPanel}" x:DataType="feat:InstrumentationPanelViewModel"
                          RowDefinitions="Auto,*,4,Auto,*" Margin="0,4,0,0">
                        <views:PanelChromeHeader Grid.Row="0" Classes="terminal" Title="Стек вызовов · отладчик" UppercaseTitle="True"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding DebugStackFrames}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}"
                                                   FontFamily="Consolas,monospace" FontSize="11"
                                                   Foreground="{DynamicResource CascadeTheme.TerminalForeground}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <views:PanelChromeHeader Grid.Row="3" Classes="terminal" Title="Локальные переменные" UppercaseTitle="True" Margin="0,8,0,0"/>
                        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding DebugVariables}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}"
                                                   FontFamily="Consolas,monospace" FontSize="11"
                                                   Foreground="{DynamicResource CascadeTheme.TerminalForeground}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
            </Border>
            <Border ZIndex="1"
                    IsVisible="{Binding ShowEnvironmentReadinessPage}"
                    Background="{DynamicResource CascadeTheme.TerminalBackground}"
                    Padding="0">
                <views:EnvironmentReadinessSecondaryPageView/>
            </Border>
            </Grid>
        </ThemeVariantScope>
        </Border>
    </Grid>
</UserControl>
