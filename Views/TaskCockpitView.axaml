<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:views="using:CascadeIDE.Views"
             x:Class="CascadeIDE.Views.TaskCockpitView"
             x:DataType="vm:MainWindowViewModel">
    <StackPanel Spacing="0">
        <!-- Блокировка сплиттеров рабочей области (раньше отдельный ToolbarView). Всегда видна, не зависит от ShowTaskBar. -->
        <Border Padding="8,4"
                Margin="0,0,0,0"
                Background="{DynamicResource CascadeTheme.ToolbarBackground}">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Padding="12,6"
                        Content="{Binding WorkspaceSplitterLockButtonText}"
                        Command="{Binding ToggleWorkspaceSplittersLockCommand}"
                        ToolTip.Tip="{Binding WorkspaceSplitterLockButtonToolTip}"
                        Background="{Binding WorkspaceSplitterLockButtonBackgroundBrush}"
                        Foreground="White"
                        BorderBrush="#40FFFFFF"/>
                <!-- ADR 0060/0064: лампа CascadeChord — PrimitivesKit + Views; не дублировать палитру в AXAML (0066). -->
                <views:CommandArmedStripLampCell IsArmed="{Binding IsCascadeChordOverlayVisible}"
                                                 ToolTip.Tip="{Binding CommandArmedLampToolTip}"
                                                 VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    <Border Margin="8,0,8,4"
            Padding="8,6"
            IsVisible="{Binding ShowTaskBar}"
            Classes="modeCard">
        <StackPanel Spacing="6">
            <WrapPanel Orientation="Horizontal" ItemHeight="28">
                <TextBlock Text="{Binding ActiveTaskTitle}" FontWeight="SemiBold" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}" Margin="0,0,8,0"/>
                <Border Classes="modeCard" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="{Binding ActiveTaskStatus}" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                </Border>
                <TextBlock Text="{Binding ActiveTaskProgress, StringFormat='{}Progress: {0}%'}"
                           IsVisible="{Binding IsActiveTaskProgressVisible}"
                           Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"
                           Margin="0,0,8,0"/>
            </WrapPanel>

            <Border Classes="modeCard" IsVisible="{Binding ShowTelemetryHiddenHint}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Панель телеметрии скрыта. Откройте её, чтобы видеть ход сборки и события."
                               Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"
                               VerticalAlignment="Center"/>
                    <Button Content="Показать" Command="{Binding ToggleTerminalCommand}"/>
                </StackPanel>
            </Border>

            <Border Classes="modeCard"
                    IsVisible="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}"
                    Padding="8"
                    Margin="0,0,0,6">
                <StackPanel Spacing="8">
                    <TextBlock Text="Autonomous run (Power)"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="8">
                        <TextBox Grid.Column="0"
                                 Text="{Binding Autonomous.AutonomousObjective, Mode=TwoWay}"
                                 PlaceholderText="Autonomous objective"
                                 FontFamily="Consolas,monospace"
                                 FontSize="11"/>
                        <TextBlock Grid.Column="1"
                                   Text="Max steps:"
                                   Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2"
                                 Text="{Binding Autonomous.AutonomousMaxSteps, Mode=TwoWay}"
                                 Width="56"
                                 TextAlignment="Center"
                                 FontFamily="Consolas,monospace"
                                 FontSize="11"/>
                        <Button Grid.Column="3"
                                Content="Start"
                                Command="{Binding Autonomous.StartAutonomousCommand}"
                                IsVisible="{Binding !Autonomous.IsAutonomousPaused}"/>
                        <Button Grid.Column="4"
                                Content="Pause"
                                Command="{Binding Autonomous.PauseAutonomousCommand}"
                                IsVisible="{Binding Autonomous.IsAutonomousRunning}"/>
                        <Button Grid.Column="4"
                                Content="Resume"
                                Command="{Binding Autonomous.ResumeAutonomousCommand}"
                                IsVisible="{Binding Autonomous.IsAutonomousPaused}"/>
                        <Button Grid.Column="5"
                                Content="Details…"
                                VerticalAlignment="Center"
                                ToolTip.Tip="Редактировать полную формулировку цели (popover)">
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedLeft">
                                    <Border Classes="modeCard"
                                            Padding="10"
                                            MinWidth="360"
                                            MaxWidth="520">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Autonomous objective (full)"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                                            <TextBox Text="{Binding Autonomous.AutonomousObjective, Mode=TwoWay}"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     MinHeight="120"
                                                     FontFamily="Consolas,monospace"
                                                     FontSize="11"/>
                                            <TextBlock Text="Та же строка, что в компактном поле выше; закрой popover кликом снаружи или Esc."
                                                       TextWrapping="Wrap"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                                        </StackPanel>
                                    </Border>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" IsVisible="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyNe}, ConverterParameter=Focus}">
                <WrapPanel Orientation="Horizontal" ItemHeight="30">
                    <Button Content="Fix failing tests" Command="{Binding Autonomous.FixFailingTestsCommand}" IsVisible="{Binding QuickActions}" Margin="0,0,6,0"/>
                    <Button Content="Investigate nullref" Command="{Binding Autonomous.InvestigateNullrefCommand}" IsVisible="{Binding QuickActions}" Margin="0,0,6,0"/>
                    <Button Content="Prepare commit" Command="{Binding Autonomous.PrepareCommitCommand}" IsVisible="{Binding QuickActions}" Margin="0,0,6,0"/>
                    <Border Classes="modeCard" Padding="6,2" Margin="0,0,6,0" IsVisible="{Binding IsComplexityBadgeVisible}"
                            ToolTip.Tip="Прокси по концепту: число строк текущего файла на диске (обновляется при смене документа), не цикломатика.">
                        <TextBlock Text="{Binding ComplexityBadge, StringFormat='{}Complexity: {0}'}" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                    </Border>
                    <Border Classes="modeCard" Padding="6,2" Margin="0,0,6,0" IsVisible="{Binding IsImpactedTestsBadgeVisible}"
                            ToolTip.Tip="Упавшие тесты в последнем прогоне dotnet test (IDE/MCP).">
                        <TextBlock Text="{Binding ImpactedTestsBadge, StringFormat='{}Impacted tests: {0}'}" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                    </Border>
                    <Border Classes="modeCard" Padding="6,2" Margin="0,0,6,0" IsVisible="{Binding Chrome.IsFilesChangedBadgeVisible}"
                            ToolTip.Tip="Число путей в git status --short (изменённые/новые), синхронно со сводкой Git.">
                        <TextBlock Text="{Binding Chrome.FilesChangedBadge, StringFormat='{}Files changed: {0}'}" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                    </Border>
                </WrapPanel>
            </ScrollViewer>
        </StackPanel>
    </Border>
    </StackPanel>
</UserControl>
