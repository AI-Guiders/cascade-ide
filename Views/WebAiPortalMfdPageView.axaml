<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:views="using:CascadeIDE.Views"
             xmlns:awv="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.WebView"
             x:Class="CascadeIDE.Views.WebAiPortalMfdPageView"
             x:DataType="vm:MainWindowViewModel">
    <DockPanel Margin="0,4,0,0">
        <views:PanelChromeHeader DockPanel.Dock="Top"
                                 Title="WEB AI · portal / bridge (ADR 0108)"
                                 UppercaseTitle="True"/>

        <!-- По умолчанию свёрнуто: под WebView уходит почти вся высота MFD (ADR 0108). -->
        <Grid RowDefinitions="Auto,*"
              RowSpacing="6"
              Margin="0,8,0,0">

            <Expander Grid.Row="0"
                      IsExpanded="False"
                      ExpandDirection="Down"
                      HorizontalAlignment="Stretch">
                <Expander.Header>
                    <DockPanel LastChildFill="True" Margin="0,2,0,0">
                        <Button DockPanel.Dock="Right"
                                Content="Отозвать"
                                MinWidth="84"
                                Margin="8,0,0,0"
                                Click="OnRevokeBridgeClick"
                                ToolTip.Tip="Сбросить согласие и выключить мост."/>
                        <Button DockPanel.Dock="Right"
                                Content="Запуск"
                                MinWidth="88"
                                Margin="8,0,0,0"
                                Click="OnExecuteJsonCascadeFromClipboardClick"
                                ToolTip.Tip="Выполнить команду из буфера или последнюю json-cascade на странице."/>
                        <Button DockPanel.Dock="Right"
                                AutomationProperties.Name="Перейти"
                                Margin="8,0,0,0"
                                MinWidth="36"
                                Padding="8,4"
                                Click="OnNavigateClick"
                                ToolTip.Tip="Перейти (Enter)">
                            <TextBlock Text="⇨"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>
                        <TextBox MinHeight="28"
                                 PlaceholderText="example.com или https://…"
                                 ToolTip.Tip="Без схемы подставится https:// (для localhost и 127.0.0.1 — http://). Enter — перейти."
                                 KeyDown="OnWebAiPortalUrlKeyDown"
                                 Text="{Binding WebAiPortalUrlText, Mode=TwoWay}"/>
                    </DockPanel>
                </Expander.Header>
                <Border Padding="8"
                        Background="#22000000"
                        CornerRadius="4">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                          ColumnSpacing="10"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="6">
                        <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                  Content="Принял политику моста"
                                  IsChecked="{Binding WebAiPortalBridge.BridgeConsented, Mode=TwoWay}"/>
                        <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                  Content="Мост включён (invokeCSharpAction)"
                                  IsChecked="{Binding WebAiPortalBridge.BridgeArmed, Mode=TwoWay}"/>
                        <CheckBox Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                                  Content="Все write на сессию"
                                  IsChecked="{Binding WebAiPortalBridge.AllowWritesForSession, Mode=TwoWay}"/>

                        <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                  Content="Ответ IDE → буфер"
                                  IsChecked="{Binding WebAiPortalCopyFullBridgeResultToClipboard, Mode=TwoWay}"
                                  ToolTip.Tip="После моста текст в системный буфер. Если включён «Под лимит чата» и ответ длинный — вместо сырого JSON кладётся компакт с HCI." />
                        <CheckBox Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2"
                                  Content="Подмешать в композитор (фокус на странице)"
                                  IsChecked="{Binding WebAiPortalTryInjectResultIntoFocusedComposer, Mode=TwoWay}"
                                  ToolTip.Tip="Курсор в поле ввода чата на странице; после ответа моста текст добавляется как эвристика (может не сработать на каждой вёрстке)."/>

                        <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4"
                                  Content="Под лимит чата (~1200): компакт + HCI вместо сырого JSON"
                                  IsChecked="{Binding WebAiPortalPreferCompactComposerForChat, Mode=TwoWay}"
                                  ToolTip.Tip="Ответы типа get_editor_state с большим превью ломают веб-чат. В буфер/композитор — короткая сводка и готовые json-cascade (codebase_index_search, codebase_index_status, explain, узкий read)." />

                        <CheckBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4"
                                  Content="Авто: последняя json-cascade на странице → мост (poll, без кнопки)"
                                  IsChecked="{Binding WebAiPortalAutoDomBridgePolling, Mode=TwoWay}"
                                  ToolTip.Tip="Раз в ~1 с IDE находит последний блок ```json-cascade с command_id в DOM и выполняет его (буфер/копипаст не нужны). Повтор того же payload не запускает мост заново до смены страницы. Отправить результат в поле чата сайта пользователь делает там (или «Подмешать в композитор»)." />

                        <Button Grid.Row="5"
                                Grid.Column="0"
                                Grid.ColumnSpan="4"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Content="Выполнить команду: буфер → последняя на странице"
                                Click="OnExecuteJsonCascadeFromClipboardClick"
                                ToolTip.Tip="Ручной вариант ADR 0108: 1) fenced json-cascade или голый JSON с command_id в буфере; 2) иначе последний такой блок в pre/code на открытой странице (снизу в DOM)." />
                    </Grid>
                </Border>
            </Expander>

            <Grid Grid.Row="1" MinHeight="180">
                <awv:NativeWebView x:Name="WebView"
                                   NavigationCompleted="OnNavigationCompletedWeb"
                                   WebMessageReceived="OnWebMessageReceived"/>
                <!-- Не резервируем отдельную строку под статус; не перехватываем клики по странице. -->
                <Border VerticalAlignment="Bottom"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,4"
                        Padding="8,4"
                        Background="#D9000000"
                        CornerRadius="4"
                        IsHitTestVisible="False">
                    <TextBlock Text="{Binding WebAiPortalLastBridgeResult}"
                               TextWrapping="Wrap"
                               MaxHeight="48"
                               FontSize="11"
                               Opacity="0.95"/>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
