<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:CascadeIDE.Views"
             xmlns:vm="using:CascadeIDE.ViewModels"
             x:Class="CascadeIDE.Views.WorkspaceTelemetrySurfaceHostView"
             x:DataType="vm:MainWindowViewModel">
    <Grid RowDefinitions="Auto,*">
        <views:EicasStripView Grid.Row="0"
                              IsVisible="{Binding ShowEicasStrip}"/>
        <Grid Grid.Row="1"
              ColumnDefinitions="220,4,*,4,340"
              IsVisible="{Binding ShowTelemetryStrip}">
            <views:TelemetryStripView Grid.Column="0"
                                      Grid.ColumnSpan="{Binding MainWorkspaceTelemetryColumnSpan}"/>
        </Grid>
    </Grid>
</UserControl>
