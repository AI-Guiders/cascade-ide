<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:ae="using:AvaloniaEdit"
             xmlns:ed="using:CascadeIDE.Features.Editor.Application.Presentation"
             x:Class="CascadeIDE.Views.DockDocumentView"
             x:DataType="vm:DockDocumentViewModel">

    <!-- Заголовок файла — только во вкладках Dock (без дублирующего PanelChromeHeader). -->
    <Grid RowDefinitions="Auto,*"
          ToolTip.Tip="{Binding Doc.FilePath}"
          ToolTip.ShowDelay="400">
        <Border Grid.Row="0"
                x:Name="StickyScrollHost"
                IsVisible="False"
                Margin="0,0,0,2"
                Padding="6,3"
                CornerRadius="4"
                Background="{DynamicResource CascadeTheme.HudBannerBackground}"
                BorderBrush="{DynamicResource CascadeTheme.HudBannerBorderBrush}"
                BorderThickness="1">
            <TextBlock x:Name="StickyScrollText"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{DynamicResource CascadeTheme.HudBannerForeground}"/>
        </Border>

        <Grid Grid.Row="1"
              x:Name="EditorContentGrid"
              Margin="0">
            <!-- Inline hover / ToolTip: EditorInlineHoverChrome.ApplyToolTipServiceTo в code-behind (один источник). -->
            <ae:TextEditor
                           x:Name="Editor"
                           Classes="EditorBox"
                           Cursor="IBeam"
                           ShowLineNumbers="True"
                           FontFamily="Consolas,Cascadia Code,monospace"
                           FontSize="13"
                           Padding="{x:Static ed:EditorForwardDocumentChrome.DocumentPadding}"/>
        </Grid>
    </Grid>
</UserControl>
