<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:ae="using:AvaloniaEdit"
             xmlns:views="using:CascadeIDE.Views"
             x:Class="CascadeIDE.Views.DockDocumentView"
             x:DataType="vm:DockDocumentViewModel">

    <Grid RowDefinitions="Auto,*">
        <views:PanelChromeHeader Grid.Row="0"
                                 Classes="documentTitle"
                                 Title="{Binding Doc.FilePath}"
                                 UppercaseTitle="False"
                                 Margin="4,4,4,0"/>

        <Grid Grid.Row="1"
              x:Name="EditorContentGrid">
            <ae:TextEditor
                           x:Name="Editor"
                           Classes="EditorBox"
                           Cursor="IBeam"
                           ShowLineNumbers="True"
                           FontFamily="Consolas,Cascadia Code,monospace"
                           FontSize="13"
                           Padding="8"
                           ToolTip.Placement="Pointer"
                           ToolTip.ShowDelay="280"
                           ToolTip.VerticalOffset="10"
                           ToolTip.HorizontalOffset="10"/>
        </Grid>
    </Grid>
</UserControl>
