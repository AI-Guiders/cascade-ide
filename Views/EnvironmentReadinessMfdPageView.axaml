<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:models="using:CascadeIDE.Models"
             xmlns:views="using:CascadeIDE.Views"
             x:Class="CascadeIDE.Views.EnvironmentReadinessMfdPageView"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Resources>
        <views:AnnunciatorLampLevelToBrushConverter x:Key="EnvLevelBrush"/>
        <views:EnvironmentReadinessIsSectionRowConverter x:Key="ErsIsSectionRow"/>
        <views:StringNotEmptyToBoolConverter x:Key="ErsDetailVisible"/>
    </UserControl.Resources>
    <DockPanel Margin="0,4,0,0">
        <views:PanelChromeHeader DockPanel.Dock="Top"
                                 Title="Готовность окружения · LSP, инструменты и переменные"
                                 UppercaseTitle="True"/>
        <!-- ADR 0063/0068: одна коллекция; порядок строк — payload (секции и детали). Список карточек, без таблицы. -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Panel>
                <!-- Узкий MFD: компактные карточки -->
                <Border x:Name="CompactLayoutRoot"
                        IsVisible="True"
                        Margin="0,0,0,4"
                        BorderBrush="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="{DynamicResource CascadeTheme.PanelBackgroundBrush}">
                    <ItemsControl ItemsSource="{Binding EnvironmentReadinessItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:AnnunciatorLampItem">
                                <Panel>
                                    <Border IsVisible="{Binding Id, Converter={StaticResource ErsIsSectionRow}}"
                                            Padding="8,8"
                                            Margin="0,8,0,0"
                                            CornerRadius="4"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"
                                            Background="{DynamicResource CascadeTheme.MarkdownPreviewPanelBackground}">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <views:AnnunciatorLampCell Grid.Column="0"
                                                                       Item="{Binding}"
                                                                       VerticalAlignment="Top"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,0,10,0"/>
                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           TextWrapping="Wrap"
                                                           FontWeight="SemiBold"
                                                           FontSize="12"
                                                           Foreground="{Binding Level, Converter={StaticResource EnvLevelBrush}}"/>
                                                <TextBlock Text="{Binding Detail}"
                                                           TextWrapping="Wrap"
                                                           FontSize="10"
                                                           IsVisible="{Binding Detail, Converter={StaticResource ErsDetailVisible}}"
                                                           Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border IsVisible="{Binding Id, Converter={StaticResource ErsIsSectionRow}, ConverterParameter=Invert}"
                                            Padding="8,6"
                                            Margin="0,0,0,6"
                                            CornerRadius="4"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"
                                            Background="{DynamicResource CascadeTheme.PanelBackgroundBrush}">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <views:AnnunciatorLampCell Grid.Column="0"
                                                                       Item="{Binding}"
                                                                       VerticalAlignment="Top"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,0,10,0"/>
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Text="{Binding Title}"
                                                           TextWrapping="Wrap"
                                                           FontWeight="SemiBold"
                                                           FontSize="11"
                                                           Foreground="{Binding Level, Converter={StaticResource EnvLevelBrush}}"/>
                                                <TextBlock Text="{Binding Detail}"
                                                           TextWrapping="Wrap"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Panel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Широкая зона: тот же список, крупнее типографика -->
                <Border x:Name="WideLayoutRoot"
                        IsVisible="False"
                        Margin="0,0,0,4"
                        BorderBrush="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="{DynamicResource CascadeTheme.PanelBackgroundBrush}">
                    <ItemsControl ItemsSource="{Binding EnvironmentReadinessItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:AnnunciatorLampItem">
                                <Panel>
                                    <Border IsVisible="{Binding Id, Converter={StaticResource ErsIsSectionRow}}"
                                            Padding="12,10"
                                            Margin="0,10,0,0"
                                            CornerRadius="6"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"
                                            Background="{DynamicResource CascadeTheme.MarkdownPreviewPanelBackground}">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <views:AnnunciatorLampCell Grid.Column="0"
                                                                       Item="{Binding}"
                                                                       VerticalAlignment="Top"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1" Spacing="6">
                                                <TextBlock Text="{Binding Title}"
                                                           TextWrapping="Wrap"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Foreground="{Binding Level, Converter={StaticResource EnvLevelBrush}}"/>
                                                <TextBlock Text="{Binding Detail}"
                                                           TextWrapping="Wrap"
                                                           FontSize="12"
                                                           IsVisible="{Binding Detail, Converter={StaticResource ErsDetailVisible}}"
                                                           Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border IsVisible="{Binding Id, Converter={StaticResource ErsIsSectionRow}, ConverterParameter=Invert}"
                                            Padding="10,8"
                                            Margin="0,0,0,8"
                                            CornerRadius="6"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"
                                            Background="{DynamicResource CascadeTheme.PanelBackgroundBrush}">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <views:AnnunciatorLampCell Grid.Column="0"
                                                                       Item="{Binding}"
                                                                       VerticalAlignment="Top"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           TextWrapping="Wrap"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           Foreground="{Binding Level, Converter={StaticResource EnvLevelBrush}}"/>
                                                <TextBlock Text="{Binding Detail}"
                                                           TextWrapping="Wrap"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Panel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Panel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
