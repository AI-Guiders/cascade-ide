<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             x:Class="CascadeIDE.Views.ToolbarView"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer
        Margin="8,4"
        HorizontalScrollBarVisibility="Auto"
        VerticalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Horizontal" Spacing="8" Background="{DynamicResource CascadeTheme.ToolbarBackground}">
            <Button x:Name="OpenSolutionButton" Content="Открыть решение" Command="{Binding OpenSolutionCommand}"/>
            <Button Content="Открыть папку" Command="{Binding OpenFolderCommand}" ToolTip.Tip="Открыть каталог как workspace (без .sln)"/>
            <Button Content="Открыть файл" Command="{Binding OpenFileFromDialogCommand}" ToolTip.Tip="Открыть произвольный файл в редакторе"/>
            <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Focus}">
                <Button Content="Запуск (сборка)" Command="{Binding BuildSolutionCommand}" IsEnabled="{Binding !IsBuilding}"/>
                <Button Content="Контрольная точка" Command="{Binding FocusCheckpointCommand}"/>
                <Button Content="Откат" Command="{Binding FocusRollbackCommand}"/>
            </StackPanel>
            <Button Content="Собрать" Command="{Binding BuildSolutionCommand}" IsEnabled="{Binding !IsBuilding}" IsVisible="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyNe}, ConverterParameter=Focus}"/>
            <!-- Отладка (как в VS): команды дублируют меню и F5/F10; IsEnabled даёт ICommand. -->
            <Border Width="1" Height="22" Margin="6,0,4,0" Background="{DynamicResource CascadeTheme.EditorColumnBorderBrush}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                <Button Content="▶"
                        Padding="10,4"
                        MinWidth="36"
                        Command="{Binding DebugStartOrContinueCommand}"
                        ToolTip.Tip="Запустить или продолжить (F5). Если выбран стартовый проект (ПКМ по .csproj в дереве) — без диалога выбора файла."/>
                <Button Content="⏹"
                        Padding="10,4"
                        MinWidth="36"
                        Command="{Binding DebugStopCommand}"
                        ToolTip.Tip="Остановить отладку (Shift+F5)"
                        IsVisible="{Binding HasDebugSession}"/>
                <Button Content="↷"
                        Padding="10,4"
                        MinWidth="36"
                        FontSize="16"
                        Command="{Binding DebugStepOverCommand}"
                        ToolTip.Tip="Шаг с обходом (F10)"
                        IsVisible="{Binding HasDebugSession}"/>
                <Button Content="↓"
                        Padding="10,4"
                        MinWidth="36"
                        FontSize="16"
                        Command="{Binding DebugStepIntoCommand}"
                        ToolTip.Tip="Шаг с заходом (F11)"
                        IsVisible="{Binding HasDebugSession}"/>
                <Button Content="↑"
                        Padding="10,4"
                        MinWidth="36"
                        FontSize="16"
                        Command="{Binding DebugStepOutCommand}"
                        ToolTip.Tip="Шаг с выходом (Shift+F11)"
                        IsVisible="{Binding HasDebugSession}"/>
            </StackPanel>
            <TextBlock Text="Режим:" VerticalAlignment="Center" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}" Margin="8,0,0,0"/>
            <ComboBox Width="150"
                      MinWidth="148"
                      ItemsSource="{Binding UiModeOptionsList}"
                      SelectedItem="{Binding UiMode, Mode=TwoWay}"/>
            <Border x:Name="ModeBadge"
                    Classes.power="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}"
                    Classes.agentchat="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=AgentChat}"
                    Classes.debug="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Debug}"
                    Padding="8,2"
                    Margin="4,0,0,0"
                    VerticalAlignment="Center">
                <TextBlock Text="{Binding UiMode}" FontWeight="SemiBold" Foreground="#EAF0FF"/>
            </Border>
            <Button Content="{Binding TelemetryButtonText}"
                    Command="{Binding ToggleTerminalCommand}"
                    IsVisible="{Binding AutonomousAgentTelemetry}"/>
            <Button Content="Show explorer" Command="{Binding ShowSolutionExplorerPanelCommand}" IsVisible="{Binding IsSolutionPanelHidden}"/>
            <Button Content="Show build" Command="{Binding ShowBuildOutputPanelCommand}" IsVisible="{Binding IsBuildPanelHidden}"/>
            <Button Content="Show chat" Command="{Binding ShowChatPanelCommand}" IsVisible="{Binding IsChatPanelHidden}"/>
            <Button Content="Show terminal" Command="{Binding ShowTerminalPanelCommand}" IsVisible="{Binding IsTerminalPanelHidden}"/>
            <TextBlock Text="Колонки редактора:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"
                       Margin="8,0,0,0"/>
            <Button Content="1"
                    Command="{Binding SetSingleEditorGroupCommand}"
                    ToolTip.Tip="Одна колонка: все вкладки в одной группе (без разделения)."/>
            <Button Content="2"
                    Command="{Binding SetDualEditorGroupCommand}"
                    ToolTip.Tip="Две колонки: можно открывать и переносить файлы во вторую группу (два редактора рядом)."/>
            <Button Content="3"
                    Command="{Binding SetTripleEditorGroupCommand}"
                    ToolTip.Tip="Три колонки: до трёх групп редакторов; новый файл из дерева открывается в активной группе."/>
            <TextBlock Text="{Binding Workspace.SolutionPath}" VerticalAlignment="Center" MaxWidth="300" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
            <TextBlock Text="{Binding Workspace.SolutionLoadError}" VerticalAlignment="Center" MaxWidth="350" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource CascadeTheme.ToolbarErrorForeground}"/>
            <TextBlock Text="{Binding OllamaStatus}" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
