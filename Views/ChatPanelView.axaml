<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chat="using:CascadeIDE.Features.Chat"
             xmlns:uikit="using:CascadeIDE.Views.UiKit"
             xmlns:views="using:CascadeIDE.Views"
             x:Class="CascadeIDE.Views.ChatPanelView"
             x:DataType="chat:ChatPanelViewModel"
             Background="{DynamicResource CascadeTheme.ChatPanelBackground}">
    <UserControl.Styles>
        <Style Selector="TextBox.chatPanelInput">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatPanelBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
        </Style>
        <Style Selector="TextBox.chatPanelInput /template/ TextBlock#PART_Watermark">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
        </Style>
    </UserControl.Styles>

    <Panel Background="{DynamicResource CascadeTheme.ChatPanelBackground}">
        <views:IntercomSkiaSurface x:Name="IntercomSkiaSurface"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   Snapshot="{Binding ChatSurfaceSnapshot}"
                                   SelectedMessageIndex="{Binding SelectedMessageIndex, Mode=TwoWay}"
                                   DetailThreadId="{Binding SelectedChatThreadId, Mode=TwoWay}"
                                   OverviewMode="{Binding IsChatOverviewMode, Mode=TwoWay}"
                                   ForwardHost="{Binding IntercomForwardChrome}"
                                   ComfortableFeed="{Binding IntercomComfortableFeed}"
                                   TopicNavigatorVisible="{Binding IntercomTopicNavigatorVisible}"
                                   TopicNavigatorSearchQuery="{Binding TopicNavigatorSearchQuery, Mode=TwoWay}"
                                   IntercomFonts="{Binding IntercomFonts}"
                                   ChromeTitle="Intercom"
                                   IsChatLoading="{Binding IsChatLoading}"
                                   LoadingStatusText="{Binding ChatLoadingStatusText}"
                                   ShowIntercomComposer="True"
                                   ComposerText="{Binding ChatInput, Mode=TwoWay}"
                                   IsComposerEnabled="{Binding !IsChatLoading}"
                                   IsSlashAutocompleteVisible="{Binding IsComposerAutocompleteVisible}"
                                   SelectedSlashSuggestionIndex="{Binding SelectedComposerAutocompleteIndex, Mode=TwoWay}"
                                   SlashSuggestions="{Binding ComposerPopupSuggestions}"
                                   SlashAutocompletePathPrefix="{Binding ChatSlashPathPrefix}"
                                   SlashAutocompleteNextStep="{Binding ChatSlashNextStepLabel}"
                                   SlashAutocompleteBreadcrumb="{Binding ChatSlashBreadcrumb}"
                                   ComposerCaretIndex="{Binding ChatComposerCaretIndex, Mode=TwoWay}"
                                   ShowCockpitCommandLine="{Binding IsCockpitCommandLineOpen}"
                                   CommandLineText="{Binding CockpitCommandLineText, Mode=TwoWay}"
                                   CommandLinePreview="{Binding CockpitCommandLinePreview}"
                                   CommandLineCaretIndex="{Binding CockpitCommandLineCaretIndex, Mode=TwoWay}"/>

        <Border IsVisible="{Binding HasActiveClarificationBatch}"
                ZIndex="40"
                Background="#B0000000">
            <Border MaxWidth="520"
                    Margin="16"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Classes="cascadeSection">
                <StackPanel Spacing="8">
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Text="{Binding ActiveClarificationTitle}"
                                   Classes="chatPanelTitle"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
                        <Button DockPanel.Dock="Right"
                                Content="Закрыть"
                                Command="{Binding DismissClarificationBatchCommand}"
                                Padding="8,3"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding ClarificationDraftItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="chat:ClarificationDraftItemViewModel">
                                <Border Classes="cascadeInset" Margin="0,0,0,6">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding Prompt}" TextWrapping="Wrap"
                                                   Classes="chatPanelBody"
                                                   Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
                                        <TextBox Text="{Binding Answer, Mode=TwoWay}"
                                                 Classes="chatPanelInput"
                                                 IsVisible="{Binding IsFreeText}"
                                                 AcceptsReturn="True"
                                                 MinHeight="56"
                                                 TextWrapping="Wrap"
                                                 PlaceholderText="Ответ..."/>
                                        <ComboBox ItemsSource="{Binding ChoiceOptions}"
                                                  Classes="chatPanelInput"
                                                  SelectedItem="{Binding Answer, Mode=TwoWay}"
                                                  IsVisible="{Binding IsChoice}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Отправить уточнения"
                                Command="{Binding SubmitClarificationResponseCommand}"
                                Padding="10,4"/>
                        <TextBlock Text="{Binding ClarificationStatusText}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Panel>
</UserControl>
