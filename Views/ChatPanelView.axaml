<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:feat="using:CascadeIDE.Features.Instrumentation"
             xmlns:views="using:CascadeIDE.Views"
             xmlns:lang="using:CascadeIDE.Lang"
             x:Class="CascadeIDE.Views.ChatPanelView"
             x:Name="ChatPanelRoot"
             Classes.power="{Binding IsPowerMode}"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="Border.traceStepCard">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.traceStatus">
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.traceStatus.success">
            <Setter Property="Background" Value="#173E2A"/>
            <Setter Property="BorderBrush" Value="#2D8A5A"/>
        </Style>
        <Style Selector="Border.traceStatus.warning">
            <Setter Property="Background" Value="#4A3A15"/>
            <Setter Property="BorderBrush" Value="#B68A2A"/>
        </Style>
        <Style Selector="Border.traceStatus.pending">
            <Setter Property="Background" Value="#26314A"/>
            <Setter Property="BorderBrush" Value="#4D72D5"/>
        </Style>
        <Style Selector="Border.chatPanelSection">
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <!-- Power cockpit: одинаковый ритм секций trace + safety -->
        <Style Selector="Border.powerCockpitBlock">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.chatLoadingBanner">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="UserControl">
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="UserControl.power">
            <Setter Property="Margin" Value="6,6,8,6"/>
        </Style>
        <Style Selector="Border#ChatIslandInner">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatPanelBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="Border#ChatIslandInner.power">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BoxShadow" Value="0 0 28 0 #668A65FF, 0 0 42 0 #4400C8E8, 0 4 22 0 #32000000"/>
        </Style>
        <Style Selector="UserControl.power Border.powerCockpitBlock">
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="UserControl.power Border.traceStepCard">
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <!-- Отдельная панель уровней (Power): ниже трассы, свой фон и кайма -->
        <Style Selector="Border.safetyLevelIsland">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.PowerSafetyDockBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.PowerNeonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="14,14"/>
            <Setter Property="Margin" Value="0,14,0,0"/>
            <Setter Property="BoxShadow" Value="0 14 36 0 #70000000, 0 0 0 1 #3000F0FF, inset 0 1 0 0 #1CFFFFFF"/>
        </Style>
        <!-- Объёмные «плитки» L1–L3: тень + подсветка сверху -->
        <Style Selector="Border.powerSafetyTierFace">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14,20"/>
            <Setter Property="MinHeight" Value="92"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BoxShadow" Value="0 14 32 0 #A0000000, 0 6 16 0 #58000000, inset 0 2 0 0 #35FFFFFF"/>
        </Style>
    </UserControl.Styles>
    <Panel>
        <Border IsVisible="{Binding IsPowerMode}"
                IsHitTestVisible="False"
                Background="{DynamicResource CascadeTheme.PowerChatIslandFrameBrush}"
                CornerRadius="14"/>
        <Border x:Name="ChatIslandInner"
                ZIndex="1"
                Classes.power="{Binding IsPowerMode}">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,4,96,Auto">
            <!-- Focus: план (чеклист) -->
            <Border Grid.Row="0" IsVisible="{Binding IsFocusMode}" Classes="modeCard chatPanelSection">
                <StackPanel Spacing="6">
                    <views:PanelChromeHeader Title="{Binding ChatPanel_PlanHeader, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Classes="compact"/>
                    <TextBlock IsVisible="{Binding !HasFocusPlanItems}"
                               Text="{Binding ChatPanel_PlanEmptyHint, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                               FontSize="11"/>
                    <ScrollViewer IsVisible="{Binding HasFocusPlanItems}"
                                  MaxHeight="120"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FocusPlanItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:FocusPlanItemViewModel">
                                    <CheckBox Content="{Binding Text}"
                                              IsChecked="{Binding IsDone, Mode=TwoWay}"
                                              Margin="0,2,0,0"
                                              Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Focus: один следующий шаг -->
            <Border Grid.Row="1" IsVisible="{Binding IsFocusMode}" Classes="modeCard chatPanelSection">
                <StackPanel Spacing="4">
                    <views:PanelChromeHeader Title="{Binding ChatPanel_NextActionHeader, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Classes="compact"/>
                    <TextBlock Text="{Binding NextActionSummary}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" IsVisible="{Binding ShowAgentOperationsBlock}" Classes="modeCard chatPanelSection">
                <StackPanel Spacing="6">
                    <views:PanelChromeHeader Title="{Binding ChatPanel_AgentOpsHeader, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Classes="compact"/>
                    <TextBlock Text="{Binding ActiveObjective}"
                               TextWrapping="Wrap"
                               MaxLines="2"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>

                    <StackPanel DataContext="{Binding InstrumentationPanel}" x:DataType="feat:InstrumentationPanelViewModel">
                        <TextBlock IsVisible="{Binding !HasAgentToolCalls}"
                                   Text="{Binding ChatPanel_AgentOpsEmptyHint, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                   FontSize="11"/>

                        <ScrollViewer IsVisible="{Binding HasAgentToolCalls}"
                                      MaxHeight="88"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding AgentToolCalls}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,2">
                                            <TextBlock DockPanel.Dock="Left"
                                                       Text="• "
                                                       Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                                            <TextBlock Text="{Binding}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <Border Classes="modeCard" Padding="6,4" IsVisible="{Binding IsRiskCardVisible}">
                        <TextBlock Text="{Binding RiskSummary}"
                                   Foreground="{DynamicResource CascadeTheme.ToolbarErrorForeground}"
                                   TextWrapping="Wrap"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                    <Border Classes="modeCard" Padding="6,4" IsVisible="{Binding IsResultCardVisible}">
                        <TextBlock Text="{Binding ResultSummary}"
                                   Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"
                                   TextWrapping="Wrap"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </StackPanel>
            </Border>
            <Border Grid.Row="3" IsVisible="{Binding IsFocusMode}" Classes="modeCard chatPanelSection">
                <StackPanel Spacing="6">
                    <views:PanelChromeHeader Title="{Binding ChatPanel_ConfirmHeader, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Classes="compact"/>
                    <TextBlock Text="{Binding ChatPanel_ConfirmHint, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="{Binding ChatPanel_ConfirmButton, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Command="{Binding ConfirmFocusStepCommand}"/>
                        <Button Content="{Binding ChatPanel_CancelButton, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Command="{Binding CancelFocusStepCommand}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="{Binding ChatPanel_ExplainStep, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Command="{Binding ExplainCurrentStepCommand}"/>
                        <Button Content="{Binding ChatPanel_EmergencyStop, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Command="{Binding EmergencyStopCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Row="4" IsVisible="{Binding ShowAgentTrace}" Classes="modeCard chatPanelSection powerCockpitBlock">
                <StackPanel Spacing="6">
                    <views:PanelChromeHeader Title="{Binding ChatPanel_TraceHeader, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Classes="compact" UppercaseTitle="True"/>
                    <StackPanel DataContext="{Binding InstrumentationPanel}" x:DataType="feat:InstrumentationPanelViewModel" Spacing="6">
                        <TextBlock IsVisible="{Binding !HasAgentTraceSteps}"
                                   Text="{Binding ChatPanel_TraceEmptyHint, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                   FontSize="11"
                                   TextWrapping="Wrap"/>
                        <ScrollViewer MaxHeight="220"
                                      VerticalScrollBarVisibility="Auto"
                                      IsVisible="{Binding HasAgentTraceSteps}">
                            <ItemsControl ItemsSource="{Binding AgentTraceSteps}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:AgentTraceStepViewModel">
                                        <Border Classes="traceStepCard">
                                            <StackPanel Spacing="4">
                                                <DockPanel LastChildFill="False">
                                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding TimestampText}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                                                        <TextBlock Text="{Binding Kind}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                                                    </StackPanel>
                                                    <Border DockPanel.Dock="Right"
                                                            Classes.success="{Binding IsSuccess}"
                                                            Classes.warning="{Binding IsWarning}"
                                                            Classes.pending="{Binding IsPending}"
                                                            Classes="traceStatus">
                                                        <TextBlock Text="{Binding Status}"
                                                                   Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"
                                                                   FontSize="11"/>
                                                    </Border>
                                                </DockPanel>
                                                <TextBlock Text="{Binding Text}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Button Content="{Binding ChatPanel_ExplainStep, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                                                            Command="{Binding #ChatPanelRoot.DataContext.ExplainTraceStepCommand}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="{Binding ChatPanel_TraceRollback, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                                                            Command="{Binding #ChatPanelRoot.DataContext.RollbackTraceStepCommand}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </StackPanel>
            </Border>
            <!-- Безопасность: в Power — отдельный «док» под трасой; иначе компактная карточка -->
            <Border Grid.Row="5"
                    IsVisible="{Binding ShowSafetyControls}"
                    Classes="chatPanelSection">
                <Grid>
                <Border IsVisible="{Binding IsPowerMode}" Classes="safetyLevelIsland">
                    <StackPanel Spacing="12">
                        <views:PanelChromeHeader Title="{Binding ChatPanel_SafetyDockTitlePower, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                                                 UppercaseTitle="True"
                                                 ShowEmergencyStop="True"
                                                 EmergencyStopCommand="{Binding EmergencyStopCommand}"/>
                        <TextBlock Text="{Binding SafetyLevelDescription}"
                                   TextWrapping="Wrap"
                                   MaxLines="3"
                                   TextTrimming="CharacterEllipsis"
                                   FontSize="11"
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                        <UniformGrid Columns="3">
                            <Grid>
                                <Border CornerRadius="16"
                                        Padding="3"
                                        Margin="-4"
                                        BorderThickness="3"
                                        BorderBrush="{DynamicResource CascadeTheme.PowerNeonAccent}"
                                        Background="Transparent"
                                        BoxShadow="0 0 28 0 #A0BF5FFF, 0 0 44 0 #50D080FF"
                                        IsVisible="{Binding IsSafetyL1}"/>
                                <Button Command="{Binding SetSafetyL1Command}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0">
                                    <Border Classes="powerSafetyTierFace"
                                            BorderBrush="{DynamicResource CascadeTheme.PowerNeonBorder}"
                                            Background="{DynamicResource CascadeTheme.PowerSafetyL1}"
                                            Opacity="{Binding SafetyL1Opacity}">
                                        <StackPanel Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ChatPanel_SafetyTierL1, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                                                       FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
                                            <TextBlock Text="{Binding ChatPanel_SafetyTierL1Subtitle, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </Grid>
                            <Grid>
                                <Border CornerRadius="16"
                                        Padding="3"
                                        Margin="-4"
                                        BorderThickness="3"
                                        BorderBrush="{DynamicResource CascadeTheme.PowerNeonAccent}"
                                        Background="Transparent"
                                        BoxShadow="0 0 28 0 #A0BF5FFF, 0 0 44 0 #50D080FF"
                                        IsVisible="{Binding IsSafetyL2}"/>
                                <Button Command="{Binding SetSafetyL2Command}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0">
                                    <Border Classes="powerSafetyTierFace"
                                            BorderBrush="{DynamicResource CascadeTheme.PowerNeonBorder}"
                                            Background="{DynamicResource CascadeTheme.PowerSafetyL2}"
                                            Opacity="{Binding SafetyL2Opacity}">
                                        <StackPanel Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ChatPanel_SafetyTierL2, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                                                       FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
                                            <TextBlock Text="{Binding ChatPanel_SafetyTierL2Subtitle, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </Grid>
                            <Grid>
                                <Border CornerRadius="16"
                                        Padding="3"
                                        Margin="-4"
                                        BorderThickness="3"
                                        BorderBrush="{DynamicResource CascadeTheme.PowerNeonAccent}"
                                        Background="Transparent"
                                        BoxShadow="0 0 32 0 #B0D080FF, 0 0 52 0 #60FF6B9D"
                                        IsVisible="{Binding IsSafetyL3}"/>
                                <Button Command="{Binding SetSafetyL3Command}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0">
                                    <Border Classes="powerSafetyTierFace"
                                            BorderBrush="{DynamicResource CascadeTheme.PowerNeonBorder}"
                                            Background="{DynamicResource CascadeTheme.PowerSafetyL3}"
                                            Opacity="{Binding SafetyL3Opacity}">
                                        <StackPanel Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ChatPanel_SafetyTierL3, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                                                       FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
                                            <TextBlock Text="{Binding ChatPanel_SafetyTierL3Subtitle, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </Grid>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding !IsPowerMode}" Classes="modeCard">
                    <StackPanel Spacing="8">
                        <views:PanelChromeHeader Title="{Binding ChatPanel_SafetyCompactHeader, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Classes="compact" UppercaseTitle="True"/>
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Content="{Binding ChatPanel_SafetyTierL1, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Command="{Binding SetSafetyL1Command}"/>
                                <Button Content="{Binding ChatPanel_SafetyTierL2, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Command="{Binding SetSafetyL2Command}"/>
                                <Button Content="{Binding ChatPanel_SafetyTierL3, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Command="{Binding SetSafetyL3Command}"/>
                                <TextBlock Text="{Binding SafetyLevel}"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"
                                           Margin="6,0,0,0"/>
                            </StackPanel>
                            <Button Content="{Binding ChatPanel_EmergencyStopCompact, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                                    Command="{Binding EmergencyStopCommand}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                </Grid>
            </Border>
            <GridSplitter Grid.Row="6" Height="4" ResizeDirection="Rows" Background="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}" IsVisible="{Binding IsChatPanelExpanded}"/>

            <DockPanel Grid.Row="7">
                <Button DockPanel.Dock="Left" Content="{Binding ChatPanel_ChatExpandButton, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Command="{Binding ToggleChatPanelCommand}"
                        IsVisible="{Binding !IsChatPanelExpanded}"
                        ToolTip.Tip="{Binding ChatPanel_ChatExpandTooltip, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Padding="6,8" Margin="0,0,4,0"
                        VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4" IsVisible="{Binding IsChatPanelExpanded}">
                    <Button Content="{Binding ChatPanelToggleButtonText}" Command="{Binding ToggleChatPanelCommand}" ToolTip.Tip="{Binding ChatPanel_ChatCollapseTooltip, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}" Padding="4,2"/>
                </StackPanel>
                <Border DockPanel.Dock="Top"
                        DataContext="{Binding ChatPanel}"
                        Classes="chatLoadingBanner"
                        IsVisible="{Binding IsChatLoading}">
                    <TextBlock Text="{Binding ChatPanel_AgentTyping, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                               FontSize="11"/>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto" IsVisible="{Binding IsChatPanelExpanded}">
                    <StackPanel DataContext="{Binding ChatPanel}" Spacing="6">
                        <TextBlock IsVisible="{Binding !HasChatMessages}"
                                   Text="{Binding ChatPanel_NoMessagesYet, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                   FontSize="11"/>
                        <ItemsControl ItemsSource="{Binding ChatMessages}"
                                      IsVisible="{Binding HasChatMessages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:ChatMessageViewModel">
                                    <Border Margin="0,0,0,6" Padding="8" Background="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}" CornerRadius="4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Role}" FontWeight="SemiBold" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}" FontSize="11"/>
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>

            <StackPanel Grid.Row="8" Margin="0,8,0,0" IsVisible="{Binding IsChatPanelExpanded}" MinHeight="56">
                <StackPanel DataContext="{Binding ChatPanel}" Spacing="4">
                    <TextBox x:Name="ChatInputBox"
                             Text="{Binding ChatInput, Mode=TwoWay}"
                             Watermark="{Binding ChatPanel_MessageWatermark, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                             MinHeight="40"
                             AcceptsReturn="True"
                             IsEnabled="{Binding !IsChatLoading}"
                             TextWrapping="Wrap"/>
                    <Button Content="{Binding ChatPanel_SendButton, Source={StaticResource Loc}, DataType={x:Type lang:LocViewModel}}"
                            Command="{Binding SendChatCommand}"
                            IsEnabled="{Binding !IsChatLoading}"
                            Background="{DynamicResource CascadeTheme.SendButtonBackground}"
                            Foreground="{DynamicResource CascadeTheme.SendButtonForeground}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
        </Border>
    </Panel>
</UserControl>
