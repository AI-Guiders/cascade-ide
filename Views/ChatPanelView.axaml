<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chat="using:CascadeIDE.Features.Chat"
             xmlns:vm="using:CascadeIDE.ViewModels"
             x:Class="CascadeIDE.Views.ChatPanelView"
             x:DataType="chat:ChatPanelViewModel">
    <UserControl.Styles>
        <Style Selector="Border.section">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
        <Border Grid.Row="0" Classes="section">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Spacing="2">
                    <TextBlock Text="Agent Chat" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
                    <TextBlock Text="Живой диалог + структурированные уточнения"
                               FontSize="11"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                </StackPanel>
                <Border DockPanel.Dock="Right" CornerRadius="10" Padding="8,3"
                        Background="#2E3A52" BorderBrush="#50658C" BorderThickness="1"
                        IsVisible="{Binding IsChatLoading}">
                    <TextBlock Text="Модель отвечает..." FontSize="11" Foreground="#D8E4FF"/>
                </Border>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Classes="section" IsVisible="{Binding HasActiveClarificationBatch}">
            <StackPanel Spacing="8">
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left" Text="{Binding ActiveClarificationTitle}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
                    <Button DockPanel.Dock="Right"
                            Content="Закрыть"
                            Command="{Binding DismissClarificationBatchCommand}"
                            Padding="8,3"/>
                </DockPanel>

                <ItemsControl ItemsSource="{Binding ClarificationDraftItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="chat:ClarificationDraftItemViewModel">
                            <Border CornerRadius="6" Padding="8" Margin="0,0,0,6"
                                    Background="#1A1A1A" BorderBrush="#3F3F3F" BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding Prompt}" TextWrapping="Wrap"
                                               Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>

                                    <TextBox Text="{Binding Answer, Mode=TwoWay}"
                                             IsVisible="{Binding IsFreeText}"
                                             AcceptsReturn="True"
                                             MinHeight="56"
                                             TextWrapping="Wrap"
                                             Watermark="Ответ..."/>

                                    <ComboBox ItemsSource="{Binding ChoiceOptions}"
                                              SelectedItem="{Binding Answer, Mode=TwoWay}"
                                              IsVisible="{Binding IsChoice}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Отправить уточнения"
                            Command="{Binding SubmitClarificationResponseCommand}"
                            Padding="10,4"/>
                    <TextBlock Text="{Binding ClarificationStatusText}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Classes="section">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Диалог"
                           FontSize="12"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="6">
                        <TextBlock IsVisible="{Binding !HasChatMessages}"
                                   Text="Пока пусто. Задай вопрос или команду."
                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                   FontSize="11"/>
                        <ItemsControl ItemsSource="{Binding ChatMessages}" IsVisible="{Binding HasChatMessages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:ChatMessageViewModel">
                                    <Border CornerRadius="6"
                                            Padding="8"
                                            Margin="0,0,0,4"
                                            Background="{DynamicResource CascadeTheme.ChatMessageBubbleBackground}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Role}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                                            <TextBlock Text="{Binding Content}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Row="3" Classes="section">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox x:Name="ChatInputBox"
                         Grid.Column="0"
                         Text="{Binding ChatInput, Mode=TwoWay}"
                         Watermark="Сообщение агенту..."
                         AcceptsReturn="True"
                         MinHeight="52"
                         TextWrapping="Wrap"
                         IsEnabled="{Binding !IsChatLoading}"/>
                <Button Grid.Column="1"
                        Content="Отправить"
                        Command="{Binding SendChatCommand}"
                        IsEnabled="{Binding !IsChatLoading}"
                        Padding="14,8"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
