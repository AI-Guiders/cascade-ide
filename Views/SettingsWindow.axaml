<views:PointerTrackingWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CascadeIDE.ViewModels"
        xmlns:views="using:CascadeIDE.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="CascadeIDE.Views.SettingsWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Настройки"
        Width="760" Height="640"
        MinWidth="560" MinHeight="480"
        Background="{DynamicResource CascadeTheme.MainWindowBackground}"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="12">
        <Button x:Name="CloseButton"
                DockPanel.Dock="Bottom"
                Content="Закрыть"
                HorizontalAlignment="Right"
                MinWidth="100"
                Margin="0,12,0,0"
                Padding="10,6"/>
        <views:SettingsShellView/>
    </DockPanel>
</views:PointerTrackingWindow>
