<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CascadeIDE.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="CascadeIDE.Views.SettingsWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Настройки"
        Width="480" Height="520"
        MinWidth="400" MinHeight="400"
        Background="{DynamicResource CascadeTheme.MainWindowBackground}"
        WindowStartupLocation="CenterOwner">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel Spacing="16">
            <TextBlock Text="AI и чат" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>

            <StackPanel Spacing="6">
                <TextBlock Text="Провайдер:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                <ComboBox ItemsSource="{Binding AiProviderKeysList}" SelectedItem="{Binding ActiveAiProvider}" MinWidth="200"/>
            </StackPanel>

            <StackPanel Spacing="6" IsVisible="{Binding IsOllamaSelected}">
                <TextBlock Text="Модель Ollama:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                <ComboBox ItemsSource="{Binding OllamaModelChoices}"
                          SelectedItem="{Binding SelectedOllamaModel}"
                          MinWidth="240"
                          IsEnabled="{Binding OllamaAvailable}"/>
                <TextBlock Text="{Binding SelectedModelDetails}" FontSize="11" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Spacing="6" IsVisible="{Binding IsAnthropicSelected}">
                <TextBlock Text="Anthropic API key:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                <TextBox Text="{Binding AnthropicApiKey, Mode=TwoWay}" PasswordChar="*" Watermark="sk-ant-..." MinWidth="280"/>
            </StackPanel>
            <StackPanel Spacing="6" IsVisible="{Binding IsOpenAiSelected}">
                <TextBlock Text="OpenAI API key:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                <TextBox Text="{Binding OpenAiApiKey, Mode=TwoWay}" PasswordChar="*" Watermark="sk-..." MinWidth="280"/>
            </StackPanel>
            <StackPanel Spacing="6" IsVisible="{Binding IsDeepSeekSelected}">
                <TextBlock Text="DeepSeek API key:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                <TextBox Text="{Binding DeepSeekApiKey, Mode=TwoWay}" PasswordChar="*" Watermark="sk-..." MinWidth="280"/>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Отправка сообщения в чате:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                <ComboBox ItemsSource="{Binding SendMessageKeyOptionsList}" SelectedItem="{Binding SendMessageKey}" MinWidth="140"/>
            </StackPanel>

            <CheckBox Content="Минимальный контекст (только диагностики и сигнатуры)" IsChecked="{Binding UseMinimizedContext}" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <CheckBox Content="Запускать MCP-сервер при старте с --mcp-stdio" IsChecked="{Binding IdeMcpServerEnabled}" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>

            <Button x:Name="CloseButton" Content="Закрыть" HorizontalAlignment="Right" MinWidth="100" Margin="0,8,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Window>
