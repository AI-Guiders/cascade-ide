<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:chrome="using:CascadeIDE.Features.UiChrome"
             x:Class="CascadeIDE.Views.TelemetryStripView"
             Classes.power="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="StackPanel#TelemetryRoot">
            <Setter Property="Margin" Value="8,4"/>
        </Style>
        <Style Selector="UserControl.power StackPanel#TelemetryRoot">
            <Setter Property="Margin" Value="10,8,12,8"/>
        </Style>
    </UserControl.Styles>
    <StackPanel x:Name="TelemetryRoot" Spacing="6">
        <!-- Balanced / Focus: классическая полоса -->
        <Border Padding="8,6"
                Classes="modeCard"
                IsVisible="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyNe}, ConverterParameter=Power}">
            <ItemsControl ItemsSource="{Binding WorkspaceTelemetrySegments}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemHeight="28" VerticalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="chrome:WorkspaceTelemetrySegment">
                        <Border Classes="modeCard" Padding="6,2" Margin="0,0,8,0">
                            <TextBlock Text="{Binding LineText}" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Power: кокпит — одна «SOC»-полоса + компактный JSON -->
        <Border IsVisible="{Binding UiModeFamily, Converter={StaticResource UiModeFamilyEq}, ConverterParameter=Power}"
                Background="{DynamicResource CascadeTheme.PowerTelemetryStripBackground}"
                BorderBrush="{DynamicResource CascadeTheme.PowerNeonBorder}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12,10"
                BoxShadow="0 0 36 0 #6600E5FF, 0 0 56 0 #448A65FF, 0 6 28 0 #48000000">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto">
                    <ItemsControl Grid.Column="0"
                                  ItemsSource="{Binding WorkspaceTelemetrySegments}"
                                  HorizontalAlignment="Left">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="chrome:WorkspaceTelemetrySegment">
                                <Panel>
                                    <Border IsVisible="{Binding IsBuildSource}"
                                            Margin="0,0,8,0"
                                            Padding="10,6"
                                            CornerRadius="6"
                                            Background="{DynamicResource CascadeTheme.PowerCockpitPanelBackground}"
                                            BorderBrush="{DynamicResource CascadeTheme.PowerNeonAccent}"
                                            BorderThickness="1">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Panel VerticalAlignment="Center">
                                                <TextBlock Text="●" FontSize="12" Foreground="#FF6B8A" IsVisible="{Binding IsBuildRunning}"/>
                                                <TextBlock Text="●" FontSize="12" Foreground="#2D8A5A" IsVisible="{Binding !IsBuildRunning}"/>
                                            </Panel>
                                            <TextBlock Text="{Binding CockpitShort}"
                                                       FontWeight="Bold"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border IsVisible="{Binding !IsBuildSource}"
                                            Margin="0,0,8,0"
                                            Padding="10,6"
                                            CornerRadius="6"
                                            Background="{DynamicResource CascadeTheme.PowerCockpitPanelBackground}"
                                            BorderBrush="{DynamicResource CascadeTheme.PowerNeonBorder}"
                                            BorderThickness="1"
                                            MaxWidth="220">
                                        <TextBlock Text="{Binding CockpitShort}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="11"
                                                   MaxWidth="200"
                                                   Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                                    </Border>
                                </Panel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Grid.Column="1"
                               Text="WORKSPACE"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Opacity="0.75"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                </Grid>

                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,*">
                    <Button Grid.Row="0" Grid.Column="0"
                            Content="Обновить снимок"
                            Command="{Binding RefreshWorkspaceSnapshotCommand}"
                            VerticalAlignment="Top"
                            Margin="0,0,8,0"
                            Padding="10,4"/>
                    <ScrollViewer Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                  MaxHeight="100"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBox Text="{Binding WorkspaceSnapshotJson, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas,monospace"
                                 FontSize="10"
                                 MinHeight="40"
                                 Background="Transparent"
                                 Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"
                                 BorderThickness="0"/>
                    </ScrollViewer>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
