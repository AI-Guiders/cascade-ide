<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             x:Class="CascadeIDE.Views.TelemetryStripView"
             Classes.power="{Binding IsPowerMode}"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="StackPanel#TelemetryRoot">
            <Setter Property="Margin" Value="8,4"/>
        </Style>
        <Style Selector="UserControl.power StackPanel#TelemetryRoot">
            <Setter Property="Margin" Value="10,8,12,8"/>
        </Style>
    </UserControl.Styles>
    <StackPanel x:Name="TelemetryRoot" Spacing="6">
        <!-- Balanced / Focus: классическая полоса -->
        <Border Padding="8,6"
                Classes="modeCard"
                IsVisible="{Binding !IsPowerMode}">
            <WrapPanel Orientation="Horizontal" ItemHeight="28" VerticalAlignment="Center">
                <Border Classes="modeCard" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="{Binding TelemetryBuildText}" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                </Border>
                <Border Classes="modeCard" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="{Binding TelemetryTestsText}" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                </Border>
                <Border Classes="modeCard" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="{Binding TelemetryDebugText}" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                </Border>
                <Border Classes="modeCard" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="{Binding TelemetryGitText}" Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                </Border>
            </WrapPanel>
        </Border>

        <!-- Power: кокпит — одна «SOC»-полоса + компактный JSON -->
        <Border IsVisible="{Binding IsPowerMode}"
                Background="{DynamicResource CascadeTheme.PowerTelemetryStripBackground}"
                BorderBrush="{DynamicResource CascadeTheme.PowerNeonBorder}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12,10"
                BoxShadow="0 0 36 0 #6600E5FF, 0 0 56 0 #448A65FF, 0 6 28 0 #48000000">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*"
                      RowDefinitions="Auto">
                    <!-- Сборка -->
                    <Border Grid.Column="0"
                            Margin="0,0,8,0"
                            Padding="10,6"
                            CornerRadius="6"
                            Background="{DynamicResource CascadeTheme.PowerCockpitPanelBackground}"
                            BorderBrush="{DynamicResource CascadeTheme.PowerNeonAccent}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Panel VerticalAlignment="Center">
                                <TextBlock Text="●" FontSize="12" Foreground="#FF6B8A" IsVisible="{Binding IsBuilding}"/>
                                <TextBlock Text="●" FontSize="12" Foreground="#2D8A5A" IsVisible="{Binding !IsBuilding}"/>
                            </Panel>
                            <TextBlock Text="{Binding TelemetryBuildCockpitShort}"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                        </StackPanel>
                    </Border>
                    <!-- Тесты -->
                    <Border Grid.Column="1"
                            Margin="0,0,8,0"
                            Padding="10,6"
                            CornerRadius="6"
                            Background="{DynamicResource CascadeTheme.PowerCockpitPanelBackground}"
                            BorderBrush="{DynamicResource CascadeTheme.PowerNeonBorder}"
                            BorderThickness="1"
                            MaxWidth="220">
                        <TextBlock Text="{Binding TelemetryTestsCockpitShort}"
                                   TextTrimming="CharacterEllipsis"
                                   FontSize="11"
                                   Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                    </Border>
                    <!-- Отладка -->
                    <Border Grid.Column="2"
                            Margin="0,0,8,0"
                            Padding="10,6"
                            CornerRadius="6"
                            Background="{DynamicResource CascadeTheme.PowerCockpitPanelBackground}"
                            BorderBrush="{DynamicResource CascadeTheme.PowerNeonBorder}"
                            BorderThickness="1">
                        <TextBlock Text="{Binding TelemetryDebugCockpitShort}"
                                   FontSize="11"
                                   Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                    </Border>
                    <!-- Git -->
                    <Border Grid.Column="3"
                            Margin="0,0,8,0"
                            Padding="10,6"
                            CornerRadius="6"
                            Background="{DynamicResource CascadeTheme.PowerCockpitPanelBackground}"
                            BorderBrush="{DynamicResource CascadeTheme.PowerNeonBorder}"
                            BorderThickness="1"
                            MaxWidth="200">
                        <TextBlock Text="{Binding TelemetryGitCockpitShort}"
                                   TextTrimming="CharacterEllipsis"
                                   FontSize="11"
                                   Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
                    </Border>
                    <TextBlock Grid.Column="4"
                               Text="WORKSPACE"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Opacity="0.75"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
                </Grid>

                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,*">
                    <Button Grid.Row="0" Grid.Column="0"
                            Content="Обновить снимок"
                            Command="{Binding RefreshWorkspaceSnapshotCommand}"
                            VerticalAlignment="Top"
                            Margin="0,0,8,0"
                            Padding="10,4"/>
                    <ScrollViewer Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                  MaxHeight="100"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBox Text="{Binding WorkspaceSnapshotJson, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas,monospace"
                                 FontSize="10"
                                 MinHeight="40"
                                 Background="Transparent"
                                 Foreground="{DynamicResource CascadeTheme.ToolbarTextForeground}"
                                 BorderThickness="0"/>
                    </ScrollViewer>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
