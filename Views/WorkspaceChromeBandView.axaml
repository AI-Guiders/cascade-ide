<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:CascadeIDE.Views"
             xmlns:vm="using:CascadeIDE.ViewModels"
             x:Class="CascadeIDE.Views.WorkspaceChromeBandView"
             x:DataType="vm:MainWindowViewModel">
    <Grid RowDefinitions="Auto,*">
        <views:EicasAlertsBarView Grid.Row="0"
                                  IsVisible="{Binding ShowEicasAlertsBar}"/>
        <!-- Полоса телеметрии: раньше выравнивалась по MainGrid; теперь зона — MFD, на всю ширину контейнера. -->
        <Grid Grid.Row="1" IsVisible="{Binding ShowWorkspaceHealthStrip}">
            <views:WorkspaceHealthStripView/>
        </Grid>
    </Grid>
</UserControl>
