<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cn="using:CascadeIDE.Services.ChordNotation"
             x:Class="CascadeIDE.Views.ChordKeycapStrip">
    <!-- Шаги последовательности — группы кэпов; внутри шага кэпы плотным рядом. ItemsSource задаётся из кода. -->
    <ItemsControl x:Name="StepsHost">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="10"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate DataType="cn:ChordKeycapStep">
                <ItemsControl ItemsSource="{Binding Segments}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="cn:ChordKeycapSegment">
                            <Border MinWidth="28"
                                    Padding="8,5"
                                    CornerRadius="5"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                                    Background="{DynamicResource CascadeTheme.TerminalBackground}">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                           Text="{Binding Label}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
