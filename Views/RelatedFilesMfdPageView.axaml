<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:nav="using:CascadeIDE.Features.WorkspaceNavigation.Presentation"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:views="using:CascadeIDE.Views"
             x:Class="CascadeIDE.Views.RelatedFilesMfdPageView"
             x:DataType="nav:WorkspaceNavigationMapViewModel">
    <UserControl.Resources>
        <views:StringNotEmptyToBoolConverter x:Key="HciOrientationLineVisible"/>
    </UserControl.Resources>
    <!-- Связанные файлы (WorkspaceNavigation) — отдельная страница MFD; PFD остаётся граф/CF (ADR 0088). -->
    <Grid RowDefinitions="Auto,*" MinHeight="0">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
            <views:PanelChromeHeader Grid.Column="0"
                                     Title="Связанные файлы · workspace"
                                     UppercaseTitle="True"/>
            <Border Grid.Column="1"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0"
                    Padding="6,2"
                    CornerRadius="4"
                    Background="#22000000"
                    BorderBrush="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                    BorderThickness="1"
                    IsVisible="{Binding WorkspaceNavigationMapHasRelated}">
                <TextBlock FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                           Text="{Binding WorkspaceNavigationMapRelatedBadge}"/>
            </Border>
        </Grid>
        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" MinHeight="0">
            <TextBlock Grid.Row="0" FontSize="10" TextWrapping="Wrap" Opacity="0.9"
                       Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                       Text="{Binding CodeNavigationMapSettingsSummaryLine}"/>
            <TextBlock Grid.Row="1" FontSize="10" TextWrapping="Wrap" Opacity="0.85"
                       Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                       IsVisible="{Binding WorkspaceNavigationMapHciOrientationLine, Converter={StaticResource HciOrientationLineVisible}}"
                       Text="{Binding WorkspaceNavigationMapHciOrientationLine}"/>
            <Button Grid.Row="2"
                    Margin="0,2,0,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Left"
                    Command="{Binding OpenWorkspaceFeatureDocsCommand}"
                    IsVisible="{Binding WorkspaceFeatureLine, Converter={StaticResource HciOrientationLineVisible}}">
                <TextBlock FontSize="10" TextWrapping="Wrap" Opacity="0.9"
                           Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                           Text="{Binding WorkspaceFeatureLine}"/>
            </Button>
            <Button Grid.Row="3"
                    Margin="0,2,0,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Left"
                    Command="{Binding OpenWorkspaceAdrCorrespondenceCommand}"
                    IsVisible="{Binding WorkspaceAdrCorrespondenceLine, Converter={StaticResource HciOrientationLineVisible}}">
                <TextBlock FontSize="10" TextWrapping="Wrap" Opacity="0.9"
                           Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                           Text="{Binding WorkspaceAdrCorrespondenceLine}"/>
            </Button>
            <TextBlock Grid.Row="4" Margin="0,2,0,0" FontSize="10" TextWrapping="Wrap" Opacity="0.85"
                       Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                       IsVisible="{Binding WorkspaceDocsCoverageLine, Converter={StaticResource HciOrientationLineVisible}}"
                       Text="{Binding WorkspaceDocsCoverageLine}"/>
            <StackPanel Grid.Row="5" Margin="0,6,0,0" Spacing="4" Orientation="Horizontal">
                <TextBlock FontSize="11" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}" Text="Якорь:"/>
                <TextBlock FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                           Text="{Binding WorkspaceNavigationMapAnchorLabel}"/>
            </StackPanel>
            <TextBlock Grid.Row="6" Margin="0,8,0,4"
                       Text="{Binding WorkspaceNavigationMapStatus}"
                       FontSize="11" TextWrapping="Wrap"
                       Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <Panel Grid.Row="7">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding ShowCodeNavigationMapList}">
                    <ItemsControl ItemsSource="{Binding WorkspaceNavigationMapItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:WorkspaceNavigationMapItemVm">
                                <Button Margin="0,0,0,6"
                                        Padding="6,8"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Background="Transparent"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"
                                        CornerRadius="6"
                                        Command="{Binding $parent[UserControl].DataContext.OpenWorkspaceNavigationRelatedCommand}"
                                        CommandParameter="{Binding FullPath}">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding RelativePath}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource CascadeTheme.SolutionExplorerHeaderForeground}"/>
                                        <TextBlock Text="{Binding KindRationaleLine}"
                                                   FontSize="10" Opacity="0.85"
                                                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <TextBlock VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           FontSize="11"
                           Opacity="0.85"
                           Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                           IsVisible="{Binding !ShowCodeNavigationMapList}"
                           Text="Список отключён: в [code_navigation_map] view задай list или both. Граф остаётся на PFD (карта намерений)."/>
            </Panel>
        </Grid>
    </Grid>
</UserControl>
