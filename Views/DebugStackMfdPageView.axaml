<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:views="using:CascadeIDE.Views"
             x:Class="CascadeIDE.Views.DebugStackMfdPageView"
             x:DataType="vm:MainWindowViewModel">
    <!-- Страница Mfd «Отладка · стек / Locals»; DataContext — MainWindowViewModel (как у соседних Mfd-страниц). -->
    <Grid RowDefinitions="Auto,2*,4,Auto,3*" Margin="0,4,0,0">
        <views:PanelChromeHeader Grid.Row="0" Classes="terminal" Title="Стек вызовов · отладчик" UppercaseTitle="True"/>
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding InstrumentationPanel.DebugStackFrames}"
                 SelectedIndex="{Binding DebugStackSelectedIndex, Mode=TwoWay}"
                 BorderThickness="0"
                 Background="Transparent"
                 Padding="0,4,0,0"
                 MinHeight="48">
            <ListBox.Styles>
                <Style Selector="ListBoxItem:selected">
                    <Setter Property="Background" Value="#3040A0E0"/>
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="#2040A0E0"/>
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:DebugStackFrameViewModel">
                    <Grid ColumnDefinitions="28,*" Margin="0,0,0,2">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding FrameIndexText}"
                                   Opacity="0.55"
                                   VerticalAlignment="Top"
                                   FontFamily="Consolas,monospace"
                                   FontSize="11"
                                   Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
                            <TextBlock Text="{Binding LocationText}"
                                       FontSize="10.5"
                                       Opacity="0.8"
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas,monospace"
                                       Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <views:PanelChromeHeader Grid.Row="3" Classes="terminal" Title="Локальные · выбранный кадр" UppercaseTitle="True" Margin="0,8,0,0"/>
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid ColumnDefinitions="*,100,*"
                      Margin="0,0,0,4"
                      Opacity="0.75">
                    <TextBlock Grid.Column="0" Text="Имя" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
                    <TextBlock Grid.Column="1" Text="Тип" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
                    <TextBlock Grid.Column="2" Text="Значение" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
                </Grid>
                <TreeView x:CompileBindings="False"
                          ItemsSource="{Binding InstrumentationPanel.DebugVariableRoots}"
                          MinHeight="48">
                    <TreeView.Styles>
                        <Style Selector="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        </Style>
                    </TreeView.Styles>
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="vm:DebugVariableNodeViewModel">
                            <Panel>
                                <StackPanel IsVisible="{Binding IsScope}" Spacing="0" Margin="0,4,0,2">
                                    <TextBlock Text="{Binding SectionTitle}"
                                               FontWeight="SemiBold"
                                               FontSize="11"
                                               Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
                                </StackPanel>
                                <Border IsVisible="{Binding IsPlaceholder}" Height="0" Padding="0" Margin="0"/>
                                <Grid IsVisible="{Binding IsVariableRow}" ColumnDefinitions="*,100,*" ColumnSpacing="8" Margin="0,1,0,2">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding NamePart}"
                                               TextWrapping="Wrap"
                                               MinWidth="60"
                                               ToolTip.Tip="{Binding NamePart}"
                                               FontFamily="Consolas,monospace"
                                               FontSize="11"
                                               Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TypePart}"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="120"
                                               ToolTip.Tip="{Binding TypePart}"
                                               Opacity="0.9"
                                               FontFamily="Consolas,monospace"
                                               FontSize="10.5"
                                               Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Value}"
                                               TextWrapping="Wrap"
                                               MinWidth="40"
                                               FontFamily="Consolas,monospace"
                                               FontSize="11"
                                               Foreground="{DynamicResource CascadeTheme.TerminalForeground}"/>
                                </Grid>
                            </Panel>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
