<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             x:Class="CascadeIDE.Views.AiChatSettingsPanelView"
             x:DataType="vm:MainWindowViewModel">
    <StackPanel Spacing="16">
        <TextBlock Text="AI и чат" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>

        <StackPanel Spacing="6">
            <TextBlock Text="Провайдер:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <ComboBox ItemsSource="{Binding AiProviderKeysList}" SelectedItem="{Binding ActiveAiProvider}" MinWidth="200"/>
        </StackPanel>

        <StackPanel Spacing="6" IsVisible="{Binding IsOllamaSelected}">
            <TextBlock Text="Модель Ollama:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <ComboBox ItemsSource="{Binding OllamaModelChoices}"
                      SelectedItem="{Binding SelectedOllamaModel}"
                      MinWidth="240"
                      IsEnabled="{Binding OllamaAvailable}"/>
            <TextBlock Text="{Binding SelectedModelDetails}" FontSize="11" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Spacing="6" IsVisible="{Binding IsAnthropicSelected}">
            <TextBlock Text="Anthropic API key:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <TextBox Text="{Binding AnthropicApiKey, Mode=TwoWay}" PasswordChar="*" PlaceholderText="sk-ant-..." MinWidth="280"/>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding IsOpenAiSelected}">
            <TextBlock Text="OpenAI API key:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <TextBox Text="{Binding OpenAiApiKey, Mode=TwoWay}" PasswordChar="*" PlaceholderText="sk-..." MinWidth="280"/>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding IsDeepSeekSelected}">
            <TextBlock Text="DeepSeek API key:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <TextBox Text="{Binding DeepSeekApiKey, Mode=TwoWay}" PasswordChar="*" PlaceholderText="sk-..." MinWidth="280"/>
        </StackPanel>

        <StackPanel Spacing="6" IsVisible="{Binding IsCursorAcpSelected}">
            <TextBlock Text="Cursor ACP: путь к cursor-agent.cmd или к папке с dist-package" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}" TextWrapping="Wrap"/>
            <TextBox Text="{Binding CursorAcpAgentPath, Mode=TwoWay}"
                     PlaceholderText="...\dist-package  или  ...\cursor-agent.cmd"
                     MinWidth="280"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Отправка сообщения в чате:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <ComboBox ItemsSource="{Binding SendMessageKeyOptionsList}" SelectedItem="{Binding SendMessageKey}" MinWidth="140"/>
        </StackPanel>

        <CheckBox Content="Минимальный контекст (только диагностики и сигнатуры)" IsChecked="{Binding UseMinimizedContext}" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
        <CheckBox Content="Чат только через MCP (не вызывать встроенный LLM; ответ ассистента — send_chat с role=assistant)"
                  IsChecked="{Binding ChatMcpOnly}"
                  Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
        <CheckBox Content="Показывать thinking/reasoning в истории (если выключено — только live во время ответа)"
                  IsChecked="{Binding ShowThinkingInHistory}"
                  Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
        <CheckBox Content="Cursor ACP: автоматически передавать MCP IDE в сессию агента (cascade-ide → текущий exe + --mcp-stdio)"
                  IsChecked="{Binding AcpAutoInjectIdeMcp}"
                  Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>

        <TextBlock Text="Внешние MCP-серверы (autonomous и Cursor ACP), JSON:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}" Margin="0,12,0,0" TextWrapping="Wrap"/>
        <TextBox Text="{Binding ExternalMcpServersJson, Mode=TwoWay}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 FontFamily="Consolas,monospace"
                 FontSize="11"
                 MinHeight="110"/>
    </StackPanel>
</UserControl>
