<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CascadeIDE.ViewModels"
             x:Class="CascadeIDE.Views.AiChatSettingsPanelView"
             x:DataType="vm:MainWindowViewModel">
    <StackPanel Spacing="14">
        <StackPanel Spacing="6">
            <TextBlock Text="Режим AI (settings.toml: ai.mode):" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <ComboBox ItemsSource="{Binding AiModeOptionsList}" SelectedItem="{Binding AiMode}" MinWidth="200"/>
        </StackPanel>

        <StackPanel Spacing="6" IsVisible="{Binding IsAiCloudMode}">
            <TextBlock Text="Облако: провайдер (ai.cloud.active_provider):" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <ComboBox ItemsSource="{Binding AiCloudProviderKeysList}" SelectedItem="{Binding CloudActiveProvider}" MinWidth="200"/>
        </StackPanel>

        <StackPanel Spacing="6" IsVisible="{Binding IsOllamaSelected}">
            <TextBlock Text="Модель Ollama:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <ComboBox ItemsSource="{Binding OllamaModelChoices}"
                      SelectedItem="{Binding SelectedOllamaModel}"
                      MinWidth="240"
                      IsEnabled="{Binding OllamaAvailable}"/>
            <TextBlock Text="{Binding SelectedModelDetails}" FontSize="11" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Spacing="6" IsVisible="{Binding IsAnthropicSelected}">
            <TextBlock Text="Anthropic API key:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <TextBox Text="{Binding AnthropicApiKey, Mode=TwoWay}" PasswordChar="*" PlaceholderText="sk-ant-..." MinWidth="280"/>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding IsOpenAiSelected}">
            <TextBlock Text="OpenAI API key:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <TextBox Text="{Binding OpenAiApiKey, Mode=TwoWay}" PasswordChar="*" PlaceholderText="sk-..." MinWidth="280"/>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding IsDeepSeekSelected}">
            <TextBlock Text="DeepSeek API key:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <TextBox Text="{Binding DeepSeekApiKey, Mode=TwoWay}" PasswordChar="*" PlaceholderText="sk-..." MinWidth="280"/>
        </StackPanel>

        <StackPanel Spacing="6" IsVisible="{Binding IsCursorAcpSelected}">
            <TextBlock Text="Cursor ACP: путь к cursor-agent.cmd или к папке с dist-package" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}" TextWrapping="Wrap"/>
            <TextBox Text="{Binding CursorAcpAgentPath, Mode=TwoWay}"
                     PlaceholderText="...\dist-package  или  ...\cursor-agent.cmd"
                     MinWidth="280"
                     TextWrapping="Wrap"/>
            <TextBlock Text="Модель Cursor ACP (список подставляется после первого ответа в чате; предпочтение сохраняется в настройках)" FontSize="11" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}" TextWrapping="Wrap"/>
            <ComboBox ItemsSource="{Binding ChatPanel.CursorAcpModelPicks}"
                      SelectedItem="{Binding ChatPanel.SelectedCursorAcpModelPick}"
                      MinWidth="280"
                      PlaceholderText="Нет данных — отправь сообщение в чат"/>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Отправка сообщения в чате:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <ComboBox ItemsSource="{Binding SendMessageKeyOptionsList}" SelectedItem="{Binding SendMessageKey}" MinWidth="140"/>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Плотность ленты Intercom (settings.toml: [intercom] feed_metrics):" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}" TextWrapping="Wrap"/>
            <ComboBox ItemsSource="{Binding IntercomFeedMetricsOptionsList}" SelectedItem="{Binding IntercomFeedMetrics}" MinWidth="200"/>
            <TextBlock Text="comfortable — prose_pt, просторная лента; compact — prose_pt_forward и плотные отступы (как раньше на Forward)."
                       FontSize="11"
                       Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <CheckBox Content="Минимальный контекст (только диагностики и сигнатуры)" IsChecked="{Binding UseMinimizedContext}" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
        <CheckBox Content="Показывать thinking/reasoning в истории (если выключено — только live во время ответа)"
                  IsChecked="{Binding ShowThinkingInHistory}"
                  Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
        <CheckBox Content="Cursor ACP: автоматически передавать MCP IDE в сессию агента (cascade-ide → текущий exe + --mcp-stdio)"
                  IsChecked="{Binding AcpAutoInjectIdeMcp}"
                  Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>

        <TextBlock Text="Внешние MCP-серверы (autonomous и Cursor ACP), JSON:" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}" Margin="0,12,0,0" TextWrapping="Wrap"/>
        <TextBox Text="{Binding ExternalMcpServersJson, Mode=TwoWay}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 FontFamily="Consolas,monospace"
                 FontSize="11"
                 MinHeight="110"/>

        <TextBlock Text="Team transport (Intercom FederatedSync, ADR 0144)" FontWeight="SemiBold" Margin="0,16,0,0"
                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
        <CheckBox Content="Включить transport ([intercom.transport] enabled)" IsChecked="{Binding IntercomTransportEnabled}"
                  Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
        <StackPanel Spacing="4">
            <TextBlock Text="base_url (reference intercom-service):" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <TextBox Text="{Binding IntercomTransportBaseUrl, Mode=TwoWay}" PlaceholderText="http://127.0.0.1:5080" MinWidth="280"/>
        </StackPanel>
        <StackPanel Spacing="4">
            <TextBlock Text="local_server_path (относительно CascadeIDE.exe):" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <TextBox Text="{Binding IntercomTransportLocalServerPath, Mode=TwoWay}"
                     PlaceholderText="tools/intercom-service/IntercomService.exe" MinWidth="280"/>
        </StackPanel>
        <StackPanel Spacing="4">
            <TextBlock Text="team_id (пусто → .cascade-ide/intercom-team.toml):" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <TextBox Text="{Binding IntercomTransportTeamId, Mode=TwoWay}" MinWidth="280"/>
        </StackPanel>
        <StackPanel Spacing="4">
            <TextBlock Text="OAuth provider (github | oidc):" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <ComboBox ItemsSource="{x:Static vm:MainWindowViewModel.IntercomOAuthProviderOptions}"
                      SelectedItem="{Binding IntercomTransportOAuthProvider, Mode=TwoWay}" MinWidth="200"/>
        </StackPanel>
        <StackPanel Spacing="4">
            <TextBlock Text="DEV team token (только локальная отладка):" Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <TextBox Text="{Binding IntercomTransportDevTeamToken, Mode=TwoWay}" PasswordChar="*" MinWidth="280"/>
        </StackPanel>
        <CheckBox Content="Auto Connect при первом human send" IsChecked="{Binding IntercomTransportAutoConnectOnSend}"
                  Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
        <CheckBox Content="Синхронизировать ответы ассистента в Channel" IsChecked="{Binding IntercomTransportSyncAgentChannelMessages}"
                  Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Connect Intercom" Command="{Binding ConnectIntercomTransportFromSettingsCommand}"/>
            <Button Content="Disconnect" Command="{Binding DisconnectIntercomTransportFromSettingsCommand}"/>
        </StackPanel>
        <TextBlock Text="{Binding IntercomTransportConnectionStatus}" TextWrapping="Wrap" FontSize="11"
                   Foreground="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
    </StackPanel>
</UserControl>
