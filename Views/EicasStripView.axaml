<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chrome="using:CascadeIDE.Features.UiChrome"
             xmlns:vm="using:CascadeIDE.ViewModels"
             xmlns:views="using:CascadeIDE.Views"
             x:Class="CascadeIDE.Views.EicasStripView"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Resources>
        <views:EicasSeverityToBrushConverter x:Key="EicasSevBrush"/>
    </UserControl.Resources>
    <Border Background="{DynamicResource CascadeTheme.McpBannerBackground}"
            BorderBrush="{DynamicResource CascadeTheme.BuildOutputBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="8,4">
        <ItemsControl ItemsSource="{Binding EicasMessages}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="12"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="chrome:EicasMessage">
                    <TextBlock Text="{Binding Text}"
                               Foreground="{Binding Severity, Converter={StaticResource EicasSevBrush}}"
                               VerticalAlignment="Center"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</UserControl>
