<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CascadeIDE.App"
             xmlns:local="using:CascadeIDE"
             xmlns:lang="using:CascadeIDE.Lang"
             xmlns:views="using:CascadeIDE.Views"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
        <ResourceDictionary>
            <lang:LocViewModel x:Key="Loc"/>
            <!-- Тема: ide_get_ui_theme / ide_set_ui_theme -->
            <SolidColorBrush x:Key="CascadeTheme.MainWindowBackground">#F5F5F5</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.MenuBackground">#F0F0F0</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.MenuForeground">#1A1A1A</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.ButtonBackground">#E0E0E0</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.ButtonForeground">#1A1A1A</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.ButtonBorderBrush">#BBB</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.ButtonHoverBackground">#D0D0D0</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.ButtonDisabledBackground">#EEE</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.ButtonDisabledForeground">#888</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.ToolbarBackground">#E8E8E8</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.ToolbarTextForeground">#333</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.ToolbarErrorForeground">#C00</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.EditorBackground">#FFF</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.EditorForeground">#1A1A1A</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.EditorSelectionBrush" Color="#55225679"/>
            <SolidColorBrush x:Key="CascadeTheme.EditorSelectionForeground">#1A1A1A</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.EditorColumnBorderBrush">#CCC</SolidColorBrush>
            <!-- Editor HUD: squiggles = те же sRGB, что MFD/Problems (EditorHudDiagnosticsChroma) -->
            <SolidColorBrush x:Key="EditorHud.SeverityError">#B25C62</SolidColorBrush>
            <SolidColorBrush x:Key="EditorHud.SeverityWarning">#A88A48</SolidColorBrush>
            <SolidColorBrush x:Key="EditorHud.SeverityInfo">#608296</SolidColorBrush>
            <!-- Рамки колонок (решение / редактор / чат), вертикальные сплиттеры, шов с нижней панелью -->
            <SolidColorBrush x:Key="CascadeTheme.WorkspacePanelBorderBrush">#CCC</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.EditorColumnBackground">#FFF</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.CurrentFileForeground">#666</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.MarkdownPreviewPanelBackground">#FAFAFA</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.MarkdownPreviewPanelBorderBrush">#E0E0E0</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.SolutionExplorerBorderBrush">#CCC</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.SolutionExplorerHeaderForeground">#1A1A1A</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PanelChromeTitleForeground">#1E2433</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PanelTitleAccentBrush">#4B6BFB</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PanelChromeHeaderBackground">#E4E9F2</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PanelChromeHeaderSeparatorBrush">#B8C4D8</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PanelChromeMenuGlyphForeground">#666</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.BuildOutputBackground">#F8F8F8</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.BuildOutputBorderBrush">#CCC</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.ChatPanelBackground">#FFF</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.ChatLabelForeground">#333</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.ChatMessageBubbleBackground">#F0F0F0</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.ChatMessageContentForeground">#1A1A1A</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PanelBackgroundBrush">#F0F0F0</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.InsetSurfaceBackground">#FAFAFA</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.InsetSurfaceBorderBrush">#CCC</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.StatusChipBackground">#E3EAF5</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.StatusChipBorderBrush">#B8C4D8</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.StatusChipForeground">#1E3A5F</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.SendButtonBackground">#4CAF50</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.SendButtonForeground">White</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.TerminalBackground">#1E1E1E</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.TerminalForeground">#CCC</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.TerminalInputBackground">#2D2D2D</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.McpBannerBackground">#E3F2FD</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.McpBannerForeground">#1565C0</SolidColorBrush>
            <!-- Тултипы IDE: спокойный тёмный хром (не «жёлтый Win95») -->
            <SolidColorBrush x:Key="CascadeTheme.ToolTipBackground">#2A303C</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.ToolTipForeground">#E6ECF4</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.ToolTipBorderBrush">#4A5568</SolidColorBrush>
            <!-- Полоса HUD над редактором: без кислотно-жёлтого, в ритме панелей -->
            <SolidColorBrush x:Key="CascadeTheme.HudBannerBackground">#180C1018</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.HudBannerBorderBrush">#354050</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.HudBannerForeground">#D8DEE8</SolidColorBrush>
            <!-- Палитра команд (IDS overlay): плотный контрастный слой поверх Fluent; токены вместо «магических» # в разметке -->
            <SolidColorBrush x:Key="CascadeTheme.CommandPaletteDimmerOverlay">#AA000000</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.CommandPaletteSurfaceBackground">#11161F</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.CommandPaletteSurfaceBorderBrush">#3D4A5C</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.CommandPaletteQueryBackground">#141B26</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.CommandPaletteQueryForeground">#E8EDF4</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.CommandPaletteQueryPlaceholderForeground">#6B7788</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.CommandPaletteQueryCaretBrush">#A8C8FF</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.CommandPaletteTitleForeground">#F0F4FA</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.CommandPaletteMetaForeground">#9AA6B8</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.CommandPaletteItemHoverBackground">#283445</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.CommandPaletteItemSelectedBackground">#324560</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.CommandPaletteHotkeyPillBackground">#1A2333</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.CommandPaletteHotkeyPillBorderBrush">#4A5C72</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.CommandPaletteHotkeyPillForeground">#C5D0E0</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.CommandPaletteUnavailableForeground">#E8B86A</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PreviewWindowBackground">#F0F0F0</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PowerNeonBorder">#00C8E8</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PowerNeonAccent">#BF5FFF</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PowerCockpitPanelBackground">#0C1428</SolidColorBrush>
            <!-- Отдельный «док» уровней L1–L3 (темнее тела чата, по концепту cockpit) -->
            <SolidColorBrush x:Key="CascadeTheme.PowerSafetyDockBackground">#060A14</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PowerWorkspaceHealthStripBackground">#080E18</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PowerSafetyL1">#2A5A8A</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PowerSafetyL2">#8A6A1A</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PowerSafetyL3">#5A2A8A</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PowerEmergency">#E02040</SolidColorBrush>
            <!-- Градиентные каймы «островов» Power cockpit (концепт: редактор cyan→blue, чат purple→pink) -->
            <LinearGradientBrush x:Key="CascadeTheme.PowerEditorIslandFrameBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#00E5FF"/>
                <GradientStop Offset="0.5" Color="#3A78D4"/>
                <GradientStop Offset="1" Color="#6B9DFF"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="CascadeTheme.PowerChatIslandFrameBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#D080FF"/>
                <GradientStop Offset="0.42" Color="#FF6B9D"/>
                <GradientStop Offset="1" Color="#00B8D8"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="CascadeTheme.PowerSolutionIslandFrameBrush" StartPoint="0%,0%" EndPoint="100%,0%">
                <GradientStop Offset="0" Color="#284A5C"/>
                <GradientStop Offset="1" Color="#142A3A"/>
            </LinearGradientBrush>
            <!-- Дерево решения в Power cockpit (тёмная панель, строки, акцент выбора) -->
            <SolidColorBrush x:Key="CascadeTheme.PowerSolutionTreePanelBackground">#0A1018</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PowerSolutionTreeForeground">#D6E4F0</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PowerSolutionTreeItemSelectedBackground">#163248</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PowerSolutionTreeItemPointerOverBackground">#122030</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PowerSolutionPanelBorderSubtle">#2A4A60</SolidColorBrush>
            <SolidColorBrush x:Key="CascadeTheme.PowerSolutionTaskQueueBubbleBackground">#152A38</SolidColorBrush>
            <views:UiModeFamilyEqualsConverter x:Key="UiModeFamilyEq"/>
            <views:UiModeFamilyNotEqualsConverter x:Key="UiModeFamilyNe"/>
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <!-- v12 Fluent: без непрозрачного PART_WindowBorder клиент окна на Windows может не заливаться (сквозь рамку виден рабочий стол). -->
        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.MainWindowBackground}"/>
        </Style>
        <Style Selector="Window /template/ Border#PART_WindowBorder">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.MainWindowBackground}"/>
        </Style>
        <Style Selector="Window /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.MainWindowBackground}"/>
        </Style>
        <!-- SukiUI: пакет 6.0.3 не совместим с Avalonia 12 (MissingMethodException в SukiTheme/TextBox.axaml). Вернуть после релиза Suki под v12. -->
        <StyleInclude Source="avares://Dock.Avalonia.Themes.Fluent/DockFluentTheme.axaml"/>
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
        <!-- Заголовки панелей: полоса + разделитель + акцент (концепт Power cockpit) -->
        <Style Selector="Border.panelChromeHeaderStrip">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.PanelChromeHeaderBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.PanelChromeHeaderSeparatorBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,8,10,8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style Selector="Border.panelTitleAccent">
            <Setter Property="Width" Value="4"/>
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="MaxHeight" Value="26"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.PanelTitleAccentBrush}"/>
        </Style>
        <Style Selector="TextBlock.panelChromeTitle">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="0.85"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.PanelChromeTitleForeground}"/>
        </Style>
        <Style Selector="TextBlock.panelChromeTitleCaps">
            <Setter Property="LetterSpacing" Value="1.35"/>
        </Style>
        <Style Selector="Button.panelChromeOverflowBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0,2,0"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.PanelChromeMenuGlyphForeground}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.72"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.panelChromeOverflowBtn:pointerover">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Background" Value="#14000000"/>
        </Style>
        <Style Selector="Button.panelChromeEmergencyBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.panelChromeEmergencyBtn:pointerover">
            <Setter Property="Background" Value="#28FFFFFF"/>
        </Style>
        <Style Selector="TextBlock.panelDocumentPathTitle">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="0.2"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.PanelChromeTitleForeground}"/>
        </Style>
        <Style Selector="views|PanelChromeHeader.documentTitle TextBlock.headerTitlePart">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="0.2"/>
        </Style>
        <!-- Терминал (тёмный фон нижней панели): заголовок и меню-глиф как у консоли -->
        <Style Selector="views|PanelChromeHeader.terminal TextBlock.headerTitlePart">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.TerminalForeground}"/>
        </Style>
        <Style Selector="views|PanelChromeHeader.terminal Button.panelChromeOverflowBtn">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.TerminalForeground}"/>
            <Setter Property="Opacity" Value="0.55"/>
        </Style>
        <Style Selector="views|PanelChromeHeader.terminal Button.panelChromeOverflowBtn:pointerover">
            <Setter Property="Background" Value="#22FFFFFF"/>
        </Style>
        <!-- Power: заголовки колонки дерева / очереди — тёмная полоса, светлый текст, бирюзовый акцент -->
        <Style Selector="views|PanelChromeHeader.powerSolutionExplorer Border.panelChromeHeaderStrip">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.PowerWorkspaceHealthStripBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.PowerSolutionPanelBorderSubtle}"/>
        </Style>
        <Style Selector="views|PanelChromeHeader.powerSolutionExplorer TextBlock.headerTitlePart">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.PowerSolutionTreeForeground}"/>
        </Style>
        <Style Selector="views|PanelChromeHeader.powerSolutionExplorer TextBlock.panelChromeTitle">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.PowerSolutionTreeForeground}"/>
        </Style>
        <Style Selector="views|PanelChromeHeader.powerSolutionExplorer Button.panelChromeOverflowBtn">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.PowerSolutionTreeForeground}"/>
            <Setter Property="Opacity" Value="0.55"/>
        </Style>
        <Style Selector="views|PanelChromeHeader.powerSolutionExplorer Button.panelChromeOverflowBtn:pointerover">
            <Setter Property="Background" Value="#22FFFFFF"/>
        </Style>
        <Style Selector="views|PanelChromeHeader.powerSolutionExplorer Border.panelTitleAccent">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.PowerNeonBorder}"/>
        </Style>
        <!-- Внутри карточек чата: компактнее, цвет как у подписей карточки -->
        <Style Selector="views|PanelChromeHeader.compact Border.panelChromeHeaderStrip">
            <Setter Property="Padding" Value="8,6,6,6"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="views|PanelChromeHeader.compact TextBlock.headerTitlePart">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
        </Style>
        <Style Selector="views|PanelChromeHeader.compact Button.panelChromeOverflowBtn">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        <Style Selector="views|PanelChromeHeader.compact Button.panelChromeOverflowBtn:pointerover">
            <Setter Property="Background" Value="#18000000"/>
        </Style>
        <!-- IDE chrome (UiKit): секции, inset, status chip — design/ide-chrome-tokens-v1.md -->
        <Style Selector="Border.cascadeSection">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.PanelBackgroundBrush}"/>
        </Style>
        <Style Selector="Border.cascadeSection TextBox">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatPanelBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource CascadeTheme.EditorSelectionBrush}"/>
            <Setter Property="SelectionForegroundBrush" Value="{DynamicResource CascadeTheme.EditorSelectionForeground}"/>
        </Style>
        <Style Selector="Border.cascadeSection TextBox /template/ TextBlock#PART_Watermark">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ChatLabelForeground}"/>
        </Style>
        <Style Selector="Border.cascadeSection CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
        </Style>
        <Style Selector="Border.cascadeSection Expander">
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ChatMessageContentForeground}"/>
        </Style>
        <Style Selector="Border.ideHealthStrip">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBlock.ideHealthSegment">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.88"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ToolbarTextForeground}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="UserControl:not(.power) TreeView TreeViewItem">
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="MinHeight" Value="22"/>
        </Style>
        <Style Selector="UserControl:not(.power) TreeView TreeViewItem:pointerover">
            <Setter Property="Background" Value="#2A2D2E"/>
        </Style>
        <Style Selector="UserControl:not(.power) TreeView TreeViewItem:selected">
            <Setter Property="Background" Value="#2A3A4A"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.PanelTitleAccentBrush}"/>
            <Setter Property="BorderThickness" Value="2,0,0,0"/>
        </Style>
        <Style Selector="Border.cascadeInset">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.InsetSurfaceBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.InsetSurfaceBackground}"/>
        </Style>
        <Style Selector="Border.cascadeAutocomplete">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.EditorColumnBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ChatPanelBackground}"/>
        </Style>
        <Style Selector="Border.cascadeStatusChip">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.StatusChipBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.StatusChipBackground}"/>
        </Style>
        <!-- Глобально: тултипы ближе к VS/Cursor, чем к дефолтному Fluent-желту -->
        <Style Selector="ToolTip">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="MaxWidth" Value="480"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.ToolTipForeground}"/>
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.ToolTipBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.ToolTipBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="ToolTip TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <!-- Контекстные меню и всплывающие подменю: тот же хром, что у меню окна (Fluent + токены) -->
        <Style Selector="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.MenuBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CascadeTheme.MenuForeground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="MenuFlyoutPresenter">
            <Setter Property="Background" Value="{DynamicResource CascadeTheme.MenuBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CascadeTheme.WorkspacePanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Application.Styles>
</Application>